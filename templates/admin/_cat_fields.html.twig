{# templates/admin/_cat_fields.html.twig #}
<div class="field">
    <label class="field-label">
        {{ 'field.name'|trans({}, 'admin_categories') }} <span class="req">*</span>
    </label>
    <input type="text"
           id="cat-name-input"
           placeholder="{{ 'field.name_placeholder'|trans({}, 'admin_categories') }}"
           onkeydown="if(event.key==='Enter') saveCategory()">
    <div class="field-error" id="cat-name-error">{{ 'field.name_required'|trans({}, 'admin_categories') }}</div>
</div>
<p style="font-size:12px;color:var(--tx-6);line-height:1.5">
    💡 {{ 'hint.ai_translations'|trans({}, 'admin_categories') }}
</p>
