<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Admin{% endblock %} — QR Menu</title>

    <style>
        :root { --brand: #C1440E; }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: #0a0a0a;
            color: #fff;
            min-height: 100vh;
            display: flex;
        }

        /* ── Sidebar ── */
        .sidebar {
            width: 220px; flex-shrink: 0;
            background: #111;
            border-right: 1px solid #1c1c1c;
            display: flex; flex-direction: column;
            position: sticky; top: 0; height: 100vh;
        }
        .sidebar-header {
            padding: 16px;
            border-bottom: 1px solid #1c1c1c;
        }
        .sidebar-restaurant {
            font-size: 14px; font-weight: 600;
            color: #fff; letter-spacing: -0.3px;
            white-space: nowrap; overflow: hidden;
            text-overflow: ellipsis;
        }
        .sidebar-role {
            font-size: 11px; color: #555; margin-top: 2px;
        }

        .nav-section {
            font-size: 10px; font-weight: 600;
            color: #333; text-transform: uppercase;
            letter-spacing: 0.1em;
            padding: 14px 16px 4px;
        }
        .nav-item {
            display: flex; align-items: center; gap: 9px;
            padding: 9px 16px;
            font-size: 13px; color: #555;
            text-decoration: none;
            transition: color 0.1s, background 0.1s;
            border-right: 2px solid transparent;
        }
        .nav-item:hover { color: #ccc; background: #161616; }
        .nav-item.active {
            color: #fff; background: #161616;
            border-right-color: var(--brand);
            font-weight: 500;
        }
        .nav-item i { font-size: 16px; flex-shrink: 0; }

        .sidebar-footer {
            margin-top: auto;
            border-top: 1px solid #1c1c1c;
            padding: 8px 0;
        }

        /* ── Main ── */
        .main {
            flex: 1; display: flex;
            flex-direction: column;
            min-width: 0;
        }
        .main-header {
            padding: 14px 24px;
            border-bottom: 1px solid #1c1c1c;
            display: flex; align-items: center;
            justify-content: space-between;
            background: #111;
            position: sticky; top: 0; z-index: 100;
        }
        .main-header-title {
            font-size: 16px; font-weight: 600;
            color: #fff; letter-spacing: -0.3px;
        }
        .main-header-actions { display: flex; gap: 8px; }

        .btn {
            display: inline-flex; align-items: center; gap: 6px;
            padding: 7px 14px; border-radius: 8px;
            font-size: 13px; font-weight: 500;
            cursor: pointer; text-decoration: none;
            border: 1px solid #2a2a2a;
            background: #1a1a1a; color: #ccc;
            transition: border-color 0.15s, color 0.15s;
        }
        .btn:hover { border-color: #444; color: #fff; }
        .btn i { font-size: 15px; }

        .btn-primary {
            background: var(--brand);
            border-color: var(--brand); color: #fff;
        }
        .btn-primary:hover { opacity: 0.9; color: #fff; }

        .btn-ai {
            background: #2a2060;
            border-color: #534AB7; color: #a09aee;
        }
        .btn-ai:hover { background: #342870; color: #c0baff; }

        .main-body {
            flex: 1; padding: 24px;
            overflow-y: auto;
        }

        /* ── Flash messages ── */
        .flash {
            padding: 10px 16px; border-radius: 8px;
            font-size: 13px; margin-bottom: 16px;
            display: flex; align-items: center; gap: 8px;
        }
        .flash-success {
            background: rgba(40,80,10,0.2);
            border: 1px solid rgba(99,153,34,0.3);
            color: #7aad40;
        }
        .flash-error {
            background: rgba(193,68,14,0.15);
            border: 1px solid rgba(193,68,14,0.3);
            color: #F0997B;
        }
    </style>

    {% block stylesheets %}{% endblock %}
</head>
<body>

{# ── Sidebar ── #}
<aside class="sidebar">
    <div class="sidebar-header">
        <div class="sidebar-restaurant">
            {{ app.user.restaurant ? app.user.restaurant.name : 'QR Menu' }}
        </div>
        <div class="sidebar-role">Panel de administración</div>
    </div>

    <div class="nav-section">Menú</div>
    <a href="{{ path('admin_menu') }}"
       class="nav-item {{ app.request.attributes.get('_route') starts with 'admin_menu' ? 'active' : '' }}">
        <i class="ti ti-layout-list" aria-hidden="true"></i> Carta
    </a>
    <a href="{{ path('admin_categories') }}"
       class="nav-item {{ app.request.attributes.get('_route') starts with 'admin_categor' ? 'active' : '' }}">
        <i class="ti ti-category" aria-hidden="true"></i> Categorías
    </a>
    <a href="{{ path('admin_tags') }}"
       class="nav-item {{ app.request.attributes.get('_route') starts with 'admin_tag' ? 'active' : '' }}">
        <i class="ti ti-tag" aria-hidden="true"></i> Etiquetas
    </a>

    <div class="nav-section">Restaurante</div>
    <a href="{{ path('admin_tables') }}"
       class="nav-item {{ app.request.attributes.get('_route') starts with 'admin_table' ? 'active' : '' }}">
        <i class="ti ti-table" aria-hidden="true"></i> Mesas y QRs
    </a>
    <a href="{{ path('admin_settings') }}"
       class="nav-item {{ app.request.attributes.get('_route') starts with 'admin_setting' ? 'active' : '' }}">
        <i class="ti ti-settings" aria-hidden="true"></i> Configuración
    </a>

    <div class="sidebar-footer">
        {% if app.user.restaurant %}
            <a href="{{ path('menu_show', {
                slug: app.user.restaurant.slug,
                qrToken: app.user.restaurant.tables.first ? app.user.restaurant.tables.first.qrToken : 'preview'
            }) }}"
               target="_blank"
               class="nav-item">
                <i class="ti ti-external-link" aria-hidden="true"></i> Ver carta
            </a>
        {% endif %}
        <a href="{{ path('admin_logout') }}" class="nav-item">
            <i class="ti ti-logout" aria-hidden="true"></i> Cerrar sesión
        </a>
    </div>
</aside>

{# ── Main ── #}
<main class="main">
    <div class="main-header">
        <div class="main-header-title">{% block page_title %}{% endblock %}</div>
        <div class="main-header-actions">{% block header_actions %}{% endblock %}</div>
    </div>

    <div class="main-body">
        {% for message in app.flashes('success') %}
            <div class="flash flash-success">
                <i class="ti ti-check" style="font-size:15px" aria-hidden="true"></i>
                {{ message }}
            </div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="flash flash-error">
                <i class="ti ti-alert-circle" style="font-size:15px" aria-hidden="true"></i>
                {{ message }}
            </div>
        {% endfor %}

        {% block body %}{% endblock %}
    </div>
</main>

{% block javascripts %}{% endblock %}

</body>
</html>
