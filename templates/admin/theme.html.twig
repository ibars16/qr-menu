{% extends 'admin/base.html.twig' %}

{% block title %}{{ 'title'|trans({}, 'admin_theme') }}{% endblock %}
{% block page_title %}{{ 'title'|trans({}, 'admin_theme') }}{% endblock %}

{% block stylesheets %}
<style>
    .customizer { max-width: 840px; }

    /* ── Confirmation modal ── */
    .confirm-backdrop {
        position: fixed; inset: 0; z-index: 2000;
        background: var(--overlay); backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
        display: flex; align-items: center; justify-content: center;
        opacity: 0; pointer-events: none; transition: opacity 0.18s;
        padding: 16px;
    }
    .confirm-backdrop.show { opacity: 1; pointer-events: all; }
    .confirm-modal {
        background: var(--bg-card); border: 1px solid var(--bd-3); border-radius: 18px;
        padding: 28px 26px 24px; width: 340px; max-width: 100%;
        box-shadow: 0 32px 80px rgba(0,0,0,0.4);
        transform: translateY(10px) scale(0.96); transition: transform 0.22s cubic-bezier(0.34,1.56,0.64,1);
    }
    .confirm-backdrop.show .confirm-modal { transform: none; }
    .confirm-title { font-size: 17px; font-weight: 700; color: var(--tx-hi); letter-spacing: -0.4px; margin-bottom: 7px; line-height: 1.3; }
    .confirm-sub   { font-size: 13px; color: var(--tx-5); line-height: 1.6; margin-bottom: 22px; }
    .confirm-btns  { display: flex; gap: 8px; }
    .confirm-cancel { flex: 1; padding: 11px; border-radius: 11px; border: 1px solid var(--bd-3); background: transparent; color: var(--tx-5); font-size: 14px; cursor: pointer; transition: border-color 0.15s, color 0.15s; }
    .confirm-cancel:hover { border-color: var(--bd-2); color: var(--tx-1); }
    .confirm-apply  { flex: 1.6; padding: 11px; border-radius: 11px; border: none; background: #C1440E; color: #fff; font-size: 14px; font-weight: 600; cursor: pointer; transition: opacity 0.15s; letter-spacing: -0.2px; }
    .confirm-apply:hover    { opacity: 0.86; }
    .confirm-apply:disabled { opacity: 0.45; cursor: default; }

    /* ── Preview bar ── */
    .preview-bar {
        display: none; align-items: center; gap: 12px;
        background: #0c091c; border: 1.5px solid #332e60; border-radius: 13px;
        padding: 11px 14px; margin-bottom: 26px;
    }
    .preview-bar.show { display: flex; }
    .preview-dot { width: 7px; height: 7px; border-radius: 50%; background: #a78bfa; flex-shrink: 0; animation: dot-pulse 2.2s ease-in-out infinite; }
    @keyframes dot-pulse { 0%,100% { opacity: 1; transform: scale(1); } 50% { opacity: 0.3; transform: scale(0.8); } }
    .preview-bar-text { flex: 1; min-width: 0; }
    .preview-bar-title { font-size: 13px; font-weight: 600; color: #c4b5fd; line-height: 1.3; }
    .preview-bar-sub   { font-size: 11px; color: #5a508a; margin-top: 2px; }
    .preview-bar-btns  { display: flex; gap: 7px; flex-shrink: 0; }

    /* ── Section header ── */
    .sec-hdr { margin-bottom: 18px; }
    .sec-eyebrow { font-size: 10px; font-weight: 700; color: var(--tx-7); text-transform: uppercase; letter-spacing: 0.13em; margin-bottom: 3px; }
    .sec-title   { font-size: 18px; font-weight: 700; color: var(--tx-hi); letter-spacing: -0.4px; }
    .sec-desc    { font-size: 13px; color: var(--tx-6); margin-top: 4px; }
    .sec-divider { height: 1px; background: linear-gradient(90deg, transparent, var(--bd-1) 30%, var(--bd-1) 70%, transparent); margin: 34px 0; }

    /* ── Shared card styles ── */
    .sel-card {
        border: 1.5px solid var(--bd-1); border-radius: 14px; overflow: hidden;
        background: var(--bg-card); cursor: pointer;
        transition: border-color 0.2s, box-shadow 0.2s, transform 0.15s;
    }
    .sel-card:hover { border-color: var(--bd-2); transform: translateY(-1px); }
    .sel-card.is-active {
        border-color: #C1440E;
        box-shadow: 0 0 0 3px rgba(193,68,14,0.1), 0 8px 24px rgba(193,68,14,0.06);
    }
    .sel-card.is-preview {
        border-color: #534AB7;
        box-shadow: 0 0 0 3px rgba(83,74,183,0.1);
    }
    .card-footer { padding: 11px 13px 13px; border-top: 1px solid var(--bd-1); }
    .card-label  { font-size: 13px; font-weight: 600; color: var(--tx-1); margin-bottom: 2px; letter-spacing: -0.2px; }
    .card-desc   { font-size: 11px; color: var(--tx-6); line-height: 1.5; margin-bottom: 9px; }
    .active-chip {
        display: inline-flex; align-items: center; gap: 4px;
        font-size: 10px; font-weight: 700; padding: 2px 9px; border-radius: 20px;
        background: rgba(193,68,14,0.12); color: #C1440E;
        border: 1px solid rgba(193,68,14,0.18); margin-bottom: 10px;
    }
    .card-actions { display: flex; gap: 7px; }
    .btn-eye {
        flex: 1; padding: 8px 6px; border-radius: 9px; font-size: 11px; font-weight: 500;
        border: 1px solid var(--bd-1); background: var(--bg-input); color: var(--tx-5);
        cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 4px;
        transition: all 0.15s;
    }
    .btn-eye:hover  { border-color: #534AB7; color: #a78bfa; background: rgba(83,74,183,0.08); }
    .btn-eye.active { border-color: #534AB7; color: #a78bfa; background: rgba(83,74,183,0.12); }
    .btn-use {
        flex: 1; padding: 8px 6px; border-radius: 9px; font-size: 12px; font-weight: 600;
        border: none; background: #C1440E; color: #fff;
        cursor: pointer; transition: opacity 0.15s;
    }
    .btn-use:hover { opacity: 0.84; }
    .btn-use.is-current { background: var(--bg-hover); border: 1px solid var(--bd-1); color: var(--tx-8); cursor: default; }
    .btn-use.is-current:hover { opacity: 1; }

    /* ── Layout cards ── */
    .layouts-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 10px; }
    @media (max-width: 580px) { .layouts-grid { grid-template-columns: 1fr; } }

    .layout-thumb { height: 148px; background: #060606; overflow: hidden; display: flex; flex-direction: column; }

    /* Standard: full-width stacked portrait cards (one per row) */
    .lt-stdstack  { display: flex; flex-direction: column; gap: 6px; padding: 9px; flex: 1; }
    .lt-stdcard   { flex: 1; background: #111; border-radius: 8px; overflow: hidden; border: 1px solid #1e1e1e; display: flex; flex-direction: column; }
    .lt-stdimg    { flex: 0 0 34px; background: #181818; display: flex; align-items: center; justify-content: center; font-size: 18px; }
    .lt-stdbody   { flex: 1; padding: 5px 9px 6px; display: flex; flex-direction: column; justify-content: space-between; }
    .lt-stdname   { height: 5px; background: #272727; border-radius: 3px; width: 65%; }
    .lt-stdbot    { display: flex; align-items: center; justify-content: space-between; }
    .lt-stdprice  { font-size: 8px; font-weight: 800; color: #C1440E; }
    .lt-stdhint   { height: 7px; width: 26px; background: #181818; border: 1px solid #252525; border-radius: 8px; }

    /* Compact: numbered list rows */
    .lt-compact-wrap { display: flex; flex-direction: column; flex: 1; }
    .lt-crow  { display: flex; align-items: center; gap: 6px; padding: 6px 10px; border-bottom: 1px solid #0e0e0e; }
    .lt-num   { font-size: 8px; font-weight: 700; color: #383838; width: 14px; flex-shrink: 0; text-align: right; }
    .lt-cimg  { width: 22px; height: 22px; border-radius: 4px; background: #181818; flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-size: 11px; }
    .lt-cname { flex: 1; height: 5px; background: #242424; border-radius: 3px; }
    .lt-cprice{ font-size: 8px; font-weight: 700; color: #555; }

    /* Grid: 2×2 image-heavy portrait cells */
    .lt-grid  { display: grid; grid-template-columns: 1fr 1fr; grid-template-rows: 1fr 1fr; gap: 6px; padding: 9px; flex: 1; }
    .lt-gcell { background: #111; border-radius: 8px; overflow: hidden; border: 1px solid #1e1e1e; display: flex; flex-direction: column; }
    .lt-gimg  { flex: 0 0 40px; display: flex; align-items: center; justify-content: center; font-size: 16px; background: #181818; }
    .lt-gbody { flex: 1; padding: 4px 6px; display: flex; flex-direction: column; justify-content: space-between; }
    .lt-gname { height: 4px; background: #272727; border-radius: 3px; width: 82%; }
    .lt-gprice{ font-size: 7px; font-weight: 800; color: #C1440E; }

    /* ── Theme cards ── */
    .themes-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(218px,1fr)); gap: 10px; }
    @media (max-width: 500px) { .themes-grid { grid-template-columns: 1fr 1fr; } }
    @media (max-width: 360px) { .themes-grid { grid-template-columns: 1fr; } }

    /* Theme swatch — mini UI with portrait cards */
    .theme-swatch { height: 158px; padding: 8px 9px; display: flex; flex-direction: column; gap: 5px; overflow: hidden; position: relative; }

    /* Swatch header */
    .sw-hdr   { display: flex; align-items: center; gap: 5px; padding: 4px 6px; border-radius: 5px; flex-shrink: 0; border-width: 1px; border-style: solid; }
    .sw-logo  { width: 11px; height: 11px; border-radius: 2px; flex-shrink: 0; }
    .sw-brand { height: 4px; border-radius: 3px; width: 38px; opacity: 0.7; }

    /* Swatch tabs */
    .sw-tabs  { display: flex; gap: 3px; flex-shrink: 0; }
    .sw-tab   { height: 8px; border-radius: 8px; width: 22px; opacity: 0.18; }
    .sw-tab.on{ width: 28px; opacity: 1; }

    /* Swatch portrait mini-cards */
    .sw-cards { display: flex; gap: 4px; flex: 1; min-height: 0; }
    .sw-card  { flex: 1; display: flex; flex-direction: column; overflow: hidden; border-width: 1px; border-style: solid; }
    .sw-cimg  { flex: 0 0 46px; }
    .sw-cbody { flex: 1; padding: 4px 5px; display: flex; flex-direction: column; justify-content: space-between; }
    .sw-cname { height: 4px; border-radius: 3px; width: 72%; }
    .sw-cname2{ height: 3px; border-radius: 3px; width: 48%; margin-top: 2px; opacity: 0.32; }
    .sw-cprice{ font-size: 8px; font-weight: 800; letter-spacing: -0.2px; }
</style>
{% endblock %}

{% block body %}
<div class="customizer">

    {# ── Confirmation modal ── #}
    <div class="confirm-backdrop" id="confirm-backdrop">
        <div class="confirm-modal">
            <div class="confirm-title" id="confirm-title">{{ 'confirm.default_title'|trans({}, 'admin_theme') }}</div>
            <div class="confirm-sub" id="confirm-sub">{{ 'confirm.default_sub'|trans({}, 'admin_theme') }}</div>
            <div class="confirm-btns">
                <button class="confirm-cancel" onclick="closeConfirm()">{{ 'confirm.cancel'|trans({}, 'admin_theme') }}</button>
                <button class="confirm-apply" id="confirm-apply-btn" onclick="doConfirm()">{{ 'confirm.apply_now'|trans({}, 'admin_theme') }}</button>
            </div>
        </div>
    </div>

    {# ── Preview bar ── #}
    <div class="preview-bar" id="preview-bar">
        <div class="preview-dot"></div>
        <div class="preview-bar-text">
            <div class="preview-bar-title" id="preview-bar-title">{{ 'preview.active_title'|trans({}, 'admin_theme') }}</div>
            <div class="preview-bar-sub">{{ 'preview.active_sub'|trans({}, 'admin_theme') }}</div>
        </div>
        <div class="preview-bar-btns">
            <button class="btn btn-sm btn-secondary" onclick="cancelPreview()">{{ 'preview.close'|trans({}, 'admin_theme') }}</button>
            <button class="btn btn-sm btn-primary" onclick="applyFromBar()">{{ 'preview.apply'|trans({}, 'admin_theme') }}</button>
        </div>
    </div>

    {# ── Layouts ── #}
    <div class="sec-hdr">
        <div class="sec-eyebrow">{{ 'section.step1_eyebrow'|trans({}, 'admin_theme') }}</div>
        <div class="sec-title">{{ 'section.layout_title'|trans({}, 'admin_theme') }}</div>
        <div class="sec-desc">{{ 'section.layout_desc'|trans({}, 'admin_theme') }}</div>
    </div>

    <div class="layouts-grid">
        {% for key, layout in layouts %}
            <div class="sel-card {{ restaurant.layout == key ? 'is-active' : '' }}" id="lcard-{{ key }}">
                <div class="layout-thumb">
                    {% if key == 'standard' %}
                        <div class="lt-stdstack">
                            <div class="lt-stdcard">
                                <div class="lt-stdimg">🥩</div>
                                <div class="lt-stdbody">
                                    <div class="lt-stdname"></div>
                                    <div class="lt-stdbot"><div class="lt-stdprice">24 €</div><div class="lt-stdhint"></div></div>
                                </div>
                            </div>
                            <div class="lt-stdcard">
                                <div class="lt-stdimg">🥗</div>
                                <div class="lt-stdbody">
                                    <div class="lt-stdname"></div>
                                    <div class="lt-stdbot"><div class="lt-stdprice">16 €</div><div class="lt-stdhint"></div></div>
                                </div>
                            </div>
                        </div>
                    {% elseif key == 'compact' %}
                        <div class="lt-compact-wrap">
                            <div class="lt-crow"><div class="lt-num">01</div><div class="lt-cimg">🥩</div><div class="lt-cname"></div><div class="lt-cprice">24 €</div></div>
                            <div class="lt-crow"><div class="lt-num">02</div><div class="lt-cimg">🥗</div><div class="lt-cname"></div><div class="lt-cprice">16 €</div></div>
                            <div class="lt-crow"><div class="lt-num">03</div><div class="lt-cimg">🍕</div><div class="lt-cname"></div><div class="lt-cprice">14 €</div></div>
                            <div class="lt-crow"><div class="lt-num">04</div><div class="lt-cimg">🥑</div><div class="lt-cname"></div><div class="lt-cprice">18 €</div></div>
                            <div class="lt-crow"><div class="lt-num">05</div><div class="lt-cimg">🦐</div><div class="lt-cname"></div><div class="lt-cprice">22 €</div></div>
                        </div>
                    {% else %}
                        <div class="lt-grid">
                            <div class="lt-gcell"><div class="lt-gimg">🥩</div><div class="lt-gbody"><div class="lt-gname"></div><div class="lt-gprice">24 €</div></div></div>
                            <div class="lt-gcell"><div class="lt-gimg">🥗</div><div class="lt-gbody"><div class="lt-gname"></div><div class="lt-gprice">16 €</div></div></div>
                            <div class="lt-gcell"><div class="lt-gimg">🍕</div><div class="lt-gbody"><div class="lt-gname"></div><div class="lt-gprice">14 €</div></div></div>
                            <div class="lt-gcell"><div class="lt-gimg">🦐</div><div class="lt-gbody"><div class="lt-gname"></div><div class="lt-gprice">22 €</div></div></div>
                        </div>
                    {% endif %}
                </div>
                <div class="card-footer">
                    <div class="card-label">{{ layout.icon }} {{ ('layout.' ~ key ~ '.name')|trans({}, 'admin_theme') }}</div>
                    <div class="card-desc">{{ ('layout.' ~ key ~ '.desc')|trans({}, 'admin_theme') }}</div>
                    {% if restaurant.layout == key %}<div class="active-chip">✓ {{ 'card.active_label'|trans({}, 'admin_theme') }}</div>{% endif %}
                    <div class="card-actions">
                        <button class="btn-eye" id="lprev-{{ key }}" onclick="previewLayout('{{ key }}')">
                            <i class="ti ti-eye"></i> {{ 'card.preview_action'|trans({}, 'admin_theme') }}
                        </button>
                        <button class="btn-use {{ restaurant.layout == key ? 'is-current' : '' }}" onclick="selectLayout('{{ key }}')">
                            {{ restaurant.layout == key ? '✓ ' ~ 'card.active_label'|trans({}, 'admin_theme') : 'card.use_action'|trans({}, 'admin_theme') }}
                        </button>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>

    <div class="sec-divider"></div>

    {# ── Themes ── #}
    <div class="sec-hdr">
        <div class="sec-eyebrow">{{ 'section.step2_eyebrow'|trans({}, 'admin_theme') }}</div>
        <div class="sec-title">{{ 'section.theme_title'|trans({}, 'admin_theme') }}</div>
        <div class="sec-desc">{{ 'section.theme_desc'|trans({}, 'admin_theme') }}</div>
    </div>

    <div class="themes-grid">
        {% for key, thm in themes %}
            <div class="sel-card {{ restaurant.theme == key ? 'is-active' : '' }}" id="tcard-{{ key }}">

                {# Mini UI preview swatch #}
                <div class="theme-swatch" style="background:{{ thm.preview_bg }}">
                    {# header #}
                    <div class="sw-hdr" style="background:{{ thm.preview_surface }};border-color:{{ thm.preview_border }}">
                        <div class="sw-logo" style="background:{{ thm.preview_accent }}"></div>
                        <div class="sw-brand" style="background:{{ thm.preview_fg }}"></div>
                    </div>
                    {# category tabs #}
                    <div class="sw-tabs">
                        <div class="sw-tab on" style="background:{{ thm.preview_accent }}"></div>
                        <div class="sw-tab"    style="background:{{ thm.preview_fg }}"></div>
                        <div class="sw-tab"    style="background:{{ thm.preview_fg }}"></div>
                    </div>
                    {# portrait mini-cards #}
                    <div class="sw-cards">
                        <div class="sw-card" style="background:{{ thm.preview_surface }};border-color:{{ thm.preview_border }};border-radius:{{ thm.preview_radius|default('12px') }}">
                            <div class="sw-cimg" style="background:{{ thm.preview_border }}"></div>
                            <div class="sw-cbody">
                                <div><div class="sw-cname" style="background:{{ thm.preview_fg }}"></div><div class="sw-cname2" style="background:{{ thm.preview_fg }}"></div></div>
                                <div class="sw-cprice" style="color:{{ thm.preview_accent }}">€€</div>
                            </div>
                        </div>
                        <div class="sw-card" style="background:{{ thm.preview_surface }};border-color:{{ thm.preview_border }};border-radius:{{ thm.preview_radius|default('12px') }}">
                            <div class="sw-cimg" style="background:{{ thm.preview_border }}"></div>
                            <div class="sw-cbody">
                                <div><div class="sw-cname" style="background:{{ thm.preview_fg }};width:85%"></div><div class="sw-cname2" style="background:{{ thm.preview_fg }}"></div></div>
                                <div class="sw-cprice" style="color:{{ thm.preview_accent }}">€€</div>
                            </div>
                        </div>
                        <div class="sw-card" style="background:{{ thm.preview_surface }};border-color:{{ thm.preview_border }};border-radius:{{ thm.preview_radius|default('12px') }}">
                            <div class="sw-cimg" style="background:{{ thm.preview_border }}"></div>
                            <div class="sw-cbody">
                                <div><div class="sw-cname" style="background:{{ thm.preview_fg }};width:60%"></div><div class="sw-cname2" style="background:{{ thm.preview_fg }}"></div></div>
                                <div class="sw-cprice" style="color:{{ thm.preview_accent }}">€€</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card-footer">
                    <div class="card-label">{{ thm.icon }} {{ ('theme.' ~ key ~ '.name')|trans({}, 'admin_theme') }}</div>
                    <div class="card-desc">{{ ('theme.' ~ key ~ '.desc')|trans({}, 'admin_theme') }}</div>
                    {% if restaurant.theme == key %}<div class="active-chip">✓ {{ 'card.active_label'|trans({}, 'admin_theme') }}</div>{% endif %}
                    <div class="card-actions">
                        <button class="btn-eye" id="tprev-{{ key }}" onclick="previewTheme('{{ key }}')">
                            <i class="ti ti-eye"></i> {{ 'card.preview_action'|trans({}, 'admin_theme') }}
                        </button>
                        <button class="btn-use {{ restaurant.theme == key ? 'is-current' : '' }}" onclick="selectTheme('{{ key }}')">
                            {{ restaurant.theme == key ? '✓ ' ~ 'card.active_label'|trans({}, 'admin_theme') : 'card.use_action'|trans({}, 'admin_theme') }}
                        </button>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>

</div>
{% endblock %}

{% block javascripts %}
<script>
const PREVIEW_BASE   = '{{ previewBase|default('') }}';
const CURRENT_LAYOUT = '{{ restaurant.layout }}';
const CURRENT_THEME  = '{{ restaurant.theme }}';
const LAYOUT_NAMES   = { {% for k in layouts|keys %}'{{ k }}': "{{ ('layout.' ~ k ~ '.name')|trans({}, 'admin_theme')|e('js') }}",{% endfor %} };
const THEME_NAMES    = { {% for k in themes|keys %}'{{ k }}': "{{ ('theme.' ~ k ~ '.name')|trans({}, 'admin_theme')|e('js') }}",{% endfor %} };

const MSG_APPLY_NOW           = "{{ 'confirm.apply_now'|trans({}, 'admin_theme')|e('js') }}";
const MSG_APPLYING            = "{{ 'confirm.applying'|trans({}, 'admin_theme')|e('js') }}";
const MSG_USE_LAYOUT_TITLE    = "{{ 'confirm.use_layout_title'|trans({}, 'admin_theme')|e('js') }}";
const MSG_USE_LAYOUT_SUB      = "{{ 'confirm.use_layout_sub'|trans({}, 'admin_theme')|e('js') }}";
const MSG_USE_THEME_TITLE     = "{{ 'confirm.use_theme_title'|trans({}, 'admin_theme')|e('js') }}";
const MSG_USE_THEME_SUB       = "{{ 'confirm.use_theme_sub'|trans({}, 'admin_theme')|e('js') }}";
const MSG_APPLY_PREVIEW_TITLE = "{{ 'confirm.apply_preview_title'|trans({}, 'admin_theme')|e('js') }}";
const MSG_APPLY_PREVIEW_SUB   = "{{ 'confirm.apply_preview_sub'|trans({}, 'admin_theme')|e('js') }}";
const MSG_PREVIEW_TITLE       = "{{ 'preview.title_with_names'|trans({}, 'admin_theme')|e('js') }}";
const MSG_PREVIEW_CLOSED      = "{{ 'preview.closed_toast'|trans({}, 'admin_theme')|e('js') }}";
const MSG_SAVE_ERROR          = "{{ 'toast.save_error'|trans({}, 'admin_theme')|e('js') }}";
const MSG_APPLIED             = "{{ 'toast.applied'|trans({}, 'admin_theme')|e('js') }}";
const MSG_CONNECTION_ERROR    = "{{ 'toast.connection_error'|trans({}, 'admin_theme')|e('js') }}";

let curPrevLayout  = CURRENT_LAYOUT;
let curPrevTheme   = CURRENT_THEME;
let previewWindow  = null;
let confirmAction  = null;  // function to call on confirm

// ── Confirm modal ──
function openConfirm(title, sub, action) {
    document.getElementById('confirm-title').textContent    = title;
    document.getElementById('confirm-sub').textContent      = sub;
    const btn = document.getElementById('confirm-apply-btn');
    btn.disabled    = false;
    btn.textContent = MSG_APPLY_NOW;
    confirmAction   = action;
    document.getElementById('confirm-backdrop').classList.add('show');
}
function closeConfirm() {
    document.getElementById('confirm-backdrop').classList.remove('show');
    confirmAction = null;
}
function doConfirm() {
    const btn = document.getElementById('confirm-apply-btn');
    btn.disabled    = true;
    btn.textContent = MSG_APPLYING;
    if (confirmAction) confirmAction();
}
document.getElementById('confirm-backdrop').addEventListener('click', function(e) {
    if (e.target === this) closeConfirm();
});

// ── Layout ──
function selectLayout(key) {
    if (key === CURRENT_LAYOUT) return;
    openConfirm(
        MSG_USE_LAYOUT_TITLE.replace('%name%', LAYOUT_NAMES[key]),
        MSG_USE_LAYOUT_SUB,
        () => applyNow({ layout: key })
    );
}
function previewLayout(key) {
    curPrevLayout = key;
    openPreviewTab();
    document.querySelectorAll('.layout-card, [id^="lcard-"]').forEach(c => c.classList.remove('is-preview'));
    document.querySelectorAll('[id^="lprev-"]').forEach(b => b.classList.remove('active'));
    if (key !== CURRENT_LAYOUT) {
        document.getElementById('lcard-' + key)?.classList.add('is-preview');
        document.getElementById('lprev-' + key)?.classList.add('active');
    }
    showPreviewBar();
}

// ── Theme ──
function selectTheme(key) {
    if (key === CURRENT_THEME) return;
    openConfirm(
        MSG_USE_THEME_TITLE.replace('%name%', THEME_NAMES[key]),
        MSG_USE_THEME_SUB,
        () => applyNow({ theme: key })
    );
}
function previewTheme(key) {
    curPrevTheme = key;
    openPreviewTab();
    document.querySelectorAll('[id^="tcard-"]').forEach(c => c.classList.remove('is-preview'));
    document.querySelectorAll('[id^="tprev-"]').forEach(b => b.classList.remove('active'));
    if (key !== CURRENT_THEME) {
        document.getElementById('tcard-' + key)?.classList.add('is-preview');
        document.getElementById('tprev-' + key)?.classList.add('active');
    }
    showPreviewBar();
}

// ── Preview tab ──
function openPreviewTab() {
    if (!PREVIEW_BASE) return;
    const url = PREVIEW_BASE + '?preview_layout=' + curPrevLayout + '&preview_theme=' + curPrevTheme;
    if (previewWindow && !previewWindow.closed) {
        previewWindow.location.href = url;
    } else {
        previewWindow = window.open(url, 'menu_preview');
    }
}
function showPreviewBar() {
    const ln = LAYOUT_NAMES[curPrevLayout] ?? curPrevLayout;
    const tn = THEME_NAMES[curPrevTheme]   ?? curPrevTheme;
    document.getElementById('preview-bar-title').textContent =
        MSG_PREVIEW_TITLE.replace('%layout%', ln).replace('%theme%', tn);
    document.getElementById('preview-bar').classList.add('show');
}
function cancelPreview() {
    curPrevLayout = CURRENT_LAYOUT;
    curPrevTheme  = CURRENT_THEME;
    if (previewWindow && !previewWindow.closed) previewWindow.close();
    document.querySelectorAll('[id^="lcard-"],[id^="tcard-"]').forEach(c => c.classList.remove('is-preview'));
    document.querySelectorAll('[id^="lprev-"],[id^="tprev-"]').forEach(b => b.classList.remove('active'));
    document.getElementById('preview-bar').classList.remove('show');
    showToast(MSG_PREVIEW_CLOSED);
}
function applyFromBar() {
    const chLayout = curPrevLayout !== CURRENT_LAYOUT ? curPrevLayout : null;
    const chTheme  = curPrevTheme  !== CURRENT_THEME  ? curPrevTheme  : null;
    if (!chLayout && !chTheme) { cancelPreview(); return; }
    const parts = [];
    if (chLayout) parts.push('"' + LAYOUT_NAMES[chLayout] + '"');
    if (chTheme)  parts.push('"' + THEME_NAMES[chTheme]   + '"');
    openConfirm(
        MSG_APPLY_PREVIEW_TITLE,
        MSG_APPLY_PREVIEW_SUB.replace('%combo%', parts.join(' + ')),
        () => {
            const body = {};
            if (chLayout) body.layout = chLayout;
            if (chTheme)  body.theme  = chTheme;
            applyNow(body);
        }
    );
}

// ── Apply (immediate) ──
async function applyNow(body) {
    try {
        const res  = await fetch('/admin/theme/apply', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body)
        });
        const data = await res.json();
        if (!data.ok) { showToast(MSG_SAVE_ERROR, 'error'); closeConfirm(); return; }
        showToast(MSG_APPLIED);
        setTimeout(() => location.reload(), 700);
    } catch(e) {
        showToast(MSG_CONNECTION_ERROR, 'error');
        closeConfirm();
    }
}
</script>
{% endblock %}
