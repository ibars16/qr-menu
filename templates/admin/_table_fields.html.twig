{# Shared table form fields — used in both desktop modal and mobile sheet #}

<div class="field">
    <div class="field-label">Número o nombre de la mesa <span class="req">*</span></div>
    <input type="text" id="table-number" placeholder="1, 2, Terraza, Barra…"
           maxlength="50"
           oninput="this.classList.remove('error'); document.getElementById('table-number-error').classList.remove('show')"
           onkeydown="if(event.key==='Enter')saveTable()">
    <div class="field-error" id="table-number-error">El número de mesa es obligatorio.</div>
    <div class="field-hint">Puede ser un número (1, 2, 3…) o un nombre descriptivo (Terraza, Barra, Reservados).</div>
</div>
