{# templates/admin/_product_fields.html.twig #}

{# Categoría — siempre visible y editable #}
<div class="field">
    <label class="field-label">{{ 'field.category'|trans({}, 'admin_menu') }} <span class="req">*</span></label>
    <select id="p-category">
        {% for category in categories %}
            {% set catT = category.getTranslation(locale) %}
            <option value="{{ category.id }}">{{ catT ? catT.name : 'common.unnamed'|trans({}, 'admin_menu') }}</option>
        {% endfor %}
    </select>
</div>

{# Nombre — obligatorio #}
<div class="field">
    <label class="field-label">
        {{ 'field.product_name'|trans({}, 'admin_menu') }} <span class="req">*</span>
    </label>
    <input type="text"
           id="p-name"
           placeholder="{{ 'field.product_name_placeholder'|trans({}, 'admin_menu') }}">
    <div class="field-error" id="p-name-error">{{ 'field_error.name_required'|trans({}, 'admin_menu') }}</div>
</div>

{# Descripción — obligatoria #}
<div class="field">
    <label class="field-label">
        {{ 'field.description'|trans({}, 'admin_menu') }} <span class="req">*</span>
    </label>
    <textarea id="p-desc"
              placeholder="{{ 'field.description_placeholder'|trans({}, 'admin_menu') }}"></textarea>
    <div class="field-error" id="p-desc-error">{{ 'field_error.description_required'|trans({}, 'admin_menu') }}</div>
</div>

{# Precio + Calorías #}
<div class="field-row">
    <div class="field">
        <label class="field-label">
            {{ 'field.price'|trans({'%currency%': restaurant.currency}, 'admin_menu') }} <span class="req">*</span>
        </label>
        <input type="number"
               id="p-price"
               min="0" step="0.01"
               placeholder="0.00"
               inputmode="decimal">
        <div class="field-error" id="p-price-error">{{ 'field_error.price_required'|trans({}, 'admin_menu') }}</div>
    </div>
    <div class="field">
        <label class="field-label">
            {{ 'field.calories'|trans({}, 'admin_menu') }} <span class="opt">({{ 'common.optional'|trans({}, 'admin_menu') }})</span>
        </label>
        <input type="number"
               id="p-calories"
               min="0"
               placeholder="kcal"
               inputmode="numeric">
    </div>
</div>

{# Imagen — opcional #}
<div class="field">
    <label class="field-label">
        {{ 'field.photo'|trans({}, 'admin_menu') }} <span class="opt">({{ 'common.optional'|trans({}, 'admin_menu') }})</span>
    </label>
    <div class="img-upload"
         id="img-upload-area"
         onclick="document.getElementById('p-img-input').click()"
         role="button"
         tabindex="0"
         aria-label="{{ 'upload.aria'|trans({}, 'admin_menu') }}">
        <div class="img-upload-hint">
            <i class="ti ti-photo-up" style="font-size:20px" aria-hidden="true"></i>
            {{ 'upload.hint'|trans({}, 'admin_menu') }}
        </div>
    </div>
    <input type="file"
           id="p-img-input"
           accept="image/*"
           style="display:none"
           onchange="previewImage(this)">
</div>

{# Picante — opcional #}
<div class="field">
    <label class="field-label">
        {{ 'field.spicy_level'|trans({}, 'admin_menu') }} <span class="opt">({{ 'common.optional'|trans({}, 'admin_menu') }})</span>
    </label>
    <div class="spicy-row">
        {% for i in 1..5 %}
            <div class="spicy-pip"
                 data-level="{{ i }}"
                 onclick="setSpicy({{ i }})"
                 role="button"
                 tabindex="0"
                 aria-label="{{ 'spicy.aria'|trans({'%level%': i}, 'admin_menu') }}"><span class="chili">🌶</span></div>
        {% endfor %}
        <span class="spicy-text">{{ 'spicy.none'|trans({}, 'admin_menu') }}</span>
    </div>
</div>

{# Etiquetas — opcional. "recommended" (Smart Waiter) is deliberately excluded
   from this generic list — it has its own dedicated section below so it's
   never duplicated between the two controls. #}
{% set recommendedTag = null %}
{% set genericTags = [] %}
{% for tag in restaurant.productTags %}
    {% if tag.isSystem and tag.code == 'recommended' %}
        {% set recommendedTag = tag %}
    {% else %}
        {% set genericTags = genericTags|merge([tag]) %}
    {% endif %}
{% endfor %}

{% if genericTags|length > 0 %}
    <div class="field">
        <label class="field-label">
            {{ 'field.tags'|trans({}, 'admin_menu') }} <span class="opt">({{ 'common.optional'|trans({}, 'admin_menu') }})</span>
        </label>
        <div class="tag-pills">
            {% for tag in genericTags %}
                {% set tagT = null %}
                {% for tr in tag.translations %}
                    {% if tr.locale == locale %}{% set tagT = tr %}{% endif %}
                {% endfor %}
                {% if tagT %}
                    <div class="tag-pill"
                         data-tag-id="{{ tag.id }}"
                         onclick="this.classList.toggle('on')"
                         role="checkbox"
                         aria-checked="false">
                        {{ tag.icon }} {{ tagT.name }}
                    </div>
                {% endif %}
            {% endfor %}
        </div>
    </div>
{% else %}
    <div style="font-size:12px;color:var(--tx-6);padding:8px 12px;background:var(--bg-card);border-radius:8px;border:1px solid var(--bd-1)">
        {{ 'tags.none_configured'|trans({
            '%link_start%': '<a href="' ~ path('admin_tags') ~ '" style="color:var(--tx-3)">',
            '%link_end%': '</a>',
        }, 'admin_menu')|raw }}
    </div>
{% endif %}

{# Smart Waiter — the one signal the AI assistant is allowed to cite when a
   customer asks what the restaurant recommends (see MenuContextBuilder /
   SmartWaiterPromptBuilder). This checkbox only adds or removes the existing
   "recommended" System Tag — same product_save "tags" payload as the pills
   above, no new field or logic. #}
{% if recommendedTag %}
    <div class="field">
        <label class="field-label">{{ recommendedTag.icon }} {{ 'smart_waiter.section_title'|trans({}, 'admin_menu') }}</label>
        <label class="sw-recommend-box">
            <input type="checkbox" id="p-recommended" data-tag-id="{{ recommendedTag.id }}">
            <span class="sw-recommend-text">
                <span class="sw-recommend-label">{{ 'smart_waiter.recommended_label'|trans({}, 'admin_menu') }}</span>
                <span class="sw-recommend-hint">{{ 'smart_waiter.recommended_hint'|trans({}, 'admin_menu') }}</span>
            </span>
        </label>
    </div>
{% endif %}

{# Ingredientes — opcional #}
<div class="field">
    <label class="field-label" for="ing-select">
        {{ 'field.ingredients'|trans({}, 'admin_menu') }} <span class="opt">({{ 'common.optional'|trans({}, 'admin_menu') }})</span>
    </label>
    <select id="ing-select" multiple placeholder="{{ 'ingredients.placeholder'|trans({}, 'admin_menu') }}"></select>
    <p style="font-size:11px;color:var(--tx-7);margin-top:6px;line-height:1.5">
        {{ 'ingredients.hint'|trans({}, 'admin_menu') }}
    </p>
</div>

{# Alérgenos — opcional, calculado desde los ingredientes + casos especiales #}
{% macro help(text) %}
    <span class="help-icon" role="button" tabindex="0" aria-label="{{ 'common.help'|trans({}, 'admin_menu') }}" data-help-text="{{ text|e('html_attr') }}" onclick="toggleHelp(event, this)">?</span>
{% endmacro %}
{% import _self as ui %}

<div class="field">
    <label class="field-label">
        {{ 'field.allergens'|trans({}, 'admin_menu') }} <span class="opt">({{ 'common.optional'|trans({}, 'admin_menu') }})</span>
    </label>

    <div class="allergen-block">
        <div class="allergen-subtitle">
            {{ 'allergens.computed_title'|trans({}, 'admin_menu') }}
            {{ ui.help('allergens.help_computed'|trans({}, 'admin_menu')) }}
        </div>
        <div class="allergen-chip-row" id="p-allergen-computed"></div>
        <p class="allergen-hint">{{ 'allergens.computed_hint'|trans({}, 'admin_menu') }}</p>
    </div>

    <div class="allergen-block" id="p-private-ingredient-allergens-wrap" style="display:none">
        <div class="allergen-subtitle">{{ 'allergens.your_ingredients_title'|trans({}, 'admin_menu') }}</div>
        <p class="allergen-hint">{{ 'allergens.your_ingredients_hint'|trans({}, 'admin_menu') }}</p>
        <div id="p-private-ingredient-allergens"></div>
    </div>

    {# Collapsed by default — the vast majority of dishes need nothing here at all;
       see toggleAllergenAdvanced() in menu.html.twig. #}
    <div class="allergen-accordion">
        <div class="allergen-accordion-toggle" onclick="toggleAllergenAdvanced(this)" role="button" tabindex="0" aria-expanded="false">
            <i class="ti ti-chevron-right allergen-accordion-chevron" aria-hidden="true"></i>
            <div class="allergen-accordion-toggle-text">
                <span class="allergen-accordion-title">
                    {{ 'allergens.advanced_title'|trans({}, 'admin_menu') }}
                    <span class="allergen-accordion-badge" style="display:none">0</span>
                </span>
                <span class="allergen-accordion-subtitle">
                    {{ 'allergens.advanced_hint'|trans({}, 'admin_menu') }}
                    {{ ui.help('allergens.help_cross_contamination'|trans({}, 'admin_menu')) }}
                </span>
            </div>
        </div>
        <div class="allergen-accordion-body">
            <div class="allergen-block-label">
                {{ 'allergens.overrides_title'|trans({}, 'admin_menu') }}
                {{ ui.help('allergens.help_product_exception'|trans({}, 'admin_menu')) }}
            </div>
            <div class="allergen-chip-row" id="p-allergen-overrides"></div>
            <div class="allergen-override-adder">
                <select id="p-allergen-add-select">
                    <option value="">{{ 'allergens.select_allergen'|trans({}, 'admin_menu') }}</option>
                    {% for allergen in allergens %}
                        {% set aT = allergen.getTranslation(locale) %}
                        {% if not aT %}{% set aT = allergen.getTranslation('en') %}{% endif %}
                        {% if aT %}<option value="{{ allergen.id }}">{{ allergen.icon }} {{ aT.name }}</option>{% endif %}
                    {% endfor %}
                </select>
                <select id="p-allergen-add-presence">
                    <option value="contains">{{ 'allergens.presence_contains'|trans({}, 'admin_menu') }}</option>
                    <option value="may_contain">{{ 'allergens.presence_may_contain'|trans({}, 'admin_menu') }}</option>
                    <option value="free_from">{{ 'allergens.presence_free_from'|trans({}, 'admin_menu') }}</option>
                </select>
                <input type="text" id="p-allergen-add-note" placeholder="{{ 'allergens.note_placeholder'|trans({}, 'admin_menu') }}">
                <div class="allergen-add-btn" onclick="addAllergenOverride()" role="button" tabindex="0">
                    <i class="ti ti-plus" style="font-size:13px" aria-hidden="true"></i> {{ 'allergens.add_exception'|trans({}, 'admin_menu') }}
                </div>
            </div>
            <div class="allergen-presence-legend">
                <span>{{ 'allergens.presence_contains'|trans({}, 'admin_menu') }} {{ ui.help('allergens.help_contains'|trans({}, 'admin_menu')) }}</span>
                <span>{{ 'allergens.presence_may_contain'|trans({}, 'admin_menu') }} {{ ui.help('allergens.help_may_contain'|trans({}, 'admin_menu')) }}</span>
                <span>{{ 'allergens.presence_free_from'|trans({}, 'admin_menu') }} {{ ui.help('allergens.help_free_from'|trans({}, 'admin_menu')) }}</span>
            </div>
        </div>
    </div>
</div>
