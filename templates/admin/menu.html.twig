{% endblock %}

{% block javascripts %}
    <script>
        const LOCALE   = '{{ locale }}';
        const CURRENCY = '{{ restaurant.currency }}';
        const SPICY_LABELS = {{ ['spicy.none','spicy.mild','spicy.medium','spicy.hot','spicy.very_hot','spicy.extreme']|map(k => k|trans({}, 'admin_menu'))|json_encode|raw }};

        const MSG_NEW_CATEGORY       = "{{ 'modal.category.new_title'|trans({}, 'admin_menu')|e('js') }}";
        const MSG_EDIT_CATEGORY      = "{{ 'modal.category.edit_title'|trans({}, 'admin_menu')|e('js') }}";
        const MSG_NEW_PRODUCT        = "{{ 'modal.product.new_title'|trans({}, 'admin_menu')|e('js') }}";
        const MSG_EDIT_PRODUCT       = "{{ 'modal.product.edit_title'|trans({}, 'admin_menu')|e('js') }}";
        const MSG_ERROR_LOADING_PRODUCT = "{{ 'js.error_loading_product'|trans({}, 'admin_menu')|e('js') }}";
        const MSG_UNEXPECTED_ERROR   = "{{ 'error.unexpected'|trans({}, 'admin_menu')|e('js') }}";
        const MENU_IMPORT_URL        = "{{ path('admin_menu_import_new') }}";
        const MSG_CATEGORY_UPDATED   = "{{ 'js.category_updated'|trans({}, 'admin_menu')|e('js') }}";
        const MSG_CATEGORY_CREATED   = "{{ 'js.category_created'|trans({}, 'admin_menu')|e('js') }}";
        const MSG_CATEGORY_VISIBLE   = "{{ 'category.toggle_visible'|trans({}, 'admin_menu')|e('js') }}";
        const MSG_CATEGORY_HIDDEN    = "{{ 'category.toggle_hidden'|trans({}, 'admin_menu')|e('js') }}";
        const MSG_CATEGORY_HIDE_TITLE = "{{ 'category.toggle_hide_title'|trans({}, 'admin_menu')|e('js') }}";
        const MSG_CATEGORY_SHOW_TITLE = "{{ 'category.toggle_show_title'|trans({}, 'admin_menu')|e('js') }}";
        const MSG_CONFIRM_DELETE_CATEGORY_WITH_PRODUCTS = "{{ 'js.confirm_delete_category_with_products'|trans({}, 'admin_menu')|e('js') }}";
        const MSG_CONFIRM_DELETE_CATEGORY = "{{ 'js.confirm_delete_category'|trans({}, 'admin_menu')|e('js') }}";
        const MSG_CATEGORY_DELETED   = "{{ 'js.category_deleted'|trans({}, 'admin_menu')|e('js') }}";
        const MSG_FILL_REQUIRED_FIELDS = "{{ 'js.fill_required_fields'|trans({}, 'admin_menu')|e('js') }}";
        const MSG_PRODUCT_SAVED     = "{{ 'js.product_saved'|trans({}, 'admin_menu')|e('js') }}";
        const MSG_PRODUCT_CREATED  = "{{ 'js.product_created'|trans({}, 'admin_menu')|e('js') }}";
        const MSG_PRODUCT_VISIBLE  = "{{ 'product.visible'|trans({}, 'admin_menu')|e('js') }}";
        const MSG_PRODUCT_HIDDEN   = "{{ 'product.hidden'|trans({}, 'admin_menu')|e('js') }}";
        const MSG_PRODUCT_DELETED  = "{{ 'js.product_deleted'|trans({}, 'admin_menu')|e('js') }}";
        const MSG_CONFIRM_DELETE_PRODUCT = "{{ 'js.confirm_delete_product'|trans({}, 'admin_menu')|e('js') }}";
        const MSG_DEFAULT_PRODUCT_NAME = "{{ 'js.default_product_name'|trans({}, 'admin_menu')|e('js') }}";
        const MSG_NEW_INGREDIENT_LABEL = "{{ 'js.new_ingredient_label'|trans({}, 'admin_menu')|e('js') }}";
        const MSG_NO_INGREDIENTS_FOUND = "{{ 'ingredients.no_results'|trans({}, 'admin_menu')|e('js') }}";
        const MSG_INGREDIENTS_PLACEHOLDER = "{{ 'ingredients.placeholder'|trans({}, 'admin_menu')|e('js') }}";
        const MSG_GLOBAL_INGREDIENT_LABEL = "{{ 'ingredients.source_global'|trans({}, 'admin_menu')|e('js') }}";
        const MSG_RESTAURANT_INGREDIENT_LABEL = "{{ 'ingredients.source_restaurant'|trans({}, 'admin_menu')|e('js') }}";
        const MSG_ALLERGEN_PRESENCE_CONTAINS    = "{{ 'allergens.presence_contains'|trans({}, 'admin_menu')|e('js') }}";
        const MSG_ALLERGEN_PRESENCE_MAY_CONTAIN = "{{ 'allergens.presence_may_contain'|trans({}, 'admin_menu')|e('js') }}";
        const MSG_ALLERGEN_PRESENCE_FREE_FROM   = "{{ 'allergens.presence_free_from'|trans({}, 'admin_menu')|e('js') }}";
        const MSG_ALLERGEN_COMPUTED_EMPTY  = "{{ 'allergens.computed_empty'|trans({}, 'admin_menu')|e('js') }}";
        const MSG_ALLERGEN_NEW_INGREDIENT_HINT = "{{ 'allergens.new_ingredient_hint'|trans({}, 'admin_menu')|e('js') }}";
        const MSG_ALLERGEN_NOTE_REQUIRED   = "{{ 'js.allergen_note_required'|trans({}, 'admin_menu')|e('js') }}";
        const MSG_ALLERGEN_OVERRIDE_ADDED  = "{{ 'js.allergen_override_added'|trans({}, 'admin_menu')|e('js') }}";
        const MSG_INGREDIENT_ALLERGENS_SAVED = "{{ 'js.ingredient_allergens_saved'|trans({}, 'admin_menu')|e('js') }}";
        const MSG_ALLERGEN_REMOVE = "{{ 'allergens.remove'|trans({}, 'admin_menu')|e('js') }}";

        // Full allergen taxonomy, translated in the Admin Panel's content
        // language — small, fixed reference data (14 rows), so it's cheap to
        // send once rather than fetched per panel-open.
        const ALLERGENS = [
            {% for allergen in allergens %}
                {% set aT = allergen.getTranslation(locale) %}
                {% if not aT %}{% set aT = allergen.getTranslation('en') %}{% endif %}
                {% if aT %}
                { id: {{ allergen.id }}, code: "{{ allergen.code }}", icon: "{{ allergen.icon }}", name: "{{ aT.name|e('js') }}" },
                {% endif %}
            {% endfor %}
        ];
        function allergenById(id) { return ALLERGENS.find(a => a.id === parseInt(id)); }

        const S = {
            productId:   null,
            categoryId:  null,
            editingCatId:null,
            spicy:       0,
            allergenOverrides: [],
            ingredientAllergenCache: {},
        };

        // ── Responsive helpers ────────────────────────────────────────────────────
        const isMobile = () => window.innerWidth < 768;

        // ── UI controller ─────────────────────────────────────────────────────────
        const UI = {
            openNewCategory() {
                S.editingCatId = null;
                document.getElementById('cat-modal-title').textContent  = MSG_NEW_CATEGORY;
                document.getElementById('cat-sheet-title').textContent  = MSG_NEW_CATEGORY;
                document.getElementById('cat-name-input').value = '';
                document.getElementById('cat-name-error').classList.remove('show');
                this._openCat();
                setTimeout(() => document.getElementById('cat-name-input').focus(), 80);
            },
            openEditCategory(id, name) {
                S.editingCatId = id;
                document.getElementById('cat-modal-title').textContent = MSG_EDIT_CATEGORY;
                document.getElementById('cat-sheet-title').textContent = MSG_EDIT_CATEGORY;
                document.getElementById('cat-name-input').value = name;
                document.getElementById('cat-name-error').classList.remove('show');
                this._openCat();
                setTimeout(() => document.getElementById('cat-name-input').focus(), 80);
            },
            _openCat() {
                if (isMobile()) document.getElementById('mobile-cat-sheet').classList.add('open');
                else            document.getElementById('desktop-cat-modal').classList.add('open');
            },
            closeCat() {
                document.getElementById('mobile-cat-sheet').classList.remove('open');
                document.getElementById('desktop-cat-modal').classList.remove('open');
            },

            openNewProduct(categoryId) {
                resetProduct();
                S.productId  = null;
                S.categoryId = categoryId;
                this._setProductTitle(MSG_NEW_PRODUCT);
                this._showDeleteBtn(false);
                if (categoryId) {
                    document.querySelectorAll('.cat-card').forEach(c =>
                        c.classList.toggle('selected', parseInt(c.dataset.catId) === categoryId)
                    );
                    this.goStep2();
                } else {
                    this.goStep1();
                }
                this._openProduct();
            },
            async openEditProduct(id) {
                resetProduct();
                S.productId = id;
                this._setProductTitle(MSG_EDIT_PRODUCT);
                this._showDeleteBtn(true);
                this._hideSteps();
                this._hideBackBtn();
                this.goStep2(true);
                this._openProduct();

                try {
                    const data = await apiFetch(`/admin/products/${id}`, null, 'GET');
                    S.categoryId = data.categoryId;
                    document.querySelectorAll('[id="p-category"]').forEach(el => { el.value = data.categoryId; });
                    S.spicy      = data.spicyLevel ?? 0;
                    updateSpicyUI();

                    const t = data.translations[LOCALE] ?? Object.values(data.translations)[0] ?? {};
                    setVal('p-name',     t.name ?? '');
                    setVal('p-desc',     t.description ?? '');
                    setVal('p-price',    (data.basePrice / 100).toFixed(2));
                    setVal('p-supplement-price', data.supplementPrice != null ? (data.supplementPrice / 100).toFixed(2) : '');
                    setVal('p-glass-price', data.glassPrice != null ? (data.glassPrice / 100).toFixed(2) : '');
                    if (data.supplementPrice != null) revealExtraPrice('supplement');
                    if (data.glassPrice != null) revealExtraPrice('glass');
                    setVal('p-calories', data.calories ?? '');

                    document.querySelectorAll('.tag-pill').forEach(p =>
                        p.classList.toggle('on', data.tags.includes(parseInt(p.dataset.tagId)))
                    );
                    document.querySelectorAll('[id="p-recommended"]').forEach(cb =>
                        cb.checked = data.tags.includes(parseInt(cb.dataset.tagId))
                    );
                    await setIngredientItems(data.ingredientsList ?? []);

                    // Seed the ingredient-allergen cache from what getProduct
                    // already loaded, so the private-ingredients panel below
                    // doesn't need a second round trip for ingredients that
                    // were already on this dish.
                    (data.ingredientsList ?? []).forEach(item => {
                        if (item.source === 'restaurant') {
                            S.ingredientAllergenCache[parseInt(item.value.slice(2))] = item.allergens ?? [];
                        }
                    });
                    renderAllergenComputed(data.allergensComputed ?? []);
                    S.allergenOverrides = (data.allergenOverrides ?? []).map(o => ({ allergenId: o.id, presence: o.presence, note: o.note ?? '' }));
                    renderAllergenOverrides();
                    renderPrivateIngredientAllergens();
                } catch(e) { showToast(MSG_ERROR_LOADING_PRODUCT, 'error'); }
            },
            _openProduct() {
                if (isMobile()) document.getElementById('mobile-product-sheet').classList.add('open');
                else            document.getElementById('desktop-product-modal').classList.add('open');
            },
            closeProduct() {
                document.getElementById('mobile-product-sheet').classList.remove('open');
                document.getElementById('desktop-product-modal').classList.remove('open');
                resetProduct();
            },
            _setProductTitle(t) {
                document.getElementById('product-modal-title').textContent = t;
                document.getElementById('product-sheet-title').textContent = t;
            },
            _showDeleteBtn(show) {
                document.getElementById('d-delete-btn').style.display = show ? '' : 'none';
                document.getElementById('m-delete-btn').style.display = show ? '' : 'none';
            },
            _hideSteps() {
                document.getElementById('product-modal-steps').style.display = 'none';
                document.getElementById('product-sheet-steps').style.display = 'none';
            },
            _hideBackBtn() {
                document.getElementById('d-back-btn').style.display = 'none';
                document.getElementById('m-back-btn').style.display = 'none';
            },

            goStep1() {
                ['d-step1-body','m-step1-body'].forEach(id => { const el=document.getElementById(id); if(el) el.style.display=''; });
                ['d-step2-body','m-step2-body'].forEach(id => { const el=document.getElementById(id); if(el) el.style.display='none'; });
                ['d-step-1','m-step-1'].forEach(id => document.getElementById(id)?.classList.add('active'));
                ['d-step-2','m-step-2'].forEach(id => document.getElementById(id)?.classList.remove('active'));
            },
            goStep2(force = false) {
                if (!force && !S.categoryId) {
                    const sel = document.querySelector('.cat-card.selected');
                    if (!sel) { document.getElementById('cat-select-error').style.display=''; return; }
                    S.categoryId = parseInt(sel.dataset.catId);
                }
                if (S.categoryId) {
                    document.querySelectorAll('[id="p-category"]').forEach(el => { el.value = S.categoryId; });
                }
                ['d-step1-body','m-step1-body'].forEach(id => { const el=document.getElementById(id); if(el) el.style.display='none'; });
                ['d-step2-body','m-step2-body'].forEach(id => { const el=document.getElementById(id); if(el) el.style.display=''; });
                ['d-step-2','m-step-2'].forEach(id => document.getElementById(id)?.classList.add('active'));
                ['d-step-1','m-step-1'].forEach(id => document.getElementById(id)?.classList.remove('active'));
                initIngredientSelects();
                setTimeout(() => panelEl('p-name')?.focus(), 80);
            },

            openAiImport() { window.location.href = MENU_IMPORT_URL; },
        };

        // ── Category CRUD ──────────────────────────────────────────────────────────
        async function saveCategory() {
            const name = document.getElementById('cat-name-input').value.trim();
            if (!name) { document.getElementById('cat-name-error').classList.add('show'); return; }
            document.getElementById('cat-name-error').classList.remove('show');

            const url = S.editingCatId
                ? `/admin/categories/${S.editingCatId}/edit`
                : '/admin/categories/create';

            const data = await apiFetch(url, { name });
            if (data.error) { showToast(data.error, 'error'); return; }

            showToast(S.editingCatId ? MSG_CATEGORY_UPDATED : MSG_CATEGORY_CREATED, 'success');
            UI.closeCat();
            setTimeout(() => location.reload(), 700);
        }

        async function toggleCategory(id, btn) {
            const data = await apiFetch(`/admin/categories/${id}/toggle`);
            btn.classList.toggle('on', data.active);
            btn.title = data.active ? MSG_CATEGORY_HIDE_TITLE : MSG_CATEGORY_SHOW_TITLE;
            showToast(data.active ? MSG_CATEGORY_VISIBLE : MSG_CATEGORY_HIDDEN);
        }

        async function deleteCategory(id, name, count, btn) {
            const msg = count > 0
                ? MSG_CONFIRM_DELETE_CATEGORY_WITH_PRODUCTS.replace('%name%', name).replace('%count%', count)
                : MSG_CONFIRM_DELETE_CATEGORY.replace('%name%', name);
            if (!confirm(msg)) return;
            const data = await apiFetch(`/admin/categories/${id}/delete`);
            if (data.ok) {
                btn.closest('.cat-block').remove();
                showToast(MSG_CATEGORY_DELETED, 'success');
                if (!document.querySelector('.cat-block')) location.reload();
            }
        }

        // ── Product CRUD ───────────────────────────────────────────────────────────
        function validateProduct() {
            let ok = true;
            [['p-name','p-name-error'],['p-desc','p-desc-error'],['p-price','p-price-error']].forEach(([fid,eid]) => {
                const val = panelEl(fid)?.value?.trim();
                const empty = !val || (fid === 'p-price' && parseFloat(val) <= 0);
                panelEl(eid)?.classList.toggle('show', empty);
                panelEl(fid)?.classList.toggle('error', empty);
                if (empty) ok = false;
            });
            return ok;
        }

        async function saveProduct() {
            if (!validateProduct()) { showToast(MSG_FILL_REQUIRED_FIELDS, 'error'); return; }

            const translations = {};
            const name = getVal('p-name'), desc = getVal('p-desc');
            if (name) translations[LOCALE] = { name, description: desc || null };

            const tags = [...document.querySelectorAll('.tag-pill.on')].map(t => parseInt(t.dataset.tagId));
            document.querySelectorAll('[id="p-recommended"]:checked').forEach(cb => tags.push(parseInt(cb.dataset.tagId)));

            const payload = {
                id:          S.productId,
                categoryId:  parseInt(getVal('p-category')) || S.categoryId,
                basePrice:   parseFloat(getVal('p-price')) || 0,
                supplementPrice: getVal('p-supplement-price') ? parseFloat(getVal('p-supplement-price')) : null,
                glassPrice:  getVal('p-glass-price') ? parseFloat(getVal('p-glass-price')) : null,
                calories:    parseInt(getVal('p-calories')) || null,
                spicyLevel:  S.spicy || null,
                active:      true,
                translations,
                tags,
                ingredients: collectIngredients(),
                allergenOverrides: S.allergenOverrides,
            };

            const data = await apiFetch('/admin/products/save', payload);
            if (data.error) { showToast(data.error, 'error'); return; }
            showToast(S.productId ? MSG_PRODUCT_SAVED : MSG_PRODUCT_CREATED, 'success');
            UI.closeProduct();
            setTimeout(() => location.reload(), 700);
        }

        async function toggleProduct(id, btn) {
            const data = await apiFetch(`/admin/products/${id}/toggle`);
            btn.classList.toggle('on', data.active);
            btn.title = data.active ? MSG_PRODUCT_VISIBLE : MSG_PRODUCT_HIDDEN;
            const row = btn.closest('.product-row');
            row.classList.toggle('inactive', !data.active);
            const status = row.querySelector('.product-status');
            if (status) status.textContent = data.active ? MSG_PRODUCT_VISIBLE : MSG_PRODUCT_HIDDEN;
            showToast(data.active ? MSG_PRODUCT_VISIBLE : MSG_PRODUCT_HIDDEN);
        }

        async function deleteProduct() {
            if (!S.productId) return;
            const name = getVal('p-name') || MSG_DEFAULT_PRODUCT_NAME;
            if (!confirm(MSG_CONFIRM_DELETE_PRODUCT.replace('%name%', name))) return;
            const data = await apiFetch(`/admin/products/${S.productId}/delete`);
            if (data.ok) { showToast(MSG_PRODUCT_DELETED, 'success'); UI.closeProduct(); setTimeout(() => location.reload(), 700); }
        }

        // ── Category selector ──────────────────────────────────────────────────────
        document.querySelectorAll('.cat-card').forEach(c => c.addEventListener('click', () => {
            document.querySelectorAll('.cat-card').forEach(x => x.classList.remove('selected'));
            c.classList.add('selected');
            S.categoryId = parseInt(c.dataset.catId);
            document.getElementById('cat-select-error').style.display = 'none';
        }));

        // ── Spicy ──────────────────────────────────────────────────────────────────
        function setSpicy(level) {
            S.spicy = S.spicy === level ? 0 : level;
            updateSpicyUI();
        }
        function updateSpicyUI() {
            document.querySelectorAll('.spicy-pip').forEach(p =>
                p.classList.toggle('on', parseInt(p.dataset.level) <= S.spicy)
            );
            document.querySelectorAll('.spicy-text').forEach(el =>
                el.textContent = SPICY_LABELS[S.spicy]
            );
        }

        // ── Ingredients (Tom Select, server-searched) ───────────────────────────────
        // The product-fields partial is included twice (desktop modal + mobile
        // sheet), so there are two <select id="ing-select"> elements in the DOM —
        // one Tom Select instance is created per copy, mirroring how the rest of
        // this file keeps duplicate-id panels in sync (see panelEl()/setVal()).
        let _tomSelectCtor = null;
        async function ensureTomSelect() {
            if (!_tomSelectCtor) {
                _tomSelectCtor = (await import('tom-select')).default;
                import('tom-select/dist/css/tom-select.default.min.css');
            }
            return _tomSelectCtor;
        }

        function ingSelects() {
            return Array.from(document.querySelectorAll('[id="ing-select"]'))
                .map(el => el.tomselect)
                .filter(Boolean);
        }

        async function initIngredientSelects() {
            const TomSelect = await ensureTomSelect();
            document.querySelectorAll('[id="ing-select"]').forEach(el => {
                if (el.tomselect) return;
                new TomSelect(el, {
                    plugins: ['remove_button'],
                    valueField: 'value',
                    labelField: 'name',
                    searchField: [],
                    options: [],
                    persist: false,
                    maxOptions: 20,
                    closeAfterSelect: true,
                    placeholder: MSG_INGREDIENTS_PLACEHOLDER,
                    create(input) {
                        return { value: 'new:' + input.trim(), name: input.trim(), source: 'new' };
                    },
                    createFilter(input) {
                        const q = input.trim().toLowerCase();
                        if (!q) return false;
                        return !Object.values(this.options).some(o => o.name.toLowerCase() === q);
                    },
                    load(query, callback) {
                        if (query.trim().length < 2) { callback(); return; }
                        apiFetch('/admin/ingredients/search?q=' + encodeURIComponent(query.trim()), null, 'GET')
                            .then(results => callback(results))
                            .catch(() => callback());
                    },
                    render: {
                        // Restaurant Ingredients vs the Global Ingredient Library
                        // must always be visually distinguishable in the dropdown.
                        option(data, escape) {
                            const badge = data.source === 'global'
                                ? `<span class="ing-source ing-source-global">${MSG_GLOBAL_INGREDIENT_LABEL}</span>`
                                : `<span class="ing-source ing-source-restaurant">${MSG_RESTAURANT_INGREDIENT_LABEL}</span>`;
                            return `<div>${escape(data.name)} ${badge}</div>`;
                        },
                        item(data, escape) {
                            const icon = data.source === 'global' ? '<i class="ti ti-world" style="font-size:11px" aria-hidden="true"></i> ' : '';
                            return `<div>${icon}${escape(data.name)}</div>`;
                        },
                        option_create(data, escape) {
                            return `<div class="create"><i class="ti ti-plus" style="font-size:14px" aria-hidden="true"></i> ${escape(data.input.trim())} <span>${MSG_NEW_INGREDIENT_LABEL}</span></div>`;
                        },
                        no_results() {
                            return `<div class="no-results">${MSG_NO_INGREDIENTS_FOUND}</div>`;
                        },
                    },
                    onItemAdd() { refreshPrivateIngredientAllergens(); },
                    onItemRemove() { refreshPrivateIngredientAllergens(); },
                });
            });
        }

        // Replaces every panel's current selection with `list` ([{value, name, source}]).
        async function setIngredientItems(list) {
            await initIngredientSelects();
            ingSelects().forEach(ts => {
                ts.clear(true);
                ts.clearOptions();
                (list || []).forEach(item => {
                    ts.addOption(item);
                    ts.addItem(item.value, true);
                });
            });
        }

        // Reads the currently-visible panel's selection back into [{value, name}]
        // for submission — the backend interprets the r:/g:/new: value prefix.
        function collectIngredients() {
            const ts = panelEl('ing-select')?.tomselect;
            if (!ts) return [];
            return ts.items.map(value => {
                const opt = ts.options[value];
                return { value, name: opt?.name ?? value };
            });
        }

        // ── Allergens ────────────────────────────────────────────────────────────
        // Three independent pieces, matching the architecture: a read-only
        // computed list (derived from ingredients, refreshed only from saved
        // state — see openEditProduct), an editor for the *ingredients'* own
        // allergens (auto-saved per ingredient, shared everywhere that
        // ingredient is used), and this product's own override list (batched
        // into the main saveProduct() payload like tags/ingredients are).

        function allergenChipHtml(a, presence, removable) {
            const label = presence === 'contains' ? MSG_ALLERGEN_PRESENCE_CONTAINS
                : presence === 'may_contain' ? MSG_ALLERGEN_PRESENCE_MAY_CONTAIN
                : MSG_ALLERGEN_PRESENCE_FREE_FROM;
            const remove = removable
                ? `<span class="achip-remove" onclick="removeAllergenOverride(${a.id})" role="button" tabindex="0" aria-label="${MSG_ALLERGEN_REMOVE}"><i class="ti ti-x" style="font-size:11px"></i></span>`
                : '';
            return `<span class="achip achip-${presence}">${a.icon} ${a.name} · ${label}${remove}</span>`;
        }

        function renderAllergenComputed(list) {
            const html = (list && list.length)
                ? list.map(e => allergenChipHtml({ icon: e.icon, name: e.name, id: e.id }, e.presence, false)).join('')
                : `<span class="allergen-empty">${MSG_ALLERGEN_COMPUTED_EMPTY}</span>`;
            document.querySelectorAll('[id="p-allergen-computed"]').forEach(el => el.innerHTML = html);
        }

        function renderAllergenOverrides() {
            const html = S.allergenOverrides.map(o => {
                const a = allergenById(o.allergenId);
                return a ? allergenChipHtml(a, o.presence, true) : '';
            }).join('');
            document.querySelectorAll('[id="p-allergen-overrides"]').forEach(el => el.innerHTML = html);

            // Collapsed by default even when editing a dish that already has
            // exceptions — but a badge keeps them from being silently hidden.
            const count = S.allergenOverrides.length;
            document.querySelectorAll('.allergen-accordion-badge').forEach(badge => {
                badge.textContent = count;
                badge.style.display = count > 0 ? '' : 'none';
            });
        }

        function addAllergenOverride() {
            const select   = panelEl('p-allergen-add-select');
            const presence = panelEl('p-allergen-add-presence')?.value || 'contains';
            const noteEl   = panelEl('p-allergen-add-note');
            const note     = (noteEl?.value || '').trim();
            const allergenId = parseInt(select?.value);

            if (!allergenId) return;
            if (presence === 'free_from' && !note) {
                showToast(MSG_ALLERGEN_NOTE_REQUIRED, 'error');
                return;
            }

            S.allergenOverrides = S.allergenOverrides.filter(o => o.allergenId !== allergenId);
            S.allergenOverrides.push({ allergenId, presence, note });
            renderAllergenOverrides();
            showToast(MSG_ALLERGEN_OVERRIDE_ADDED, 'success');

            document.querySelectorAll('[id="p-allergen-add-select"]').forEach(el => el.selectedIndex = 0);
            document.querySelectorAll('[id="p-allergen-add-note"]').forEach(el => el.value = '');
        }

        function removeAllergenOverride(allergenId) {
            S.allergenOverrides = S.allergenOverrides.filter(o => o.allergenId !== allergenId);
            renderAllergenOverrides();
        }

        // Ingredient-level allergens — auto-saves per ingredient (a "pill grid"
        // rather than the product override's select, since only CONTAINS /
        // MAY_CONTAIN apply here: an ingredient either carries an allergen or
        // it doesn't, there's no "confirmed free from" at this level).
        function ingredientAllergenPillGrid(ingredientId, current) {
            const stateByAllergen = {};
            (current || []).forEach(c => { stateByAllergen[c.allergenId] = c.presence; });

            return ALLERGENS.map(a => {
                const state = stateByAllergen[a.id] || '';
                return `<span class="allergen-pill" data-state="${state}" data-allergen-id="${a.id}"
                    onclick="cycleIngredientAllergen(${ingredientId}, ${a.id}, this)">${a.icon} ${a.name}</span>`;
            }).join('');
        }

        // Cycles a single ingredient's allergen state: none → contains → may
        // contain → none, saving immediately (same instant-apply convention
        // as the category/product visibility toggles elsewhere in this file).
        async function cycleIngredientAllergen(ingredientId, allergenId, pillEl) {
            const next = { '': 'contains', 'contains': 'may_contain', 'may_contain': '' };
            const newState = next[pillEl.dataset.state] ?? 'contains';
            pillEl.dataset.state = newState;

            const card = pillEl.closest('.allergen-ing-card');
            const allergens = Array.from(card.querySelectorAll('.allergen-pill'))
                .filter(p => p.dataset.state)
                .map(p => ({ allergenId: parseInt(p.dataset.allergenId), presence: p.dataset.state }));

            S.ingredientAllergenCache[ingredientId] = allergens;

            const data = await apiFetch(`/admin/ingredients/${ingredientId}/allergens`, { allergens });
            if (!data.error) showToast(MSG_INGREDIENT_ALLERGENS_SAVED, 'success');
        }

        function renderPrivateIngredientAllergens() {
            const restaurantItems = collectIngredients().filter(i => i.value.startsWith('r:') || i.value.startsWith('new:'));
            const wrap = () => document.querySelectorAll('[id="p-private-ingredient-allergens-wrap"]');

            if (!restaurantItems.length) {
                wrap().forEach(el => el.style.display = 'none');
                return;
            }
            wrap().forEach(el => el.style.display = '');

            const html = restaurantItems.map(item => {
                if (item.value.startsWith('new:')) {
                    return `<div class="allergen-ing-card"><div class="allergen-ing-name">${item.name}</div><p class="allergen-hint" style="margin-top:0">${MSG_ALLERGEN_NEW_INGREDIENT_HINT}</p></div>`;
                }
                const id = parseInt(item.value.slice(2));
                const grid = ingredientAllergenPillGrid(id, S.ingredientAllergenCache[id]);
                return `<div class="allergen-ing-card"><div class="allergen-ing-name">${item.name}</div><div class="allergen-pill-grid">${grid}</div></div>`;
            }).join('');

            document.querySelectorAll('[id="p-private-ingredient-allergens"]').forEach(el => el.innerHTML = html);
        }

        // Fetches allergen data for any selected private ingredient this
        // panel hasn't already cached (e.g. one just added via search — a
        // freshly-created "new:" one has nothing to fetch yet), then renders.
        async function refreshPrivateIngredientAllergens() {
            const restaurantIds = collectIngredients()
                .filter(i => i.value.startsWith('r:'))
                .map(i => parseInt(i.value.slice(2)));

            const missing = restaurantIds.filter(id => !(id in S.ingredientAllergenCache));
            if (missing.length) {
                const fetched = await apiFetch('/admin/ingredients/allergens?ids=' + missing.join(','), null, 'GET');
                Object.assign(S.ingredientAllergenCache, fetched);
            }

            renderPrivateIngredientAllergens();
        }

        // ── Precio copa / suplemento — add one at a time, each at most once ─────────
        function showExtraPriceChooser(toggleEl) {
            const section = toggleEl.closest('.extra-price-section');
            toggleEl.style.display = 'none';
            section.querySelectorAll('.extra-price-pill').forEach(pill => {
                const field = section.querySelector('.extra-price-field[data-extra="' + pill.dataset.extra + '"]');
                pill.style.display = (field.style.display === 'none') ? '' : 'none';
            });
            section.querySelector('.extra-price-chooser').style.display = '';
        }
        function addExtraPrice(pillEl) {
            const section = pillEl.closest('.extra-price-section');
            section.querySelector('.extra-price-field[data-extra="' + pillEl.dataset.extra + '"]').style.display = '';
            section.querySelector('.extra-price-chooser').style.display = 'none';
            updateExtraPriceToggle(section);
        }
        function removeExtraPrice(removeEl) {
            const field = removeEl.closest('.extra-price-field');
            field.querySelector('input').value = '';
            field.style.display = 'none';
            updateExtraPriceToggle(field.closest('.extra-price-section'));
        }
        function updateExtraPriceToggle(section) {
            const anyAvailable = Array.from(section.querySelectorAll('.extra-price-field')).some(f => f.style.display === 'none');
            section.querySelector('.extra-price-toggle').style.display = anyAvailable ? '' : 'none';
            section.querySelector('.extra-price-chooser').style.display = 'none';
        }
        function revealExtraPrice(type) {
            document.querySelectorAll('.extra-price-section').forEach(section => {
                section.querySelector('.extra-price-field[data-extra="' + type + '"]').style.display = '';
                updateExtraPriceToggle(section);
            });
        }

        // ── Advanced allergen accordion (collapsed by default) ──────────────────────
        function toggleAllergenAdvanced(toggleEl) {
            const body = toggleEl.nextElementSibling;
            const open = toggleEl.getAttribute('aria-expanded') === 'true';
            toggleEl.setAttribute('aria-expanded', open ? 'false' : 'true');
            body.classList.toggle('open', !open);
        }

        // ── Contextual help icons (click/tap to open, click elsewhere to close) ─────
        function toggleHelp(event, iconEl) {
            event.stopPropagation();
            const wasOpen = iconEl.classList.contains('help-open');
            closeAllHelp();
            if (wasOpen) return;

            const pop = document.createElement('div');
            pop.className = 'help-popover';
            pop.textContent = iconEl.dataset.helpText;
            document.body.appendChild(pop);

            const iconRect = iconEl.getBoundingClientRect();
            const popRect = pop.getBoundingClientRect();
            let left = iconRect.left + iconRect.width / 2 - popRect.width / 2;
            left = Math.max(8, Math.min(left, window.innerWidth - popRect.width - 8));
            let top = iconRect.top - popRect.height - 8;
            if (top < 8) top = iconRect.bottom + 8;

            pop.style.left = left + 'px';
            pop.style.top = top + 'px';
            iconEl.classList.add('help-open');
        }
        function closeAllHelp() {
            document.querySelectorAll('.help-popover').forEach(p => p.remove());
            document.querySelectorAll('.help-icon.help-open').forEach(el => el.classList.remove('help-open'));
        }
        document.addEventListener('click', closeAllHelp);
        document.addEventListener('keydown', e => { if (e.key === 'Escape') closeAllHelp(); });

        // ── Image preview ──────────────────────────────────────────────────────────
        function previewImage(input) {
            if (!input.files?.length) return;
            const area = panelEl('img-upload-area');
            const url  = URL.createObjectURL(input.files[0]);
            let img    = area.querySelector('img');
            if (!img) { img = document.createElement('img'); area.appendChild(img); }
            img.src = url;
            area.querySelector('.img-upload-hint').style.display = 'none';
        }

        // ── Reset ──────────────────────────────────────────────────────────────────
        function resetProduct() {
            ['p-name','p-desc','p-price','p-supplement-price','p-glass-price','p-calories'].forEach(id =>
                document.querySelectorAll('[id="' + id + '"]').forEach(el => { el.value=''; el.classList.remove('error'); })
            );
            ['p-name-error','p-desc-error','p-price-error'].forEach(id =>
                document.querySelectorAll('[id="' + id + '"]').forEach(el => el.classList.remove('show'))
            );
            document.querySelectorAll('[id="p-category"]').forEach(el => { el.selectedIndex = 0; });
            document.querySelectorAll('.tag-pill').forEach(p => p.classList.remove('on'));
            document.querySelectorAll('[id="p-recommended"]').forEach(cb => cb.checked = false);
            document.querySelectorAll('.cat-card').forEach(c => c.classList.remove('selected'));
            setIngredientItems([]);
            S.allergenOverrides = [];
            S.ingredientAllergenCache = {};
            renderAllergenComputed([]);
            renderAllergenOverrides();
            document.querySelectorAll('[id="p-private-ingredient-allergens-wrap"]').forEach(el => el.style.display = 'none');
            document.querySelectorAll('.extra-price-toggle').forEach(el => el.style.display = '');
            document.querySelectorAll('.extra-price-chooser').forEach(el => el.style.display = 'none');
            document.querySelectorAll('.extra-price-field').forEach(el => el.style.display = 'none');
            document.querySelectorAll('.allergen-accordion-toggle').forEach(el => el.setAttribute('aria-expanded', 'false'));
            document.querySelectorAll('.allergen-accordion-body').forEach(el => el.classList.remove('open'));
            closeAllHelp();
            document.getElementById('cat-select-error').style.display = 'none';
            document.querySelectorAll('[id="img-upload-area"]').forEach(area => {
                area.querySelector('img')?.remove();
                const hint = area.querySelector('.img-upload-hint');
                if (hint) hint.style.display = '';
            });
            S.productId=null; S.categoryId=null; S.spicy=0;
            // Reset steps visibility
            ['product-modal-steps','product-sheet-steps'].forEach(id => {
                const el=document.getElementById(id); if(el) el.style.display='';
            });
            ['d-back-btn','m-back-btn'].forEach(id => {
                const el=document.getElementById(id); if(el) el.style.display='';
            });
            updateSpicyUI();
        }

        // ── Utils ──────────────────────────────────────────────────────────────────
        // The product-fields partial is included twice (desktop modal + mobile sheet).
        // panelEl() queries inside the currently-open panel first, so reads always hit
        // the visible copy. setVal() writes to both copies so they stay in sync.
        function activePanel() {
            return document.querySelector('.modal-overlay.open, .sheet-overlay.open');
        }
        function panelEl(id) {
            const p = activePanel();
            return p?.querySelector('[id="' + id + '"]') ?? document.getElementById(id);
        }
        const getVal = id => panelEl(id)?.value?.trim() ?? '';
        const setVal = (id, v) => document.querySelectorAll('[id="' + id + '"]').forEach(el => { el.value = v ?? ''; });

        async function apiFetch(url, body=null, method=null) {
            // Method must always be explicit (or default to POST, which is
            // what every mutating route here expects) — it must never be
            // inferred from whether a body was passed. A GET-only route
            // (like product_get) that received a request with no body used
            // to silently fall back to GET seeming to work, but a POST-only
            // route (toggle/delete) receiving no body was silently sent as
            // GET too, which Symfony rejects with a 405 the caller never saw
            // coming since it always assumed method === 'POST' had been sent.
            const m = method ?? 'POST';
            const opts = { method: m, headers: body ? {'Content-Type':'application/json'} : {} };
            if (body) opts.body = JSON.stringify(body);

            let res, data;
            try {
                res = await fetch(url, opts);
                data = await res.json();
            } catch (e) {
                data = null;
            }

            if (!res || !res.ok || data === null) {
                const message = (data && data.error) ? data.error : MSG_UNEXPECTED_ERROR;
                showToast(message, 'error');
                return { error: message };
            }

            return data;
        }

    </script>
{% endblock %}
