{% block javascripts %}
    <script>
        const LOCALE   = '{{ locale }}';
        const CURRENCY = '{{ restaurant.currency }}';
        const SPICY_LABELS = {{ ['spicy.none','spicy.mild','spicy.medium','spicy.hot','spicy.very_hot','spicy.extreme']|map(k => k|trans({}, 'admin_menu'))|json_encode|raw }};

        const MSG_NEW_CATEGORY       = "{{ 'modal.category.new_title'|trans({}, 'admin_menu')|e('js') }}";
        const MSG_EDIT_CATEGORY      = "{{ 'modal.category.edit_title'|trans({}, 'admin_menu')|e('js') }}";
        const MSG_NEW_PRODUCT        = "{{ 'modal.product.new_title'|trans({}, 'admin_menu')|e('js') }}";
        const MSG_EDIT_PRODUCT       = "{{ 'modal.product.edit_title'|trans({}, 'admin_menu')|e('js') }}";
        const MSG_ERROR_LOADING_PRODUCT = "{{ 'js.error_loading_product'|trans({}, 'admin_menu')|e('js') }}";
        const MSG_AI_IMPORT_SOON     = "{{ 'js.ai_import_soon'|trans({}, 'admin_menu')|e('js') }}";
        const MSG_CATEGORY_UPDATED   = "{{ 'js.category_updated'|trans({}, 'admin_menu')|e('js') }}";
        const MSG_CATEGORY_CREATED   = "{{ 'js.category_created'|trans({}, 'admin_menu')|e('js') }}";
        const MSG_CATEGORY_VISIBLE   = "{{ 'category.toggle_visible'|trans({}, 'admin_menu')|e('js') }}";
        const MSG_CATEGORY_HIDDEN    = "{{ 'category.toggle_hidden'|trans({}, 'admin_menu')|e('js') }}";
        const MSG_CATEGORY_HIDE_TITLE = "{{ 'category.toggle_hide_title'|trans({}, 'admin_menu')|e('js') }}";
        const MSG_CATEGORY_SHOW_TITLE = "{{ 'category.toggle_show_title'|trans({}, 'admin_menu')|e('js') }}";
        const MSG_CONFIRM_DELETE_CATEGORY_WITH_PRODUCTS = "{{ 'js.confirm_delete_category_with_products'|trans({}, 'admin_menu')|e('js') }}";
        const MSG_CONFIRM_DELETE_CATEGORY = "{{ 'js.confirm_delete_category'|trans({}, 'admin_menu')|e('js') }}";
        const MSG_CATEGORY_DELETED   = "{{ 'js.category_deleted'|trans({}, 'admin_menu')|e('js') }}";
        const MSG_FILL_REQUIRED_FIELDS = "{{ 'js.fill_required_fields'|trans({}, 'admin_menu')|e('js') }}";
        const MSG_PRODUCT_SAVED     = "{{ 'js.product_saved'|trans({}, 'admin_menu')|e('js') }}";
        const MSG_PRODUCT_CREATED  = "{{ 'js.product_created'|trans({}, 'admin_menu')|e('js') }}";
        const MSG_PRODUCT_VISIBLE  = "{{ 'product.visible'|trans({}, 'admin_menu')|e('js') }}";
        const MSG_PRODUCT_HIDDEN   = "{{ 'product.hidden'|trans({}, 'admin_menu')|e('js') }}";
        const MSG_PRODUCT_DELETED  = "{{ 'js.product_deleted'|trans({}, 'admin_menu')|e('js') }}";
        const MSG_CONFIRM_DELETE_PRODUCT = "{{ 'js.confirm_delete_product'|trans({}, 'admin_menu')|e('js') }}";
        const MSG_DEFAULT_PRODUCT_NAME = "{{ 'js.default_product_name'|trans({}, 'admin_menu')|e('js') }}";
        const MSG_NEW_INGREDIENT_LABEL = "{{ 'js.new_ingredient_label'|trans({}, 'admin_menu')|e('js') }}";
        const MSG_NO_INGREDIENTS_FOUND = "{{ 'ingredients.no_results'|trans({}, 'admin_menu')|e('js') }}";
        const MSG_INGREDIENTS_PLACEHOLDER = "{{ 'ingredients.placeholder'|trans({}, 'admin_menu')|e('js') }}";

        const S = {
            productId:   null,
            categoryId:  null,
            editingCatId:null,
            spicy:       0,
        };

        // ── Responsive helpers ────────────────────────────────────────────────────
        const isMobile = () => window.innerWidth < 768;

        // ── UI controller ─────────────────────────────────────────────────────────
        const UI = {
            openNewCategory() {
                S.editingCatId = null;
                document.getElementById('cat-modal-title').textContent  = MSG_NEW_CATEGORY;
                document.getElementById('cat-sheet-title').textContent  = MSG_NEW_CATEGORY;
                document.getElementById('cat-name-input').value = '';
                document.getElementById('cat-name-error').classList.remove('show');
                this._openCat();
                setTimeout(() => document.getElementById('cat-name-input').focus(), 80);
            },
            openEditCategory(id, name) {
                S.editingCatId = id;
                document.getElementById('cat-modal-title').textContent = MSG_EDIT_CATEGORY;
                document.getElementById('cat-sheet-title').textContent = MSG_EDIT_CATEGORY;
                document.getElementById('cat-name-input').value = name;
                document.getElementById('cat-name-error').classList.remove('show');
                this._openCat();
                setTimeout(() => document.getElementById('cat-name-input').focus(), 80);
            },
            _openCat() {
                if (isMobile()) document.getElementById('mobile-cat-sheet').classList.add('open');
                else            document.getElementById('desktop-cat-modal').classList.add('open');
            },
            closeCat() {
                document.getElementById('mobile-cat-sheet').classList.remove('open');
                document.getElementById('desktop-cat-modal').classList.remove('open');
            },

            openNewProduct(categoryId) {
                resetProduct();
                S.productId  = null;
                S.categoryId = categoryId;
                this._setProductTitle(MSG_NEW_PRODUCT);
                this._showDeleteBtn(false);
                if (categoryId) {
                    document.querySelectorAll('.cat-card').forEach(c =>
                        c.classList.toggle('selected', parseInt(c.dataset.catId) === categoryId)
                    );
                    this.goStep2();
                } else {
                    this.goStep1();
                }
                this._openProduct();
            },
            async openEditProduct(id) {
                resetProduct();
                S.productId = id;
                this._setProductTitle(MSG_EDIT_PRODUCT);
                this._showDeleteBtn(true);
                this._hideSteps();
                this._hideBackBtn();
                this.goStep2(true);
                this._openProduct();

                try {
                    const data = await apiFetch(`/admin/products/${id}`);
                    S.categoryId = data.categoryId;
                    document.querySelectorAll('[id="p-category"]').forEach(el => { el.value = data.categoryId; });
                    S.spicy      = data.spicyLevel ?? 0;
                    updateSpicyUI();

                    const t = data.translations[LOCALE] ?? Object.values(data.translations)[0] ?? {};
                    setVal('p-name',     t.name ?? '');
                    setVal('p-desc',     t.description ?? '');
                    setVal('p-price',    (data.basePrice / 100).toFixed(2));
                    setVal('p-calories', data.calories ?? '');

                    document.querySelectorAll('.tag-pill').forEach(p =>
                        p.classList.toggle('on', data.tags.includes(parseInt(p.dataset.tagId)))
                    );
                    await setIngredientItems(data.ingredientsList ?? []);
                } catch(e) { showToast(MSG_ERROR_LOADING_PRODUCT, 'error'); }
            },
            _openProduct() {
                if (isMobile()) document.getElementById('mobile-product-sheet').classList.add('open');
                else            document.getElementById('desktop-product-modal').classList.add('open');
            },
            closeProduct() {
                document.getElementById('mobile-product-sheet').classList.remove('open');
                document.getElementById('desktop-product-modal').classList.remove('open');
                resetProduct();
            },
            _setProductTitle(t) {
                document.getElementById('product-modal-title').textContent = t;
                document.getElementById('product-sheet-title').textContent = t;
            },
            _showDeleteBtn(show) {
                document.getElementById('d-delete-btn').style.display = show ? '' : 'none';
                document.getElementById('m-delete-btn').style.display = show ? '' : 'none';
            },
            _hideSteps() {
                document.getElementById('product-modal-steps').style.display = 'none';
                document.getElementById('product-sheet-steps').style.display = 'none';
            },
            _hideBackBtn() {
                document.getElementById('d-back-btn').style.display = 'none';
                document.getElementById('m-back-btn').style.display = 'none';
            },

            goStep1() {
                ['d-step1-body','m-step1-body'].forEach(id => { const el=document.getElementById(id); if(el) el.style.display=''; });
                ['d-step2-body','m-step2-body'].forEach(id => { const el=document.getElementById(id); if(el) el.style.display='none'; });
                ['d-step-1','m-step-1'].forEach(id => document.getElementById(id)?.classList.add('active'));
                ['d-step-2','m-step-2'].forEach(id => document.getElementById(id)?.classList.remove('active'));
            },
            goStep2(force = false) {
                if (!force && !S.categoryId) {
                    const sel = document.querySelector('.cat-card.selected');
                    if (!sel) { document.getElementById('cat-select-error').style.display=''; return; }
                    S.categoryId = parseInt(sel.dataset.catId);
                }
                if (S.categoryId) {
                    document.querySelectorAll('[id="p-category"]').forEach(el => { el.value = S.categoryId; });
                }
                ['d-step1-body','m-step1-body'].forEach(id => { const el=document.getElementById(id); if(el) el.style.display='none'; });
                ['d-step2-body','m-step2-body'].forEach(id => { const el=document.getElementById(id); if(el) el.style.display=''; });
                ['d-step-2','m-step-2'].forEach(id => document.getElementById(id)?.classList.add('active'));
                ['d-step-1','m-step-1'].forEach(id => document.getElementById(id)?.classList.remove('active'));
                initIngredientSelects();
                setTimeout(() => panelEl('p-name')?.focus(), 80);
            },

            openAiImport() { showToast(MSG_AI_IMPORT_SOON); },
        };

        // ── Category CRUD ──────────────────────────────────────────────────────────
        async function saveCategory() {
            const name = document.getElementById('cat-name-input').value.trim();
            if (!name) { document.getElementById('cat-name-error').classList.add('show'); return; }
            document.getElementById('cat-name-error').classList.remove('show');

            const url = S.editingCatId
                ? `/admin/categories/${S.editingCatId}/edit`
                : '/admin/categories/create';

            const data = await apiFetch(url, { name });
            if (data.error) { showToast(data.error, 'error'); return; }

            showToast(S.editingCatId ? MSG_CATEGORY_UPDATED : MSG_CATEGORY_CREATED, 'success');
            UI.closeCat();
            setTimeout(() => location.reload(), 700);
        }

        async function toggleCategory(id, btn) {
            const data = await apiFetch(`/admin/categories/${id}/toggle`);
            btn.classList.toggle('on', data.active);
            btn.title = data.active ? MSG_CATEGORY_HIDE_TITLE : MSG_CATEGORY_SHOW_TITLE;
            showToast(data.active ? MSG_CATEGORY_VISIBLE : MSG_CATEGORY_HIDDEN);
        }

        async function deleteCategory(id, name, count, btn) {
            const msg = count > 0
                ? MSG_CONFIRM_DELETE_CATEGORY_WITH_PRODUCTS.replace('%name%', name).replace('%count%', count)
                : MSG_CONFIRM_DELETE_CATEGORY.replace('%name%', name);
            if (!confirm(msg)) return;
            const data = await apiFetch(`/admin/categories/${id}/delete`);
            if (data.ok) {
                btn.closest('.cat-block').remove();
                showToast(MSG_CATEGORY_DELETED, 'success');
                if (!document.querySelector('.cat-block')) location.reload();
            }
        }

        // ── Product CRUD ───────────────────────────────────────────────────────────
        function validateProduct() {
            let ok = true;
            [['p-name','p-name-error'],['p-desc','p-desc-error'],['p-price','p-price-error']].forEach(([fid,eid]) => {
                const val = panelEl(fid)?.value?.trim();
                const empty = !val || (fid === 'p-price' && parseFloat(val) <= 0);
                panelEl(eid)?.classList.toggle('show', empty);
                panelEl(fid)?.classList.toggle('error', empty);
                if (empty) ok = false;
            });
            return ok;
        }

        async function saveProduct() {
            if (!validateProduct()) { showToast(MSG_FILL_REQUIRED_FIELDS, 'error'); return; }

            const translations = {};
            const name = getVal('p-name'), desc = getVal('p-desc');
            if (name) translations[LOCALE] = { name, description: desc || null };

            const tags = [...document.querySelectorAll('.tag-pill.on')].map(t => parseInt(t.dataset.tagId));

            const payload = {
                id:          S.productId,
                categoryId:  parseInt(getVal('p-category')) || S.categoryId,
                basePrice:   parseFloat(getVal('p-price')) || 0,
                calories:    parseInt(getVal('p-calories')) || null,
                spicyLevel:  S.spicy || null,
                active:      true,
                translations,
                tags,
                ingredients: collectIngredients(),
            };

            const data = await apiFetch('/admin/products/save', payload);
            if (data.error) { showToast(data.error, 'error'); return; }
            showToast(S.productId ? MSG_PRODUCT_SAVED : MSG_PRODUCT_CREATED, 'success');
            UI.closeProduct();
            setTimeout(() => location.reload(), 700);
        }

        async function toggleProduct(id, btn) {
            const data = await apiFetch(`/admin/products/${id}/toggle`);
            btn.classList.toggle('on', data.active);
            btn.title = data.active ? MSG_PRODUCT_VISIBLE : MSG_PRODUCT_HIDDEN;
            const row = btn.closest('.product-row');
            row.classList.toggle('inactive', !data.active);
            const status = row.querySelector('.product-status');
            if (status) status.textContent = data.active ? MSG_PRODUCT_VISIBLE : MSG_PRODUCT_HIDDEN;
            showToast(data.active ? MSG_PRODUCT_VISIBLE : MSG_PRODUCT_HIDDEN);
        }

        async function deleteProduct() {
            if (!S.productId) return;
            const name = getVal('p-name') || MSG_DEFAULT_PRODUCT_NAME;
            if (!confirm(MSG_CONFIRM_DELETE_PRODUCT.replace('%name%', name))) return;
            const data = await apiFetch(`/admin/products/${S.productId}/delete`);
            if (data.ok) { showToast(MSG_PRODUCT_DELETED, 'success'); UI.closeProduct(); setTimeout(() => location.reload(), 700); }
        }

        // ── Category selector ──────────────────────────────────────────────────────
        document.querySelectorAll('.cat-card').forEach(c => c.addEventListener('click', () => {
            document.querySelectorAll('.cat-card').forEach(x => x.classList.remove('selected'));
            c.classList.add('selected');
            S.categoryId = parseInt(c.dataset.catId);
            document.getElementById('cat-select-error').style.display = 'none';
        }));

        // ── Spicy ──────────────────────────────────────────────────────────────────
        function setSpicy(level) {
            S.spicy = S.spicy === level ? 0 : level;
            updateSpicyUI();
        }
        function updateSpicyUI() {
            document.querySelectorAll('.spicy-pip').forEach(p =>
                p.classList.toggle('on', parseInt(p.dataset.level) <= S.spicy)
            );
            document.querySelectorAll('.spicy-text').forEach(el =>
                el.textContent = SPICY_LABELS[S.spicy]
            );
        }

        // ── Ingredients (Tom Select, server-searched) ───────────────────────────────
        // The product-fields partial is included twice (desktop modal + mobile
        // sheet), so there are two <select id="ing-select"> elements in the DOM —
        // one Tom Select instance is created per copy, mirroring how the rest of
        // this file keeps duplicate-id panels in sync (see panelEl()/setVal()).
        let _tomSelectCtor = null;
        async function ensureTomSelect() {
            if (!_tomSelectCtor) {
                _tomSelectCtor = (await import('tom-select')).default;
                import('tom-select/dist/css/tom-select.default.min.css');
            }
            return _tomSelectCtor;
        }

        function ingSelects() {
            return Array.from(document.querySelectorAll('[id="ing-select"]'))
                .map(el => el.tomselect)
                .filter(Boolean);
        }

        async function initIngredientSelects() {
            const TomSelect = await ensureTomSelect();
            document.querySelectorAll('[id="ing-select"]').forEach(el => {
                if (el.tomselect) return;
                new TomSelect(el, {
                    plugins: ['remove_button'],
                    valueField: 'id',
                    labelField: 'name',
                    searchField: [],
                    options: [],
                    persist: false,
                    maxOptions: 20,
                    closeAfterSelect: true,
                    placeholder: MSG_INGREDIENTS_PLACEHOLDER,
                    create(input) {
                        return { id: 'new:' + input.trim(), name: input.trim() };
                    },
                    createFilter(input) {
                        const q = input.trim().toLowerCase();
                        if (!q) return false;
                        return !Object.values(this.options).some(o => o.name.toLowerCase() === q);
                    },
                    load(query, callback) {
                        if (query.trim().length < 2) { callback(); return; }
                        apiFetch('/admin/ingredients/search?q=' + encodeURIComponent(query.trim()), null, 'GET')
                            .then(results => callback(results))
                            .catch(() => callback());
                    },
                    render: {
                        option_create(data, escape) {
                            return `<div class="create"><i class="ti ti-plus" style="font-size:14px" aria-hidden="true"></i> ${escape(data.input.trim())} <span>${MSG_NEW_INGREDIENT_LABEL}</span></div>`;
                        },
                        no_results() {
                            return `<div class="no-results">${MSG_NO_INGREDIENTS_FOUND}</div>`;
                        },
                    },
                });
            });
        }

        // Replaces every panel's current selection with `list` ([{id, name}]).
        async function setIngredientItems(list) {
            await initIngredientSelects();
            ingSelects().forEach(ts => {
                ts.clear(true);
                ts.clearOptions();
                (list || []).forEach(item => {
                    const value = item.id != null ? String(item.id) : ('new:' + item.name);
                    ts.addOption({ id: value, name: item.name });
                    ts.addItem(value, true);
                });
            });
        }

        // Reads the currently-visible panel's selection back into [{id, name}],
        // translating the "new:" placeholder ids created client-side back to null
        // so the backend knows to create them.
        function collectIngredients() {
            const ts = panelEl('ing-select')?.tomselect;
            if (!ts) return [];
            return ts.items.map(value => {
                const opt = ts.options[value];
                return {
                    id:   value.startsWith('new:') ? null : parseInt(value, 10),
                    name: opt?.name ?? value,
                };
            });
        }

        // ── Image preview ──────────────────────────────────────────────────────────
        function previewImage(input) {
            if (!input.files?.length) return;
            const area = panelEl('img-upload-area');
            const url  = URL.createObjectURL(input.files[0]);
            let img    = area.querySelector('img');
            if (!img) { img = document.createElement('img'); area.appendChild(img); }
            img.src = url;
            area.querySelector('.img-upload-hint').style.display = 'none';
        }

        // ── Reset ──────────────────────────────────────────────────────────────────
        function resetProduct() {
            ['p-name','p-desc','p-price','p-calories'].forEach(id =>
                document.querySelectorAll('[id="' + id + '"]').forEach(el => { el.value=''; el.classList.remove('error'); })
            );
            ['p-name-error','p-desc-error','p-price-error'].forEach(id =>
                document.querySelectorAll('[id="' + id + '"]').forEach(el => el.classList.remove('show'))
            );
            document.querySelectorAll('[id="p-category"]').forEach(el => { el.selectedIndex = 0; });
            document.querySelectorAll('.tag-pill').forEach(p => p.classList.remove('on'));
            document.querySelectorAll('.cat-card').forEach(c => c.classList.remove('selected'));
            setIngredientItems([]);
            document.getElementById('cat-select-error').style.display = 'none';
            document.querySelectorAll('[id="img-upload-area"]').forEach(area => {
                area.querySelector('img')?.remove();
                const hint = area.querySelector('.img-upload-hint');
                if (hint) hint.style.display = '';
            });
            S.productId=null; S.categoryId=null; S.spicy=0;
            // Reset steps visibility
            ['product-modal-steps','product-sheet-steps'].forEach(id => {
                const el=document.getElementById(id); if(el) el.style.display='';
            });
            ['d-back-btn','m-back-btn'].forEach(id => {
                const el=document.getElementById(id); if(el) el.style.display='';
            });
            updateSpicyUI();
        }

        // ── Utils ──────────────────────────────────────────────────────────────────
        // The product-fields partial is included twice (desktop modal + mobile sheet).
        // panelEl() queries inside the currently-open panel first, so reads always hit
        // the visible copy. setVal() writes to both copies so they stay in sync.
        function activePanel() {
            return document.querySelector('.modal-overlay.open, .sheet-overlay.open');
        }
        function panelEl(id) {
            const p = activePanel();
            return p?.querySelector('[id="' + id + '"]') ?? document.getElementById(id);
        }
        const getVal = id => panelEl(id)?.value?.trim() ?? '';
        const setVal = (id, v) => document.querySelectorAll('[id="' + id + '"]').forEach(el => { el.value = v ?? ''; });

        async function apiFetch(url, body=null, method=null) {
            const m = method ?? (body !== null ? 'POST' : 'GET');
            const opts = { method: m, headers: body ? {'Content-Type':'application/json'} : {} };
            if (body) opts.body = JSON.stringify(body);
            const res = await fetch(url, opts);
            return res.json();
        }

    </script>
{% endblock %}
