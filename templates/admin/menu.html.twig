                <div class="panel-body">
                    {% include 'admin/_product_fields.html.twig' %}
                </div>
                <div class="panel-footer">
                    <button class="btn btn-danger" id="m-delete-btn" onclick="deleteProduct()" style="display:none">
                        <i class="ti ti-trash" aria-hidden="true"></i>
                    </button>
                    <button class="btn" id="m-back-btn" onclick="UI.goStep1()">
                        <i class="ti ti-arrow-left" aria-hidden="true"></i>
                    </button>
                    <button class="btn btn-primary" onclick="saveProduct()">
