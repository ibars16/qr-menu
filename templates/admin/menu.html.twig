{#/home/david/gitProjects/qr-menu/templates/admin/menu.html.twig#}
{% extends 'admin/base.html.twig' %}

{% block title %}Carta{% endblock %}
{% block page_title %}Carta{% endblock %}

{% block header_actions %}
    <button class="btn btn-ai" onclick="UI.openAiImport()">
        <i class="ti ti-sparkles" aria-hidden="true"></i>
        <span class="hide-mobile">Importar con IA</span>
    </button>
    <button class="btn" onclick="UI.openNewCategory()">
        <i class="ti ti-folder-plus" aria-hidden="true"></i>
        <span class="hide-mobile">Nueva categoría</span>
    </button>
    <button class="btn btn-primary" onclick="UI.openNewProduct(null)">
        <i class="ti ti-plus" aria-hidden="true"></i>
        Nuevo plato
    </button>
{% endblock %}

{% block stylesheets %}
    <style>
        /* ── Hide labels on mobile ── */
        @media (max-width: 767px) { .hide-mobile { display: none; } }

        /* ══════════════════════════════
           CARTA
        ══════════════════════════════ */
        .menu-wrap { max-width: 860px; }

        .empty-state  { text-align:center; padding:80px 24px; }
        .empty-icon   { font-size:52px; display:block; margin-bottom:16px; opacity:0.2; }
        .empty-title  { font-size:20px; font-weight:600; color:#fff; margin-bottom:8px; letter-spacing:-0.3px; }
        .empty-sub    { font-size:14px; color:#444; line-height:1.6; margin-bottom:28px; max-width:340px; margin-left:auto; margin-right:auto; }
        .empty-btns   { display:flex; gap:10px; justify-content:center; flex-wrap:wrap; }

        .cat-block    { border:1px solid #1c1c1c; border-radius:12px; margin-bottom:10px; overflow:hidden; }
        .cat-header   { display:flex; align-items:center; gap:8px; padding:11px 14px; background:#141414; border-bottom:1px solid #1c1c1c; }
        .cat-drag     { color:#2a2a2a; cursor:grab; font-size:16px; flex-shrink:0; }
        .cat-drag:active { cursor:grabbing; }
        .cat-name-text { font-size:14px; font-weight:500; color:#ccc; flex:1; }
        .cat-count    { font-size:11px; color:#3a3a3a; }
        .cat-actions  { display:flex; gap:4px; }

        .toggle {
            width:32px; height:18px; border-radius:9px; background:#222;
            position:relative; cursor:pointer; transition:background 0.15s;
            border:none; padding:0; flex-shrink:0;
        }
        .toggle::after {
            content:''; position:absolute; width:12px; height:12px;
            border-radius:50%; background:#444; top:3px; left:3px;
            transition:left 0.15s, background 0.15s;
        }
        .toggle.on { background:rgba(193,68,14,0.25); }
        .toggle.on::after { left:17px; background:#C1440E; }

        .icon-btn {
            width:28px; height:28px; border-radius:6px; border:1px solid #242424;
            background:#1a1a1a; display:flex; align-items:center; justify-content:center;
            cursor:pointer; color:#444; font-size:13px;
            transition:color 0.1s, border-color 0.1s;
        }
        .icon-btn:hover        { color:#ccc; border-color:#3a3a3a; }
        .icon-btn.danger:hover { color:#F0997B; border-color:rgba(240,153,123,0.3); }

        @media (max-width: 767px) {
            .icon-btn { width:36px; height:36px; font-size:16px; }
            .toggle   { width:38px; height:22px; }
            .toggle::after { width:14px; height:14px; top:4px; left:4px; }
            .toggle.on::after { left:20px; }
        }

        .products-list { padding:4px; }
        .product-row {
            display:flex; align-items:center; gap:8px; padding:9px 8px;
            border-radius:8px; border:1px solid transparent; cursor:pointer;
            transition:background 0.1s, border-color 0.1s; min-height:52px;
        }
        .product-row:hover { background:#161616; border-color:#1c1c1c; }
        .product-drag { color:#222; cursor:grab; font-size:14px; flex-shrink:0; }
        .product-drag:active { cursor:grabbing; }
        .product-thumb {
            width:38px; height:38px; border-radius:8px; background:#1c1c1c;
            border:1px solid #242424; display:flex; align-items:center;
            justify-content:center; font-size:18px; flex-shrink:0; overflow:hidden;
        }
        .product-thumb img { width:100%; height:100%; object-fit:cover; }
        .product-info { flex:1; min-width:0; }
        .product-name { font-size:13px; font-weight:500; color:#ccc; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
        .product-meta { font-size:11px; color:#3a3a3a; margin-top:2px; }
        .product-price { font-size:13px; font-weight:500; color:#666; flex-shrink:0; min-width:58px; text-align:right; }
        .product-row.inactive { opacity:0.4; }

        @media (max-width: 767px) {
            .product-row  { min-height:64px; padding:10px 8px; }
            .product-thumb { width:44px; height:44px; font-size:20px; }
            .product-name { font-size:14px; }
            .product-meta { font-size:12px; }
            .product-price { font-size:14px; }
        }

        .add-row { padding:4px 6px 8px; }
        .add-product-btn {
            width:100%; padding:8px; border:1px dashed #1e1e1e; border-radius:8px;
            background:none; color:#2e2e2e; font-size:12px; cursor:pointer;
            display:flex; align-items:center; justify-content:center; gap:5px;
            min-height:40px; transition:border-color 0.1s, color 0.1s;
        }
        .add-product-btn:hover { border-color:#3a3a3a; color:#666; }

        @media (max-width: 767px) {
            .add-product-btn { min-height:48px; font-size:13px; }
        }

        /* ══════════════════════════════
           DESKTOP MODAL
        ══════════════════════════════ */
        .modal-overlay {
            position:fixed; inset:0; background:rgba(0,0,0,0.75);
            z-index:500; display:flex; align-items:center; justify-content:center;
            padding:20px; opacity:0; pointer-events:none; transition:opacity 0.2s;
        }
        .modal-overlay.open { opacity:1; pointer-events:all; }
        .modal {
            background:#141414; border:1px solid #242424; border-radius:16px;
            width:100%; max-height:90vh; display:flex; flex-direction:column;
            transform:translateY(8px) scale(0.98); transition:transform 0.2s;
        }
        .modal-overlay.open .modal { transform:translateY(0) scale(1); }
        .modal-sm { max-width:380px; }
        .modal-md { max-width:560px; }

        /* ══════════════════════════════
           MOBILE BOTTOM SHEET
        ══════════════════════════════ */
        .sheet-overlay {
            position:fixed; inset:0; background:rgba(0,0,0,0.75);
            z-index:500; display:flex; align-items:flex-end;
            opacity:0; pointer-events:none; transition:opacity 0.25s;
        }
        .sheet-overlay.open { opacity:1; pointer-events:all; }
        .sheet {
            width:100%; background:#141414; border-radius:20px 20px 0 0;
            border-top:1px solid #242424; max-height:92vh;
            display:flex; flex-direction:column;
            transform:translateY(100%); transition:transform 0.3s cubic-bezier(0.32,0.72,0,1);
        }
        .sheet-overlay.open .sheet { transform:translateY(0); }
        .sheet-handle {
            width:36px; height:4px; border-radius:2px; background:#2a2a2a;
            margin:10px auto 0; flex-shrink:0;
        }

        /* Shared modal/sheet parts */
        .panel-header {
            padding:14px 16px 12px; border-bottom:1px solid #1c1c1c;
            display:flex; align-items:center; justify-content:space-between; flex-shrink:0;
        }
        .panel-title { font-size:16px; font-weight:600; color:#fff; letter-spacing:-0.3px; }
        .panel-close {
            width:30px; height:30px; border-radius:50%; border:1px solid #2a2a2a;
            background:#1a1a1a; display:flex; align-items:center; justify-content:center;
            cursor:pointer; color:#555; font-size:13px;
        }
        .panel-close:hover { color:#ccc; }
        .panel-body {
            flex:1; overflow-y:auto; padding:18px; display:flex; flex-direction:column;
            gap:15px; scrollbar-width:thin; scrollbar-color:#222 transparent;
        }
        .panel-footer {
            padding:12px 18px; border-top:1px solid #1c1c1c;
            display:flex; gap:8px; justify-content:flex-end; flex-shrink:0;
            padding-bottom:calc(12px + env(safe-area-inset-bottom));
        }

        @media (max-width: 767px) {
            .panel-title { font-size:17px; }
            .panel-body  { padding:16px; gap:16px; }
            .panel-footer { justify-content:stretch; }
            .panel-footer .btn { flex:1; justify-content:center; min-height:48px; font-size:15px; }
            .panel-footer .btn-danger { flex:0; min-width:48px; padding:0; }
        }

        /* Steps */
        .steps { display:flex; align-items:center; gap:8px; margin-top:4px; }
        .step  { display:flex; align-items:center; gap:5px; font-size:12px; color:#333; }
        .step.active { color:#ccc; }
        .step-num {
            width:20px; height:20px; border-radius:50%; border:1px solid #2a2a2a;
            background:#1a1a1a; display:flex; align-items:center; justify-content:center;
            font-size:10px; font-weight:600; color:#444;
        }
        .step.active .step-num { background:#C1440E; border-color:#C1440E; color:#fff; }
        .step-sep { color:#2a2a2a; }

        /* Cat select */
        .cat-select-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(130px,1fr)); gap:8px; }
        .cat-select-card {
            padding:12px; border-radius:10px; border:1px solid #2a2a2a;
            background:#1a1a1a; cursor:pointer; transition:all 0.1s; text-align:left;
        }
        .cat-select-card:hover     { border-color:#3a3a3a; background:#1e1e1e; }
        .cat-select-card.selected  { border-color:#C1440E; background:rgba(193,68,14,0.1); }
        .cat-select-card-name  { font-size:13px; font-weight:500; color:#ccc; }
        .cat-select-card-count { font-size:11px; color:#444; margin-top:2px; }
        .cat-select-new {
            padding:12px; border-radius:10px; border:1px dashed #2a2a2a;
            background:none; cursor:pointer; color:#444; font-size:13px;
            display:flex; align-items:center; gap:6px;
            transition:border-color 0.1s, color 0.1s;
        }
        .cat-select-new:hover { border-color:#444; color:#888; }

        @media (max-width: 767px) {
            .cat-select-grid { grid-template-columns:repeat(2,1fr); gap:10px; }
            .cat-select-card { padding:14px 12px; }
            .cat-select-card-name { font-size:14px; }
            .cat-select-new { padding:14px 12px; font-size:14px; }
        }

        /* Form fields */
        .field { display:flex; flex-direction:column; gap:5px; }
        .field-label {
            font-size:11px; font-weight:600; color:#555;
            text-transform:uppercase; letter-spacing:0.07em;
            display:flex; align-items:center; gap:5px;
        }
        .req { color:#C1440E; }
        .opt { color:#2a2a2a; font-weight:400; text-transform:none; letter-spacing:0; font-size:10px; }
        .field input, .field textarea, .field select {
            background:#1a1a1a; border:1px solid #2a2a2a; color:#ccc;
            font-size:14px; padding:10px 12px; border-radius:9px;
            outline:none; width:100%; font-family:inherit;
            transition:border-color 0.15s; min-height:42px;
        }
        .field input::placeholder, .field textarea::placeholder { color:#333; }
        .field input:focus, .field textarea:focus, .field select:focus { border-color:#555; }
        .field input.error { border-color:rgba(240,100,80,0.6); }
        .field-error { font-size:11px; color:#F0997B; margin-top:2px; display:none; }
        .field-error.show { display:block; }
        .field textarea { resize:none; height:76px; line-height:1.55; }
        .field-row { display:flex; gap:10px; }
        .field-row .field { flex:1; }

        @media (max-width: 767px) {
            .field input, .field textarea, .field select { font-size:16px; min-height:48px; }
        }

        /* Image upload */
        .img-upload {
            width:100%; height:76px; border:1px dashed #2a2a2a; border-radius:9px;
            display:flex; align-items:center; justify-content:center; gap:8px;
            font-size:13px; color:#444; cursor:pointer; background:#141414;
            transition:border-color 0.15s, color 0.15s; position:relative; overflow:hidden;
        }
        .img-upload:hover { border-color:#444; color:#888; }
        .img-upload img  { position:absolute; inset:0; width:100%; height:100%; object-fit:cover; border-radius:8px; }
        .img-upload-hint { position:relative; z-index:1; display:flex; align-items:center; gap:6px; }

        /* Spicy */
        .spicy-row { display:flex; gap:6px; align-items:center; flex-wrap:wrap; }
        .spicy-pip {
            width:32px; height:32px; border-radius:7px; border:1px solid #2a2a2a;
            background:#1a1a1a; display:flex; align-items:center; justify-content:center;
            cursor:pointer; font-size:15px; transition:all 0.1s; user-select:none;
        }
        .spicy-pip.on   { background:rgba(216,90,48,0.2); border-color:#D85A30; }
        .spicy-pip:hover { border-color:#555; }
        .spicy-text { font-size:12px; color:#444; }

        @media (max-width: 767px) {
            .spicy-pip { width:38px; height:38px; font-size:18px; }
        }

        /* Tags */
        .tag-pills { display:flex; flex-wrap:wrap; gap:6px; }
        .tag-pill  {
            font-size:12px; padding:5px 11px; border-radius:20px; border:1px solid #2a2a2a;
            background:#1a1a1a; color:#555; cursor:pointer; transition:all 0.1s; user-select:none;
            min-height:32px; display:flex; align-items:center;
        }
        .tag-pill.on { background:rgba(99,153,34,0.15); color:#7aad40; border-color:rgba(99,153,34,0.35); }
        .tag-pill:hover:not(.on) { border-color:#3a3a3a; color:#888; }

        @media (max-width: 767px) {
            .tag-pill { font-size:13px; min-height:38px; padding:6px 14px; }
        }

        /* Ingredients */
        .ing-wrap { position:relative; }
        .ing-suggestions {
            position:absolute; top:100%; left:0; right:0; background:#1e1e1e;
            border:1px solid #2a2a2a; border-radius:9px; margin-top:4px;
            z-index:10; overflow:hidden; display:none;
        }
        .ing-suggestions.open { display:block; }
        .ing-option {
            padding:10px 13px; font-size:13px; color:#aaa; cursor:pointer;
            transition:background 0.1s; display:flex; align-items:center; gap:8px;
        }
        .ing-option:hover { background:#252525; }
        .ing-option .new-label { font-size:11px; color:#555; }
        .ing-tags { display:flex; flex-wrap:wrap; gap:5px; margin-top:8px; }
        .ing-tag  {
            display:flex; align-items:center; gap:5px; font-size:12px;
            padding:4px 10px; border-radius:20px; background:#1e1e1e;
            border:1px solid #2a2a2a; color:#888;
        }
        .ing-tag button {
            background:none; border:none; color:#444; cursor:pointer;
            font-size:13px; padding:0; line-height:1; display:flex; align-items:center;
        }
        .ing-tag button:hover { color:#F0997B; }

        @media (max-width: 767px) {
            .ing-option { padding:13px; font-size:14px; }
            .ing-tag    { font-size:13px; padding:5px 12px; }
        }

        /* En móvil NUNCA se muestran los modales de desktop */
        @media (max-width: 767px) {
            .modal-overlay { display:none !important; }
        }

        /* En desktop NUNCA se muestran los bottom sheets */
        @media (min-width: 768px) {
            .sheet-overlay { display:none !important; }
        }
    </style>
{% endblock %}

{% block body %}
    <div class="menu-wrap">

        {% if categories|length == 0 %}
            <div class="empty-state">
                <span class="empty-icon">🍽️</span>
                <div class="empty-title">Tu carta está vacía</div>
                <div class="empty-sub">
                    Crea tu primera categoría (Entrantes, Pizzas, Postres…)
                    y después añade tus platos. O importa toda la carta desde una foto con IA.
                </div>
                <div class="empty-btns">
                    <button class="btn btn-ai" onclick="UI.openAiImport()">
                        <i class="ti ti-sparkles" aria-hidden="true"></i> Importar carta con IA
                    </button>
                    <button class="btn btn-primary" onclick="UI.openNewCategory()">
                        <i class="ti ti-folder-plus" aria-hidden="true"></i> Crear primera categoría
                    </button>
                </div>
            </div>

        {% else %}

            <div id="cats-list">
                {% for category in categories %}
                    {% set catT = category.getTranslation(locale) %}
                    {% set catName = catT ? catT.name : '(sin nombre)' %}

                    <div class="cat-block" data-id="{{ category.id }}">
                        <div class="cat-header">
                            <i class="ti ti-grip-vertical cat-drag" aria-hidden="true"></i>
                            <span class="cat-name-text">{{ catName }}</span>
                            <span class="cat-count">{{ category.products|length }}</span>
                            <div class="cat-actions">
                                <button class="toggle {{ category.isActive ? 'on' : '' }}"
                                        onclick="toggleCategory({{ category.id }}, this)"
                                        title="{{ category.isActive ? 'Visible · pulsa para ocultar' : 'Oculta · pulsa para mostrar' }}"
                                        aria-label="Activar/desactivar categoría"></button>
                                <button class="icon-btn"
                                        onclick="UI.openEditCategory({{ category.id }}, '{{ catName|e('js') }}')"
                                        title="Editar nombre de la categoría">
                                    <i class="ti ti-edit" aria-hidden="true"></i>
                                </button>
                                <button class="icon-btn danger"
                                        onclick="deleteCategory({{ category.id }}, '{{ catName|e('js') }}', {{ category.products|length }}, this)"
                                        title="Eliminar categoría">
                                    <i class="ti ti-trash" aria-hidden="true"></i>
                                </button>
                            </div>
                        </div>

                        <div class="products-list" id="prods-{{ category.id }}">
                            {% for product in category.products %}
                                {% set pT = product.getTranslation(locale) %}
                                {% set pName = pT ? pT.name : '(sin nombre)' %}
                                <div class="product-row {{ not product.isActive ? 'inactive' : '' }}"
                                     data-id="{{ product.id }}"
                                     onclick="UI.openEditProduct({{ product.id }})">
                                    <i class="ti ti-grip-vertical product-drag" aria-hidden="true"></i>
                                    <div class="product-thumb">
                                        {% if product.image %}
                                            <img src="{{ asset('uploads/products/' ~ product.image) }}" alt="{{ pName }}">
                                        {% else %}🍽️{% endif %}
                                    </div>
                                    <div class="product-info">
                                        <div class="product-name">{{ pName }}</div>
                                        <div class="product-meta">
                                            {% if product.spicyLevel > 0 %}🌶 · {% endif %}
                                            {% if product.calories %}{{ product.calories }} kcal · {% endif %}
                                            {{ product.isActive ? 'Visible' : 'Oculto' }}
                                        </div>
                                    </div>
                                    <div class="product-price">
                                        {{ (product.basePrice / 100)|number_format(2) }} {{ restaurant.currency }}
                                    </div>
                                    <button class="toggle {{ product.isActive ? 'on' : '' }}"
                                            onclick="event.stopPropagation(); toggleProduct({{ product.id }}, this)"
                                            title="{{ product.isActive ? 'Visible' : 'Oculto' }}"
                                            aria-label="Activar/desactivar plato"></button>
                                </div>
                            {% endfor %}
                        </div>

                        <div class="add-row">
                            <button class="add-product-btn" onclick="UI.openNewProduct({{ category.id }})">
                                <i class="ti ti-plus" aria-hidden="true"></i>
                                Añadir plato a {{ catName }}
                            </button>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}

    </div>

    {# ════════════════════════════
   DESKTOP: modal categoría
════════════════════════════ #}
    <div class="modal-overlay" id="desktop-cat-modal"
         onclick="if(event.target===this)UI.closeCat()">
        <div class="modal modal-sm">
            <div class="panel-header">
                <div class="panel-title" id="cat-modal-title">Nueva categoría</div>
                <button class="panel-close" onclick="UI.closeCat()" aria-label="Cerrar">
                    <i class="ti ti-x" aria-hidden="true"></i>
                </button>
            </div>
            <div class="panel-body">
                {% include 'admin/_cat_fields.html.twig' %}
            </div>
            <div class="panel-footer">
                <button class="btn" onclick="UI.closeCat()">Cancelar</button>
                <button class="btn btn-primary" onclick="saveCategory()">
                    <i class="ti ti-check" aria-hidden="true"></i> Guardar
                </button>
            </div>
        </div>
    </div>

    {# ════════════════════════════
   MOBILE: bottom sheet categoría
════════════════════════════ #}
    <div class="sheet-overlay" id="mobile-cat-sheet"
         onclick="if(event.target===this)UI.closeCat()">
        <div class="sheet">
            <div class="sheet-handle"></div>
            <div class="panel-header">
                <div class="panel-title" id="cat-sheet-title">Nueva categoría</div>
                <button class="panel-close" onclick="UI.closeCat()" aria-label="Cerrar">
                    <i class="ti ti-x" aria-hidden="true"></i>
                </button>
            </div>
            <div class="panel-body">
                {% include 'admin/_cat_fields.html.twig' %}
            </div>
            <div class="panel-footer">
                <button class="btn" onclick="UI.closeCat()">Cancelar</button>
                <button class="btn btn-primary" onclick="saveCategory()">
                    <i class="ti ti-check" aria-hidden="true"></i> Guardar
                </button>
            </div>
        </div>
    </div>

    {# ════════════════════════════
   DESKTOP: modal producto
════════════════════════════ #}
    <div class="modal-overlay" id="desktop-product-modal"
         onclick="if(event.target===this)UI.closeProduct()">
        <div class="modal modal-md">
            <div class="panel-header">
                <div>
                    <div class="panel-title" id="product-modal-title">Nuevo plato</div>
                    <div class="steps" id="product-modal-steps">
                        <div class="step active" id="d-step-1"><div class="step-num">1</div> Categoría</div>
                        <div class="step-sep">›</div>
                        <div class="step" id="d-step-2"><div class="step-num">2</div> Información</div>
                    </div>
                </div>
                <button class="panel-close" onclick="UI.closeProduct()" aria-label="Cerrar">
                    <i class="ti ti-x" aria-hidden="true"></i>
                </button>
            </div>
            <div id="d-step1-body">
                <div class="panel-body">
                    {% include 'admin/_cat_select.html.twig' %}
                </div>
                <div class="panel-footer">
                    <button class="btn" onclick="UI.closeProduct()">Cancelar</button>
                    <button class="btn btn-primary" onclick="UI.goStep2()">
                        Siguiente <i class="ti ti-arrow-right" aria-hidden="true"></i>
                    </button>
                </div>
            </div>
            <div id="d-step2-body" style="display:none">
                <div class="panel-body">
                    {% include 'admin/_product_fields.html.twig' %}
                </div>
                <div class="panel-footer">
                    <button class="btn btn-danger" id="d-delete-btn" onclick="deleteProduct()" style="display:none">
                        <i class="ti ti-trash" aria-hidden="true"></i>
                    </button>
                    <button class="btn" id="d-back-btn" onclick="UI.goStep1()" style="margin-right:auto">
                        <i class="ti ti-arrow-left" aria-hidden="true"></i> Atrás
                    </button>
                    <button class="btn" onclick="UI.closeProduct()">Cancelar</button>
                    <button class="btn btn-primary" onclick="saveProduct()">
                        <i class="ti ti-check" aria-hidden="true"></i> Guardar plato
                    </button>
                </div>
            </div>
        </div>
    </div>

    {# ════════════════════════════
   MOBILE: bottom sheet producto
════════════════════════════ #}
    <div class="sheet-overlay" id="mobile-product-sheet"
         onclick="if(event.target===this)UI.closeProduct()">
        <div class="sheet">
            <div class="sheet-handle"></div>
            <div class="panel-header">
                <div>
                    <div class="panel-title" id="product-sheet-title">Nuevo plato</div>
                    <div class="steps" id="product-sheet-steps">
                        <div class="step active" id="m-step-1"><div class="step-num">1</div> Categoría</div>
                        <div class="step-sep">›</div>
                        <div class="step" id="m-step-2"><div class="step-num">2</div> Información</div>
                    </div>
                </div>
                <button class="panel-close" onclick="UI.closeProduct()" aria-label="Cerrar">
                    <i class="ti ti-x" aria-hidden="true"></i>
                </button>
            </div>
            <div id="m-step1-body">
                <div class="panel-body">
                    {% include 'admin/_cat_select.html.twig' %}
                </div>
                <div class="panel-footer">
                    <button class="btn" onclick="UI.closeProduct()">Cancelar</button>
                    <button class="btn btn-primary" onclick="UI.goStep2()">
                        Siguiente <i class="ti ti-arrow-right" aria-hidden="true"></i>
                    </button>
                </div>
            </div>
            <div id="m-step2-body" style="display:none">
                <div class="panel-body">
                    {% include 'admin/_product_fields.html.twig' %}
                </div>
                <div class="panel-footer">
                    <button class="btn btn-danger" id="m-delete-btn" onclick="deleteProduct()" style="display:none">
                        <i class="ti ti-trash" aria-hidden="true"></i>
                    </button>
                    <button class="btn" id="m-back-btn" onclick="UI.goStep1()">
                        <i class="ti ti-arrow-left" aria-hidden="true"></i>
                    </button>
                    <button class="btn btn-primary" onclick="saveProduct()">
                        <i class="ti ti-check" aria-hidden="true"></i> Guardar
                    </button>
                </div>
            </div>
        </div>
    </div>

{% endblock %}

{% block javascripts %}
    <script>
        const LOCALE   = '{{ locale }}';
        const CURRENCY = '{{ restaurant.currency }}';
        const SPICY_LABELS = ['Sin picante','Suave 🌶','Medio 🌶🌶','Picante 🌶🌶🌶','Muy picante 🌶🌶🌶🌶','Extremo 🌶🌶🌶🌶🌶'];

        const S = {
            productId:   null,
            categoryId:  null,
            editingCatId:null,
            spicy:       0,
            ingredients: [],
            allIngredients: [],
        };

        // ── Responsive helpers ────────────────────────────────────────────────────
        const isMobile = () => window.innerWidth < 768;

        // ── UI controller ─────────────────────────────────────────────────────────
        const UI = {
            openNewCategory() {
                S.editingCatId = null;
                document.getElementById('cat-modal-title').textContent  = 'Nueva categoría';
                document.getElementById('cat-sheet-title').textContent  = 'Nueva categoría';
                document.getElementById('cat-name-input').value = '';
                document.getElementById('cat-name-error').classList.remove('show');
                this._openCat();
                setTimeout(() => document.getElementById('cat-name-input').focus(), 80);
            },
            openEditCategory(id, name) {
                S.editingCatId = id;
                document.getElementById('cat-modal-title').textContent = 'Editar categoría';
                document.getElementById('cat-sheet-title').textContent = 'Editar categoría';
                document.getElementById('cat-name-input').value = name;
                document.getElementById('cat-name-error').classList.remove('show');
                this._openCat();
                setTimeout(() => document.getElementById('cat-name-input').focus(), 80);
            },
            _openCat() {
                if (isMobile()) document.getElementById('mobile-cat-sheet').classList.add('open');
                else            document.getElementById('desktop-cat-modal').classList.add('open');
            },
            closeCat() {
                document.getElementById('mobile-cat-sheet').classList.remove('open');
                document.getElementById('desktop-cat-modal').classList.remove('open');
            },

            openNewProduct(categoryId) {
                resetProduct();
                S.productId  = null;
                S.categoryId = categoryId;
                this._setProductTitle('Nuevo plato');
                this._showDeleteBtn(false);
                if (categoryId) {
                    document.querySelectorAll('.cat-card').forEach(c =>
                        c.classList.toggle('selected', parseInt(c.dataset.catId) === categoryId)
                    );
                    this.goStep2();
                } else {
                    this.goStep1();
                }
                this._openProduct();
            },
            async openEditProduct(id) {
                resetProduct();
                S.productId = id;
                this._setProductTitle('Editar plato');
                this._showDeleteBtn(true);
                this._hideSteps();
                this._hideBackBtn();
                this.goStep2();
                this._openProduct();

                try {
                    const data = await apiFetch(`/admin/products/${id}`);
                    S.categoryId = data.categoryId;
                    S.spicy      = data.spicyLevel ?? 0;
                    updateSpicyUI();

                    const t = data.translations[LOCALE] ?? Object.values(data.translations)[0] ?? {};
                    setVal('p-name',     t.name ?? '');
                    setVal('p-desc',     t.description ?? '');
                    setVal('p-price',    (data.basePrice / 100).toFixed(2));
                    setVal('p-calories', data.calories ?? '');

                    document.querySelectorAll('.tag-pill').forEach(p =>
                        p.classList.toggle('on', data.tags.includes(parseInt(p.dataset.tagId)))
                    );
                    S.ingredients = data.ingredientsList ?? [];
                    renderIngTags();
                } catch(e) { showToast('Error cargando el plato', 'error'); }
            },
            _openProduct() {
                if (isMobile()) document.getElementById('mobile-product-sheet').classList.add('open');
                else            document.getElementById('desktop-product-modal').classList.add('open');
            },
            closeProduct() {
                document.getElementById('mobile-product-sheet').classList.remove('open');
                document.getElementById('desktop-product-modal').classList.remove('open');
                resetProduct();
            },
            _setProductTitle(t) {
                document.getElementById('product-modal-title').textContent = t;
                document.getElementById('product-sheet-title').textContent = t;
            },
            _showDeleteBtn(show) {
                document.getElementById('d-delete-btn').style.display = show ? '' : 'none';
                document.getElementById('m-delete-btn').style.display = show ? '' : 'none';
            },
            _hideSteps() {
                document.getElementById('product-modal-steps').style.display = 'none';
                document.getElementById('product-sheet-steps').style.display = 'none';
            },
            _hideBackBtn() {
                document.getElementById('d-back-btn').style.display = 'none';
                document.getElementById('m-back-btn').style.display = 'none';
            },

            goStep1() {
                ['d-step1-body','m-step1-body'].forEach(id => { const el=document.getElementById(id); if(el) el.style.display=''; });
                ['d-step2-body','m-step2-body'].forEach(id => { const el=document.getElementById(id); if(el) el.style.display='none'; });
                ['d-step-1','m-step-1'].forEach(id => document.getElementById(id)?.classList.add('active'));
                ['d-step-2','m-step-2'].forEach(id => document.getElementById(id)?.classList.remove('active'));
            },
            goStep2() {
                if (!S.categoryId) {
                    const sel = document.querySelector('.cat-card.selected');
                    if (!sel) { document.getElementById('cat-select-error').style.display=''; return; }
                    S.categoryId = parseInt(sel.dataset.catId);
                }
                ['d-step1-body','m-step1-body'].forEach(id => { const el=document.getElementById(id); if(el) el.style.display='none'; });
                ['d-step2-body','m-step2-body'].forEach(id => { const el=document.getElementById(id); if(el) el.style.display=''; });
                ['d-step-2','m-step-2'].forEach(id => document.getElementById(id)?.classList.add('active'));
                ['d-step-1','m-step-1'].forEach(id => document.getElementById(id)?.classList.remove('active'));
                loadIngredients();
                setTimeout(() => document.getElementById('p-name')?.focus(), 80);
            },

            openAiImport() { showToast('Importación con IA — próximamente ✨'); },
        };

        // ── Category CRUD ──────────────────────────────────────────────────────────
        async function saveCategory() {
            const name = document.getElementById('cat-name-input').value.trim();
            if (!name) { document.getElementById('cat-name-error').classList.add('show'); return; }
            document.getElementById('cat-name-error').classList.remove('show');

            const url = S.editingCatId
                ? `/admin/categories/${S.editingCatId}/edit`
                : '/admin/categories/create';

            const data = await apiFetch(url, { name });
            if (data.error) { showToast(data.error, 'error'); return; }

            showToast(S.editingCatId ? 'Categoría actualizada ✓' : 'Categoría creada ✓', 'success');
            UI.closeCat();
            setTimeout(() => location.reload(), 700);
        }

        async function toggleCategory(id, btn) {
            const data = await apiFetch(`/admin/categories/${id}/toggle`);
            btn.classList.toggle('on', data.active);
            btn.title = data.active ? 'Visible · pulsa para ocultar' : 'Oculta · pulsa para mostrar';
            showToast(data.active ? 'Categoría visible' : 'Categoría oculta');
        }

        async function deleteCategory(id, name, count, btn) {
            const msg = count > 0
                ? `¿Eliminar "${name}" y sus ${count} platos? No se puede deshacer.`
                : `¿Eliminar la categoría "${name}"?`;
            if (!confirm(msg)) return;
            const data = await apiFetch(`/admin/categories/${id}/delete`);
            if (data.ok) {
                btn.closest('.cat-block').remove();
                showToast('Categoría eliminada', 'success');
                if (!document.querySelector('.cat-block')) location.reload();
            }
        }

        // ── Product CRUD ───────────────────────────────────────────────────────────
        function validateProduct() {
            let ok = true;
            [['p-name','p-name-error'],['p-desc','p-desc-error'],['p-price','p-price-error']].forEach(([fid,eid]) => {
                const val = document.getElementById(fid)?.value?.trim();
                const empty = !val || (fid === 'p-price' && parseFloat(val) <= 0);
                document.getElementById(eid)?.classList.toggle('show', empty);
                document.getElementById(fid)?.classList.toggle('error', empty);
                if (empty) ok = false;
            });
            return ok;
        }

        async function saveProduct() {
            if (!validateProduct()) { showToast('Rellena los campos obligatorios', 'error'); return; }

            const translations = {};
            const name = getVal('p-name'), desc = getVal('p-desc');
            if (name) translations[LOCALE] = { name, description: desc || null };

            const tags = [...document.querySelectorAll('.tag-pill.on')].map(t => parseInt(t.dataset.tagId));

            const payload = {
                id:          S.productId,
                categoryId:  S.categoryId,
                basePrice:   parseFloat(getVal('p-price')) || 0,
                calories:    parseInt(getVal('p-calories')) || null,
                spicyLevel:  S.spicy || null,
                active:      true,
                translations,
                tags,
                ingredients: S.ingredients,
            };

            const data = await apiFetch('/admin/products/save', payload);
            if (data.error) { showToast(data.error, 'error'); return; }
            showToast(S.productId ? 'Plato guardado ✓' : 'Plato creado ✓', 'success');
            UI.closeProduct();
            setTimeout(() => location.reload(), 700);
        }

        async function toggleProduct(id, btn) {
            const data = await apiFetch(`/admin/products/${id}/toggle`);
            btn.classList.toggle('on', data.active);
            const row = btn.closest('.product-row');
            row.classList.toggle('inactive', !data.active);
            const meta = row.querySelector('.product-meta');
            if (meta) meta.innerHTML = meta.innerHTML.replace(/Visible|Oculto/, data.active ? 'Visible' : 'Oculto');
            showToast(data.active ? 'Plato visible' : 'Plato oculto');
        }

        async function deleteProduct() {
            if (!S.productId) return;
            const name = getVal('p-name') || 'este plato';
            if (!confirm(`¿Eliminar "${name}"? No se puede deshacer.`)) return;
            const data = await apiFetch(`/admin/products/${S.productId}/delete`);
            if (data.ok) { showToast('Plato eliminado', 'success'); UI.closeProduct(); setTimeout(() => location.reload(), 700); }
        }

        // ── Category selector ──────────────────────────────────────────────────────
        document.querySelectorAll('.cat-card').forEach(c => c.addEventListener('click', () => {
            document.querySelectorAll('.cat-card').forEach(x => x.classList.remove('selected'));
            c.classList.add('selected');
            S.categoryId = parseInt(c.dataset.catId);
            document.getElementById('cat-select-error').style.display = 'none';
        }));

        // ── Spicy ──────────────────────────────────────────────────────────────────
        function setSpicy(level) {
            S.spicy = S.spicy === level ? 0 : level;
            updateSpicyUI();
        }
        function updateSpicyUI() {
            document.querySelectorAll('.spicy-pip').forEach(p =>
                p.classList.toggle('on', parseInt(p.dataset.level) <= S.spicy)
            );
            document.querySelectorAll('.spicy-text').forEach(el =>
                el.textContent = SPICY_LABELS[S.spicy]
            );
        }

        // ── Ingredients ────────────────────────────────────────────────────────────
        async function loadIngredients() {
            if (S.allIngredients.length) return;
            try { S.allIngredients = await apiFetch('/admin/ingredients/list', null, 'GET'); } catch(e) {}
        }

        function searchIngredients(query) {
            const box = document.getElementById('ing-suggestions');
            if (!query.trim()) { box.classList.remove('open'); return; }
            const lower    = query.toLowerCase();
            const existing = S.ingredients.map(i => i.name.toLowerCase());
            const matches  = S.allIngredients.filter(i =>
                i.name.toLowerCase().includes(lower) && !existing.includes(i.name.toLowerCase())
            ).slice(0, 6);
            const exact     = S.allIngredients.some(i => i.name.toLowerCase() === lower);
            const alreadyIn = existing.includes(lower);

            let html = matches.map(i =>
                `<div class="ing-option" onclick="addIng(${i.id},'${i.name.replace(/'/g,"\\'")}')">
            <i class="ti ti-leaf" style="font-size:14px;color:#555" aria-hidden="true"></i> ${i.name}
        </div>`
            ).join('');
            if (!exact && !alreadyIn) html +=
                `<div class="ing-option" onclick="addIng(null,'${query.trim().replace(/'/g,"\\'")}')">
            <i class="ti ti-plus" style="font-size:14px;color:#555" aria-hidden="true"></i>
            <strong>${query.trim()}</strong> <span class="new-label">· Crear nuevo</span>
        </div>`;

            box.innerHTML = html;
            box.classList.toggle('open', !!html);
        }

        function ingKeydown(e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                const q = e.target.value.trim();
                if (!q) return;
                const exact = S.allIngredients.find(i => i.name.toLowerCase() === q.toLowerCase());
                addIng(exact?.id ?? null, exact?.name ?? q);
            }
            if (e.key === 'Escape') document.getElementById('ing-suggestions').classList.remove('open');
        }

        function addIng(id, name) {
            if (S.ingredients.some(i => i.name.toLowerCase() === name.toLowerCase())) return;
            S.ingredients.push({ id, name });
            renderIngTags();
            document.getElementById('ing-input').value = '';
            document.getElementById('ing-suggestions').classList.remove('open');
        }

        function removeIng(name) {
            S.ingredients = S.ingredients.filter(i => i.name !== name);
            renderIngTags();
        }

        function renderIngTags() {
            document.getElementById('ing-tags').innerHTML = S.ingredients.map(i =>
                `<div class="ing-tag">${i.name}
            <button onclick="removeIng('${i.name.replace(/'/g,"\\'")}')
" aria-label="Quitar ${i.name}">
                <i class="ti ti-x" aria-hidden="true"></i>
            </button>
        </div>`
            ).join('');
        }

        // ── Image preview ──────────────────────────────────────────────────────────
        function previewImage(input) {
            if (!input.files?.length) return;
            const area = document.getElementById('img-upload-area');
            const url  = URL.createObjectURL(input.files[0]);
            let img    = area.querySelector('img');
            if (!img) { img = document.createElement('img'); area.appendChild(img); }
            img.src = url;
            area.querySelector('.img-upload-hint').style.display = 'none';
        }

        // ── Reset ──────────────────────────────────────────────────────────────────
        function resetProduct() {
            ['p-name','p-desc','p-price','p-calories','ing-input'].forEach(id => {
                const el = document.getElementById(id);
                if (el) { el.value=''; el.classList.remove('error'); }
            });
            ['p-name-error','p-desc-error','p-price-error'].forEach(id =>
                document.getElementById(id)?.classList.remove('show')
            );
            document.querySelectorAll('.tag-pill').forEach(p => p.classList.remove('on'));
            document.querySelectorAll('.cat-card').forEach(c => c.classList.remove('selected'));
            document.getElementById('ing-tags').innerHTML = '';
            document.getElementById('ing-suggestions')?.classList.remove('open');
            document.getElementById('cat-select-error').style.display = 'none';
            const area = document.getElementById('img-upload-area');
            if (area) { area.querySelector('img')?.remove(); area.querySelector('.img-upload-hint').style.display=''; }
            S.productId=null; S.categoryId=null; S.spicy=0; S.ingredients=[];
            // Reset steps visibility
            ['product-modal-steps','product-sheet-steps'].forEach(id => {
                const el=document.getElementById(id); if(el) el.style.display='';
            });
            ['d-back-btn','m-back-btn'].forEach(id => {
                const el=document.getElementById(id); if(el) el.style.display='';
            });
            updateSpicyUI();
        }

        // ── Utils ──────────────────────────────────────────────────────────────────
        const getVal = id => document.getElementById(id)?.value?.trim() ?? '';
        const setVal = (id, v) => { const el=document.getElementById(id); if(el) el.value=v??''; };

        async function apiFetch(url, body=null, method=null) {
            const m = method ?? (body !== null ? 'POST' : 'GET');
            const opts = { method: m, headers: body ? {'Content-Type':'application/json'} : {} };
            if (body) opts.body = JSON.stringify(body);
            const res = await fetch(url, opts);
            return res.json();
        }

        // Close suggestions on outside click
        document.addEventListener('click', e => {
            if (!e.target.closest('.ing-wrap')) {
                document.getElementById('ing-suggestions')?.classList.remove('open');
            }
        });
    </script>
{% endblock %}
