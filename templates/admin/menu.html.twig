{#/home/david/gitProjects/qr-menu/templates/admin/menu.html.twig#}
{% extends 'admin/base.html.twig' %}

{% block title %}{{ 'title'|trans({}, 'admin_menu') }}{% endblock %}
{% block page_title %}{{ 'title'|trans({}, 'admin_menu') }}{% endblock %}

{% block header_actions %}
    <button class="btn btn-ai" onclick="UI.openAiImport()">
        <i class="ti ti-sparkles" aria-hidden="true"></i>
        <span class="hide-mobile">{{ 'action.import_ai'|trans({}, 'admin_menu') }}</span>
    </button>
    <button class="btn" onclick="UI.openNewCategory()">
        <i class="ti ti-folder-plus" aria-hidden="true"></i>
        <span class="hide-mobile">{{ 'modal.category.new_title'|trans({}, 'admin_menu') }}</span>
    </button>
    <button class="btn btn-primary" onclick="UI.openNewProduct(null)">
        <i class="ti ti-plus" aria-hidden="true"></i>
        {{ 'modal.product.new_title'|trans({}, 'admin_menu') }}
    </button>
{% endblock %}

{% block stylesheets %}
    <style>
        /* ── Hide labels on mobile ── */
        @media (max-width: 767px) { .hide-mobile { display: none; } }

        /* ══════════════════════════════
           CARTA
        ══════════════════════════════ */
        .menu-wrap { max-width: 860px; }

        .empty-state  { text-align:center; padding:80px 24px; }
        .empty-icon   { font-size:52px; display:block; margin-bottom:16px; opacity:0.2; }
        .empty-title  { font-size:20px; font-weight:600; color:var(--tx-hi); margin-bottom:8px; letter-spacing:-0.3px; }
        .empty-sub    { font-size:14px; color:var(--tx-6); line-height:1.6; margin-bottom:28px; max-width:340px; margin-left:auto; margin-right:auto; }
        .empty-btns   { display:flex; gap:10px; justify-content:center; flex-wrap:wrap; }

        .cat-block    { border:1px solid var(--bd-1); border-radius:12px; margin-bottom:10px; overflow:hidden; }
        .cat-header   { display:flex; align-items:center; gap:8px; padding:11px 14px; background:var(--bg-card); border-bottom:1px solid var(--bd-1); }
        .cat-drag     { color:var(--tx-8); cursor:grab; font-size:16px; flex-shrink:0; }
        .cat-drag:active { cursor:grabbing; }
        .cat-name-text { font-size:14px; font-weight:500; color:var(--tx-1); flex:1; }
        .cat-count    { font-size:11px; color:var(--tx-6); }
        .cat-actions  { display:flex; gap:4px; }

        .toggle {
            width:32px; height:18px; border-radius:9px; background:var(--bg-tgl);
            position:relative; cursor:pointer; transition:background 0.15s;
            border:none; padding:0; flex-shrink:0;
        }
        .toggle::after {
            content:''; position:absolute; width:12px; height:12px;
            border-radius:50%; background:var(--tx-6); top:3px; left:3px;
            transition:left 0.15s, background 0.15s;
        }
        .toggle.on { background:rgba(193,68,14,0.25); }
        .toggle.on::after { left:17px; background:#C1440E; }

        .icon-btn {
            width:28px; height:28px; border-radius:6px; border:1px solid var(--bd-3);
            background:var(--bg-input); display:flex; align-items:center; justify-content:center;
            cursor:pointer; color:var(--tx-6); font-size:13px;
            transition:color 0.1s, border-color 0.1s;
        }
        .icon-btn:hover        { color:var(--tx-1); border-color:var(--bd-2); }
        .icon-btn.danger:hover { color:#F0997B; border-color:rgba(240,153,123,0.3); }

        @media (max-width: 767px) {
            .icon-btn { width:36px; height:36px; font-size:16px; }
            .toggle   { width:38px; height:22px; }
            .toggle::after { width:14px; height:14px; top:4px; left:4px; }
            .toggle.on::after { left:20px; }
        }

        .products-list { padding:4px; }
        .product-row {
            display:flex; align-items:center; gap:8px; padding:9px 8px;
            border-radius:8px; border:1px solid transparent; cursor:pointer;
            transition:background 0.1s, border-color 0.1s; min-height:52px;
        }
        .product-row:hover { background:var(--bg-hover); border-color:var(--bd-1); }
        .product-drag { color:var(--tx-8); cursor:grab; font-size:14px; flex-shrink:0; }
        .product-drag:active { cursor:grabbing; }
        .product-thumb {
            width:38px; height:38px; border-radius:8px; background:var(--bd-1);
            border:1px solid var(--bd-3); display:flex; align-items:center;
            justify-content:center; font-size:18px; flex-shrink:0; overflow:hidden;
        }
        .product-thumb img { width:100%; height:100%; object-fit:cover; }
        .product-info { flex:1; min-width:0; }
        .product-name { font-size:13px; font-weight:500; color:var(--tx-1); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
        .product-meta { font-size:11px; color:var(--tx-6); margin-top:2px; }
        .product-price { font-size:13px; font-weight:500; color:var(--tx-4); flex-shrink:0; min-width:58px; text-align:right; }
        .product-row.inactive { opacity:0.4; }

        @media (max-width: 767px) {
            .product-row  { min-height:64px; padding:10px 8px; }
            .product-thumb { width:44px; height:44px; font-size:20px; }
            .product-name { font-size:14px; }
            .product-meta { font-size:12px; }
            .product-price { font-size:14px; }
        }

        .add-row { padding:4px 6px 8px; }
        .add-product-btn {
            width:100%; padding:8px; border:1px dashed var(--bg-deep); border-radius:8px;
            background:none; color:var(--tx-8); font-size:12px; cursor:pointer;
            display:flex; align-items:center; justify-content:center; gap:5px;
            min-height:40px; transition:border-color 0.1s, color 0.1s;
        }
        .add-product-btn:hover { border-color:var(--bd-2); color:var(--tx-4); }

        @media (max-width: 767px) {
            .add-product-btn { min-height:48px; font-size:13px; }
        }

        /* ══════════════════════════════
           DESKTOP MODAL
        ══════════════════════════════ */
        .modal-overlay {
            position:fixed; inset:0; background:var(--overlay);
            z-index:500; display:flex; align-items:center; justify-content:center;
            padding:20px; opacity:0; pointer-events:none; transition:opacity 0.2s;
        }
        .modal-overlay.open { opacity:1; pointer-events:all; }
        .modal {
            background:var(--bg-card); border:1px solid var(--bd-3); border-radius:16px;
            width:100%; max-height:90vh; display:flex; flex-direction:column;
            transform:translateY(8px) scale(0.98); transition:transform 0.2s;
        }
        .modal-overlay.open .modal { transform:translateY(0) scale(1); }
        .modal-sm { max-width:380px; }
        .modal-md { max-width:560px; }

        /* ══════════════════════════════
           MOBILE BOTTOM SHEET
        ══════════════════════════════ */
        .sheet-overlay {
            position:fixed; inset:0; background:var(--overlay);
            z-index:500; display:flex; align-items:flex-end;
            opacity:0; pointer-events:none; transition:opacity 0.25s;
        }
        .sheet-overlay.open { opacity:1; pointer-events:all; }
        .sheet {
            width:100%; background:var(--bg-card); border-radius:20px 20px 0 0;
            border-top:1px solid var(--bd-3); max-height:92vh;
            display:flex; flex-direction:column;
            transform:translateY(100%); transition:transform 0.3s cubic-bezier(0.32,0.72,0,1);
        }
        .sheet-overlay.open .sheet { transform:translateY(0); }
        .sheet-handle {
            width:36px; height:4px; border-radius:2px; background:var(--bd-2);
            margin:10px auto 0; flex-shrink:0;
        }

        /* Shared modal/sheet parts */
        .panel-header {
            padding:14px 16px 12px; border-bottom:1px solid var(--bd-1);
            display:flex; align-items:center; justify-content:space-between; flex-shrink:0;
        }
        .panel-title { font-size:16px; font-weight:600; color:var(--tx-hi); letter-spacing:-0.3px; }
        .panel-close {
            width:30px; height:30px; border-radius:50%; border:1px solid var(--bd-2);
            background:var(--bg-input); display:flex; align-items:center; justify-content:center;
            cursor:pointer; color:var(--tx-5); font-size:13px;
        }
        .panel-close:hover { color:var(--tx-1); }
        .panel-body {
            flex:1; min-height:0; overflow-y:auto; padding:18px; display:flex; flex-direction:column;
            gap:15px; scrollbar-width:thin; scrollbar-color:var(--bg-tgl) transparent;
        }
        .panel-footer {
            padding:12px 18px; border-top:1px solid var(--bd-1);
            display:flex; gap:8px; justify-content:flex-end; flex-shrink:0;
            padding-bottom:calc(12px + env(safe-area-inset-bottom));
        }

        @media (max-width: 767px) {
            .panel-title { font-size:17px; }
            .panel-body  { padding:16px; gap:16px; }
            .panel-footer { justify-content:stretch; }
            .panel-footer .btn { flex:1; justify-content:center; min-height:48px; font-size:15px; }
            .panel-footer .btn-danger { flex:0; min-width:48px; padding:0; }
        }

        /* Step body wrappers — must be flex containers so the constrained height from
           .sheet/.modal (max-height: 92/90vh) reaches .panel-body and enables scroll */
        #d-step1-body, #d-step2-body,
        #m-step1-body, #m-step2-body {
            display: flex;
            flex-direction: column;
            flex: 1;
            min-height: 0;
        }

        /* Steps */
        .steps { display:flex; align-items:center; gap:8px; margin-top:4px; }
        .step  { display:flex; align-items:center; gap:5px; font-size:12px; color:var(--tx-7); }
        .step.active { color:var(--tx-1); }
        .step-num {
            width:20px; height:20px; border-radius:50%; border:1px solid var(--bd-2);
            background:var(--bg-input); display:flex; align-items:center; justify-content:center;
            font-size:10px; font-weight:600; color:var(--tx-6);
        }
        .step.active .step-num { background:#C1440E; border-color:#C1440E; color:#fff; }
        .step-sep { color:var(--bd-2); }

        /* Cat select */
        .cat-select-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(130px,1fr)); gap:8px; }
        .cat-select-card {
            padding:12px; border-radius:10px; border:1px solid var(--bd-2);
            background:var(--bg-input); cursor:pointer; transition:all 0.1s; text-align:left;
        }
        .cat-select-card:hover     { border-color:var(--bd-1); background:var(--bg-deep); }
        .cat-select-card.selected  { border-color:#C1440E; background:rgba(193,68,14,0.1); }
        .cat-select-card-name  { font-size:13px; font-weight:500; color:var(--tx-1); }
        .cat-select-card-count { font-size:11px; color:var(--tx-6); margin-top:2px; }
        .cat-select-new {
            padding:12px; border-radius:10px; border:1px dashed var(--bd-2);
            background:none; cursor:pointer; color:var(--tx-6); font-size:13px;
            display:flex; align-items:center; gap:6px;
            transition:border-color 0.1s, color 0.1s;
        }
        .cat-select-new:hover { border-color:var(--tx-6); color:var(--tx-3); }

        @media (max-width: 767px) {
            .cat-select-grid { grid-template-columns:repeat(2,1fr); gap:10px; }
            .cat-select-card { padding:14px 12px; }
            .cat-select-card-name { font-size:14px; }
            .cat-select-new { padding:14px 12px; font-size:14px; }
        }

        /* Form fields */
        .field { display:flex; flex-direction:column; gap:5px; }
        .field-label {
            font-size:11px; font-weight:600; color:var(--tx-5);
            text-transform:uppercase; letter-spacing:0.07em;
            display:flex; align-items:center; gap:5px;
        }
        .req { color:#C1440E; }
        .opt { color:var(--tx-8); font-weight:400; text-transform:none; letter-spacing:0; font-size:10px; }
        .field input, .field textarea, .field select {
            background:var(--bg-input); border:1px solid var(--bd-2); color:var(--tx-1);
            font-size:14px; padding:10px 12px; border-radius:9px;
            outline:none; width:100%; font-family:inherit;
            transition:border-color 0.15s; min-height:42px;
        }
        .field input::placeholder, .field textarea::placeholder { color:var(--tx-7); }
        .field input:focus, .field textarea:focus, .field select:focus { border-color:var(--tx-5); }
        .field input.error { border-color:rgba(240,100,80,0.6); }
        .field-error { font-size:11px; color:#F0997B; margin-top:2px; display:none; }
        .field-error.show { display:block; }
        .field textarea { resize:none; height:76px; line-height:1.55; }
        .field-row { display:flex; gap:10px; }
        .field-row .field { flex:1; }

        @media (max-width: 767px) {
            .field input, .field textarea, .field select { font-size:16px; min-height:48px; }
        }

        /* Image upload */
        .img-upload {
            width:100%; height:76px; border:1px dashed var(--bd-2); border-radius:9px;
            display:flex; align-items:center; justify-content:center; gap:8px;
            font-size:13px; color:var(--tx-6); cursor:pointer; background:var(--bg-card);
            transition:border-color 0.15s, color 0.15s; position:relative; overflow:hidden;
        }
        .img-upload:hover { border-color:var(--tx-6); color:var(--tx-3); }
        .img-upload img  { position:absolute; inset:0; width:100%; height:100%; object-fit:cover; border-radius:8px; }
        .img-upload-hint { position:relative; z-index:1; display:flex; align-items:center; gap:6px; }

        /* Spicy */
        .chili {
            display: inline-block; line-height: 1;
            /* Convert emoji silhouette to solid red */
            filter: brightness(0) invert(30%) sepia(100%) saturate(800%) hue-rotate(320deg) brightness(1.1);
        }
        .spicy-row { display:flex; gap:6px; align-items:center; flex-wrap:wrap; }
        .spicy-pip {
            width:32px; height:32px; border-radius:7px; border:1px solid transparent;
            background:transparent; display:flex; align-items:center; justify-content:center;
            cursor:pointer; font-size:17px; transition:all 0.1s; user-select:none;
            opacity: 0.3;
        }
        .spicy-pip.on   { opacity:1; background:rgba(220,38,38,0.08); border-color:rgba(220,38,38,0.22); }
        .spicy-pip:hover { opacity:0.65; }
        .spicy-text { font-size:12px; color:var(--tx-6); }

        @media (max-width: 767px) {
            .spicy-pip { width:38px; height:38px; font-size:20px; }
        }

        /* Tags */
        .tag-pills { display:flex; flex-wrap:wrap; gap:6px; }
        .tag-pill  {
            font-size:12px; padding:5px 11px; border-radius:20px; border:1px solid var(--bd-2);
            background:var(--bg-input); color:var(--tx-5); cursor:pointer; transition:all 0.1s; user-select:none;
            min-height:32px; display:flex; align-items:center;
        }
        .tag-pill.on { background:rgba(99,153,34,0.15); color:#7aad40; border-color:rgba(99,153,34,0.35); }
        .tag-pill:hover:not(.on) { border-color:var(--bd-2); color:var(--tx-3); }

        @media (max-width: 767px) {
            .tag-pill { font-size:13px; min-height:38px; padding:6px 14px; }
        }

        /* Ingredients — Tom Select (base structure from tom-select.default.min.css, reskinned here) */
        .ts-wrapper.multi .ts-control {
            background:var(--bg-input); border:1px solid var(--bd-2); border-radius:10px;
            padding:6px 8px; gap:5px;
        }
        .ts-wrapper.multi.focus .ts-control { border-color:var(--tx-6); box-shadow:none; }
        .ts-control input { color:var(--tx-2); font-size:13px; }
        .ts-control input::placeholder { color:var(--tx-6); }
        .ts-wrapper.multi .ts-control > .item {
            display:flex; align-items:center; gap:5px; font-size:12px;
            padding:4px 10px; border-radius:20px; background:var(--bg-deep);
            border:1px solid var(--bd-2); color:var(--tx-3);
        }
        .ts-wrapper.multi .ts-control > .item.active { background:var(--bg-hover); border-color:var(--bd-2); }
        .plugin-remove_button .item .remove {
            border-left:none; color:var(--tx-6); padding:0 0 0 2px; font-size:13px;
        }
        .plugin-remove_button .item .remove:hover { background:none; color:#F0997B; }
        .ts-dropdown {
            background:var(--bg-deep); border:1px solid var(--bd-2); border-radius:9px;
            margin-top:4px; overflow:hidden; box-shadow:none;
        }
        .ts-dropdown .option, .ts-dropdown .create {
            padding:10px 13px; font-size:13px; color:var(--tx-2);
        }
        .ts-dropdown .option.active { background:var(--bg-hover); color:var(--tx-2); }
        .ts-dropdown .create { color:var(--tx-5); cursor:pointer; }
        .ts-dropdown .create strong { color:var(--tx-2); font-weight:600; }
        .ts-dropdown .no-results { padding:10px 13px; font-size:13px; color:var(--tx-6); }

        @media (max-width: 767px) {
            .ts-dropdown .option, .ts-dropdown .create { padding:13px; font-size:14px; }
            .ts-wrapper.multi .ts-control > .item { font-size:13px; padding:5px 12px; }
        }

        /* En móvil NUNCA se muestran los modales de desktop */
        @media (max-width: 767px) {
            .modal-overlay { display:none !important; }
        }

        /* En desktop NUNCA se muestran los bottom sheets */
        @media (min-width: 768px) {
            .sheet-overlay { display:none !important; }
        }
    </style>
{% endblock %}

{% block body %}
    <div class="menu-wrap">

        {% if categories|length == 0 %}
            <div class="empty-state">
                <span class="empty-icon">🍽️</span>
                <div class="empty-title">{{ 'empty.title'|trans({}, 'admin_menu') }}</div>
                <div class="empty-sub">
                    {{ 'empty.subtitle'|trans({}, 'admin_menu') }}
                </div>
                <div class="empty-btns">
                    <button class="btn btn-ai" onclick="UI.openAiImport()">
                        <i class="ti ti-sparkles" aria-hidden="true"></i> {{ 'empty.import_ai'|trans({}, 'admin_menu') }}
                    </button>
                    <button class="btn btn-primary" onclick="UI.openNewCategory()">
                        <i class="ti ti-folder-plus" aria-hidden="true"></i> {{ 'empty.create_first_category'|trans({}, 'admin_menu') }}
                    </button>
                </div>
            </div>

        {% else %}

            <div id="cats-list">
                {% for category in categories %}
                    {% set catT = category.getTranslation(locale) %}
                    {% set catName = catT ? catT.name : 'common.unnamed'|trans({}, 'admin_menu') %}

                    <div class="cat-block" data-id="{{ category.id }}">
                        <div class="cat-header">
                            <i class="ti ti-grip-vertical cat-drag" aria-hidden="true"></i>
                            <span class="cat-name-text">{{ catName }}</span>
                            <span class="cat-count">{{ category.products|length }}</span>
                            <div class="cat-actions">
                                <button class="toggle {{ category.isActive ? 'on' : '' }}"
                                        onclick="toggleCategory({{ category.id }}, this)"
                                        title="{{ category.isActive ? 'category.toggle_hide_title'|trans({}, 'admin_menu') : 'category.toggle_show_title'|trans({}, 'admin_menu') }}"
                                        aria-label="{{ 'category.toggle_aria'|trans({}, 'admin_menu') }}"></button>
                                <button class="icon-btn"
                                        onclick="UI.openEditCategory({{ category.id }}, '{{ catName|e('js') }}')"
                                        title="{{ 'category.edit_title'|trans({}, 'admin_menu') }}">
                                    <i class="ti ti-edit" aria-hidden="true"></i>
                                </button>
                                <button class="icon-btn danger"
                                        onclick="deleteCategory({{ category.id }}, '{{ catName|e('js') }}', {{ category.products|length }}, this)"
                                        title="{{ 'category.delete_title'|trans({}, 'admin_menu') }}">
                                    <i class="ti ti-trash" aria-hidden="true"></i>
                                </button>
                            </div>
                        </div>

                        <div class="products-list" id="prods-{{ category.id }}">
                            {% for product in category.products %}
                                {% set pT = product.getTranslation(locale) %}
                                {% set pName = pT ? pT.name : 'common.unnamed'|trans({}, 'admin_menu') %}
                                <div class="product-row {{ not product.isActive ? 'inactive' : '' }}"
                                     data-id="{{ product.id }}"
                                     onclick="UI.openEditProduct({{ product.id }})">
                                    <i class="ti ti-grip-vertical product-drag" aria-hidden="true"></i>
                                    <div class="product-thumb">
                                        {% if product.image %}
                                            <img src="{{ asset('uploads/products/' ~ product.image) }}" alt="{{ pName }}">
                                        {% else %}🍽️{% endif %}
                                    </div>
                                    <div class="product-info">
                                        <div class="product-name">{{ pName }}</div>
                                        <div class="product-meta">
                                            {% if product.spicyLevel > 0 %}<span class="chili" style="font-size:12px">🌶</span> · {% endif %}
                                            {% if product.calories %}{{ product.calories }} kcal · {% endif %}
                                            <span class="product-status">{{ product.isActive ? 'product.visible'|trans({}, 'admin_menu') : 'product.hidden'|trans({}, 'admin_menu') }}</span>
                                        </div>
                                    </div>
                                    <div class="product-price">
                                        {{ (product.basePrice / 100)|number_format(2) }} {{ restaurant.currency }}
                                    </div>
                                    <button class="toggle {{ product.isActive ? 'on' : '' }}"
                                            onclick="event.stopPropagation(); toggleProduct({{ product.id }}, this)"
                                            title="{{ product.isActive ? 'product.visible'|trans({}, 'admin_menu') : 'product.hidden'|trans({}, 'admin_menu') }}"
                                            aria-label="{{ 'product.toggle_aria'|trans({}, 'admin_menu') }}"></button>
                                </div>
                            {% endfor %}
                        </div>

                        <div class="add-row">
                            <button class="add-product-btn" onclick="UI.openNewProduct({{ category.id }})">
                                <i class="ti ti-plus" aria-hidden="true"></i>
                                {{ 'product.add_to_category'|trans({'%category%': catName}, 'admin_menu') }}
                            </button>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}

    </div>

    {# ════════════════════════════
   DESKTOP: modal categoría
════════════════════════════ #}
    <div class="modal-overlay" id="desktop-cat-modal"
         onclick="if(event.target===this)UI.closeCat()">
        <div class="modal modal-sm">
            <div class="panel-header">
                <div class="panel-title" id="cat-modal-title">{{ 'modal.category.new_title'|trans({}, 'admin_menu') }}</div>
                <button class="panel-close" onclick="UI.closeCat()" aria-label="{{ 'modal.close_aria'|trans({}, 'admin_menu') }}">
                    <i class="ti ti-x" aria-hidden="true"></i>
                </button>
            </div>
            <div class="panel-body">
                {% include 'admin/_cat_fields.html.twig' %}
            </div>
            <div class="panel-footer">
