{% extends 'admin/base.html.twig' %}

{% block title %}{{ 'title'|trans({}, 'admin_menu_import') }}{% endblock %}
{% block page_title %}{{ 'title'|trans({}, 'admin_menu_import') }}{% endblock %}

{% block header_actions %}
    <a href="{{ path('admin_menu') }}" class="btn">
        <i class="ti ti-arrow-left" aria-hidden="true"></i>
        <span class="hide-mobile">{{ 'action.back_to_menu'|trans({}, 'admin_menu_import') }}</span>
    </a>
{% endblock %}

{% block stylesheets %}
    <style>
        .import-card {
            max-width: 560px; margin: 0 auto; background: var(--bg-card); border: 1px solid var(--bd-1);
            border-radius: 14px; padding: 28px;
        }
        .import-intro { font-size: 14px; color: var(--tx-5); line-height: 1.6; margin-bottom: 22px; }
        .import-drop {
            border: 1.5px dashed var(--bd-2); border-radius: 12px; padding: 36px 20px; text-align: center;
            cursor: pointer; transition: border-color 0.15s, background 0.15s; background: var(--bg-input);
        }
        .import-drop:hover, .import-drop.drag-over { border-color: var(--brand); background: var(--bg-hover); }
        .import-drop-icon { font-size: 28px; margin-bottom: 8px; }
        .import-drop-text { font-size: 14px; color: var(--tx-3); font-weight: 600; margin-bottom: 4px; }
        .import-drop-hint { font-size: 12px; color: var(--tx-7); }
        .import-file-list { display: flex; flex-direction: column; gap: 6px; margin-top: 16px; }
        .import-file-row {
            display: flex; align-items: center; gap: 10px; padding: 7px 12px 7px 7px; background: var(--bg-input);
            border: 1px solid var(--bd-1); border-radius: 9px; font-size: 13px; color: var(--tx-3);
        }
        .import-file-thumb {
            width: 34px; height: 34px; border-radius: 7px; object-fit: cover; flex-shrink: 0;
            border: 1px solid var(--bd-1); background: var(--bg-deep);
        }
        .import-file-name { flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
        .import-submit-row { margin-top: 20px; display: flex; justify-content: flex-end; }
        .import-submit-row .btn { opacity: 0.5; pointer-events: none; }
        .import-submit-row .btn.ready { opacity: 1; pointer-events: auto; }

        /* ── Uploading state — one motion source: the bar itself. ── */
        .upload-progress { text-align: center; padding: 8px 4px 4px; }
        .up-icon {
            width: 52px; height: 52px; border-radius: 50%; margin: 0 auto 16px; flex-shrink: 0;
            display: flex; align-items: center; justify-content: center; color: #fff;
            background: radial-gradient(circle at 34% 30%, color-mix(in srgb, var(--brand) 55%, white 10%), var(--brand) 60%, color-mix(in srgb, var(--brand) 80%, black 25%));
            box-shadow: 0 6px 22px -6px color-mix(in srgb, var(--brand) 70%, transparent);
        }
        .up-icon svg { width: 22px; height: 22px; }
        .up-title { font-size: 15px; font-weight: 600; color: var(--tx-hi); margin-bottom: 16px; }
        .up-track { height: 7px; border-radius: 5px; background: var(--bg-deep); overflow: hidden; }
        .up-fill {
            height: 100%; width: 0%; border-radius: 5px;
            background: linear-gradient(90deg, color-mix(in srgb, var(--brand) 80%, black), var(--brand));
            transition: width .15s linear;
        }
        .up-pct { font-size: 12px; color: var(--tx-4); margin-top: 8px; font-variant-numeric: tabular-nums; }
        .up-error { margin-top: 18px; }
        .up-error p { font-size: 13px; color: var(--bad); margin-bottom: 12px; }

        @media (prefers-reduced-motion: reduce) { .up-fill { transition: none; } }
    </style>
{% endblock %}

{% block body %}
    <div class="import-card" id="import-card">
        <p class="import-intro">{{ 'upload.intro'|trans({}, 'admin_menu_import') }}</p>

        <form method="post" action="{{ path('admin_menu_import_upload') }}" enctype="multipart/form-data" id="import-form">
            <div id="import-picker">
                <label class="import-drop" id="import-drop" for="import-file-input">
                    <div class="import-drop-icon">📷</div>
                    <div class="import-drop-text">{{ 'upload.drop_text'|trans({}, 'admin_menu_import') }}</div>
                    <div class="import-drop-hint">{{ 'upload.drop_hint'|trans({}, 'admin_menu_import') }}</div>
                </label>
                <input type="file" id="import-file-input" name="images[]" multiple accept="image/jpeg,image/png,image/webp" style="display:none">

                <div class="import-file-list" id="import-file-list"></div>

                <div class="import-submit-row">
                    <button type="submit" class="btn btn-primary" id="import-submit-btn">
                        <i class="ti ti-sparkles" aria-hidden="true"></i>
                        {{ 'upload.submit'|trans({}, 'admin_menu_import') }}
                    </button>
                </div>
            </div>

            <div class="upload-progress" id="upload-progress" hidden>
                <div class="up-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v12"/><path d="M7 8l5-5 5 5"/><path d="M4 17v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2"/></svg>
                </div>
                <div class="up-title" id="up-title">{{ 'upload.uploading'|trans({}, 'admin_menu_import') }}</div>
                <div class="up-track"><div class="up-fill" id="up-fill"></div></div>
                <div class="up-pct" id="up-pct">0%</div>
                <div class="up-error" id="up-error" hidden>
                    <p id="up-error-text">{{ 'upload.upload_failed'|trans({}, 'admin_menu_import') }}</p>
                    <button type="button" class="btn btn-primary" id="up-retry-btn">{{ 'upload.retry'|trans({}, 'admin_menu_import') }}</button>
                </div>
            </div>
        </form>
    </div>

    <script>
        (function () {
            const form = document.getElementById('import-form');
            const input = document.getElementById('import-file-input');
            const drop = document.getElementById('import-drop');
            const list = document.getElementById('import-file-list');
            const submitBtn = document.getElementById('import-submit-btn');
            const picker = document.getElementById('import-picker');
            const progress = document.getElementById('upload-progress');
            const fill = document.getElementById('up-fill');
            const pct = document.getElementById('up-pct');
            const title = document.getElementById('up-title');
            const track = document.querySelector('.up-track');
            const errorBox = document.getElementById('up-error');
            const retryBtn = document.getElementById('up-retry-btn');
            const UPLOADING_TEXT = {{ 'upload.uploading'|trans({}, 'admin_menu_import')|json_encode|raw }};

            let objectUrls = [];
            function render() {
                objectUrls.forEach(url => URL.revokeObjectURL(url));
                objectUrls = [];
                list.innerHTML = '';
                const files = input.files || [];
                Array.from(files).forEach(file => {
                    const url = URL.createObjectURL(file);
                    objectUrls.push(url);
                    const row = document.createElement('div');
                    row.className = 'import-file-row';
                    row.innerHTML = '<img class="import-file-thumb" alt=""><span class="import-file-name"></span>';
                    row.querySelector('.import-file-thumb').src = url;
                    row.querySelector('.import-file-name').textContent = file.name;
                    list.appendChild(row);
                });
                submitBtn.classList.toggle('ready', files.length > 0);
            }

            input.addEventListener('change', render);

            ['dragover', 'dragenter'].forEach(evt => drop.addEventListener(evt, e => {
                e.preventDefault();
                drop.classList.add('drag-over');
            }));
            ['dragleave', 'drop'].forEach(evt => drop.addEventListener(evt, e => {
                e.preventDefault();
                drop.classList.remove('drag-over');
            }));
            drop.addEventListener('drop', e => {
                if (e.dataTransfer.files.length) {
                    input.files = e.dataTransfer.files;
                    render();
                }
            });

            function startUpload() {
                if (!input.files || !input.files.length) return;

                errorBox.hidden = true;
                track.style.display = '';
                pct.style.display = '';
                title.textContent = UPLOADING_TEXT;
                fill.style.width = '0%';
                pct.textContent = '0%';
                picker.hidden = true;
                progress.hidden = false;

                const formData = new FormData(form);
                const xhr = new XMLHttpRequest();
                xhr.open('POST', form.action, true);

                xhr.upload.addEventListener('progress', function (ev) {
                    if (!ev.lengthComputable) return;
                    const p = Math.round((ev.loaded / ev.total) * 100);
                    fill.style.width = p + '%';
                    pct.textContent = p + '%';
                });

                xhr.addEventListener('load', function () {
                    if (xhr.status >= 200 && xhr.status < 400 && xhr.responseURL) {
                        // Covers both success (redirects to the status page) and a
                        // server-side validation failure (redirects back to this same
                        // page with a flash message) — the existing flash-rendering
                        // in base.html.twig handles the second case correctly either way.
                        window.location.href = xhr.responseURL;
                    } else {
                        showError();
                    }
                });
                xhr.addEventListener('error', showError);

                xhr.send(formData);
            }

            function showError() {
                track.style.display = 'none';
                pct.style.display = 'none';
                errorBox.hidden = false;
            }

            retryBtn.addEventListener('click', function () {
                progress.hidden = true;
                picker.hidden = false;
            });

            form.addEventListener('submit', function (e) {
                e.preventDefault();
                startUpload();
            });
        })();
    </script>
{% endblock %}
