{#/home/david/gitProjects/qr-menu/templates/admin/categories.html.twig#}
{% extends 'admin/base.html.twig' %}

{% block title %}{{ 'title'|trans({}, 'admin_categories') }}{% endblock %}
{% block page_title %}{{ 'title'|trans({}, 'admin_categories') }}{% endblock %}

{% block header_actions %}
    <button class="btn btn-primary" onclick="UI.openNew()">
        <i class="ti ti-plus" aria-hidden="true"></i> {{ 'action.new_category'|trans({}, 'admin_categories') }}
    </button>
{% endblock %}

{% block stylesheets %}
    <style>
        .cats-wrap { max-width: 860px; }

        .empty-state { text-align:center; padding:80px 24px; }
        .empty-icon  { font-size:48px; display:block; margin-bottom:16px; opacity:0.2; }
        .empty-title { font-size:20px; font-weight:600; color:var(--tx-hi); margin-bottom:8px; }
        .empty-sub   { font-size:14px; color:var(--tx-6); line-height:1.6; margin-bottom:28px; max-width:340px; margin:0 auto 28px; }

        /* Category card */
        .cat-card {
            background: var(--bg-card); border: 1px solid var(--bd-1);
            border-radius: 12px; margin-bottom: 10px; overflow: hidden;
        }
        .cat-card-header {
            display: flex; align-items: center; gap: 10px;
            padding: 14px 16px;
        }
        .cat-drag { color: var(--tx-8); cursor: grab; font-size: 18px; flex-shrink: 0; }
        .cat-drag:active { cursor: grabbing; }
        .cat-info { flex: 1; min-width: 0; }
        .cat-name { font-size: 15px; font-weight: 500; color: var(--tx-1); }
        .cat-meta { font-size: 12px; color: var(--tx-6); margin-top: 2px; }
        .cat-badge {
            font-size: 11px; padding: 3px 9px; border-radius: 20px;
            background: var(--bg-input); border: 1px solid var(--bd-2); color: var(--tx-5);
        }

        .toggle {
            width: 36px; height: 20px; border-radius: 10px; background: var(--bg-tgl);
            position: relative; cursor: pointer; transition: background 0.15s;
            border: none; padding: 0; flex-shrink: 0;
        }
        .toggle::after {
            content: ''; position: absolute; width: 14px; height: 14px;
            border-radius: 50%; background: var(--tx-6); top: 3px; left: 3px;
            transition: left 0.15s, background 0.15s;
        }
        .toggle.on { background: rgba(193,68,14,0.3); }
        .toggle.on::after { left: 19px; background: #C1440E; }

        .icon-btn {
            width: 34px; height: 34px; border-radius: 8px;
            border: 1px solid var(--bd-3); background: var(--bg-input);
            display: flex; align-items: center; justify-content: center;
            cursor: pointer; color: var(--tx-5); font-size: 15px;
            transition: color 0.1s, border-color 0.1s; flex-shrink: 0;
        }
        .icon-btn:hover        { color: var(--tx-1); border-color: var(--bd-2); }
        .icon-btn.danger:hover { color: #F0997B; border-color: rgba(240,153,123,0.3); }

        /* Modal */
        .modal-overlay {
            position: fixed; inset: 0; background: var(--overlay);
            z-index: 500; display: flex; align-items: center; justify-content: center;
            padding: 20px; opacity: 0; pointer-events: none; transition: opacity 0.2s;
        }
        .modal-overlay.open { opacity: 1; pointer-events: all; }
        .modal {
            background: var(--bg-card); border: 1px solid var(--bd-3); border-radius: 16px;
            width: 100%; max-width: 420px; max-height: 90vh;
            display: flex; flex-direction: column;
            transform: translateY(8px); transition: transform 0.2s;
        }
        .modal-overlay.open .modal { transform: translateY(0); }

        /* Mobile sheet */
        .sheet-overlay {
            position: fixed; inset: 0; background: var(--overlay);
            z-index: 500; display: flex; align-items: flex-end;
            opacity: 0; pointer-events: none; transition: opacity 0.25s;
        }
        .sheet-overlay.open { opacity: 1; pointer-events: all; }
        .sheet {
            width: 100%; background: var(--bg-card); border-radius: 20px 20px 0 0;
            border-top: 1px solid var(--bd-3); max-height: 80vh;
            display: flex; flex-direction: column;
            transform: translateY(100%); transition: transform 0.3s cubic-bezier(0.32,0.72,0,1);
        }
        .sheet-overlay.open .sheet { transform: translateY(0); }
        .sheet-handle { width: 40px; height: 4px; border-radius: 2px; background: var(--bd-2); margin: 12px auto 0; flex-shrink: 0; }

        @media (max-width: 767px) { .modal-overlay { display: none !important; } }
        @media (min-width: 768px) { .sheet-overlay { display: none !important; } }

        .panel-header {
            padding: 16px 18px 14px; border-bottom: 1px solid var(--bd-1);
            display: flex; align-items: center; justify-content: space-between; flex-shrink: 0;
        }
        .panel-title { font-size: 17px; font-weight: 600; color: var(--tx-hi); letter-spacing: -0.3px; }
        .panel-close {
            width: 30px; height: 30px; border-radius: 50%;
            border: 1px solid var(--bd-2); background: var(--bg-input);
            display: flex; align-items: center; justify-content: center;
            cursor: pointer; color: var(--tx-5); font-size: 13px;
        }
        .panel-close:hover { color: var(--tx-1); }
        .panel-body { flex: 1; min-height: 0; overflow-y: auto; padding: 18px; display: flex; flex-direction: column; gap: 14px; }
        .panel-footer {
            padding: 14px 18px; border-top: 1px solid var(--bd-1);
            display: flex; gap: 8px; justify-content: flex-end; flex-shrink: 0;
            padding-bottom: calc(14px + env(safe-area-inset-bottom));
        }

        .field { display: flex; flex-direction: column; gap: 6px; }
        .field label { font-size: 13px; font-weight: 500; color: var(--tx-4); }
        .field input {
            background: var(--bg-input); border: 1px solid var(--bd-2); color: var(--tx-hi);
            font-size: 15px; padding: 12px 14px; border-radius: 10px;
            outline: none; width: 100%; transition: border-color 0.15s;
        }
        .field input:focus { border-color: var(--tx-5); }
        .field-error { font-size: 12px; color: #F0997B; display: none; }
        .field-error.show { display: block; }

        @media (max-width: 767px) {
            .panel-footer .btn { flex: 1; justify-content: center; min-height: 48px; font-size: 15px; }
            .field input { font-size: 16px; min-height: 48px; }
            .cat-card-header { padding: 16px; }
            .cat-name { font-size: 16px; }
        }
    </style>
{% endblock %}

{% block body %}
    <div class="cats-wrap">

        {% if categories|length == 0 %}
            <div class="empty-state">
                <span class="empty-icon">📂</span>
                <div class="empty-title">{{ 'empty_state.title'|trans({}, 'admin_categories') }}</div>
                <div class="empty-sub">
                    {{ 'empty_state.subtitle'|trans({}, 'admin_categories') }}
                </div>
                <button class="btn btn-primary" onclick="UI.openNew()">
                    <i class="ti ti-plus" aria-hidden="true"></i> {{ 'action.create_first_category'|trans({}, 'admin_categories') }}
                </button>
            </div>

        {% else %}
            <div id="cats-sortable">
                {% for category in categories %}
                    {% set catT = category.getTranslation(locale) %}
                    {% set catName = catT ? catT.name : '(sin nombre)' %}
                    {% set productCount = category.products|length %}

                    <div class="cat-card" data-id="{{ category.id }}">
                        <div class="cat-card-header">
                            <i class="ti ti-grip-vertical cat-drag" aria-hidden="true"></i>
                            <div class="cat-info">
                                <div class="cat-name">{{ catName }}</div>
                                <div class="cat-meta">
                                    {{ productCount }} {{ (productCount == 1 ? 'meta.dish_singular' : 'meta.dish_plural')|trans({}, 'admin_categories') }}
                                    · {{ (category.isActive ? 'status.visible' : 'status.hidden')|trans({}, 'admin_categories') }}
                                </div>
                            </div>
                            <span class="cat-badge">{{ 'badge.position'|trans({'%position%': loop.index}, 'admin_categories') }}</span>
                            <button class="toggle {{ category.isActive ? 'on' : '' }}"
                                    onclick="toggleCat({{ category.id }}, this)"
                                    title="{{ (category.isActive ? 'status.visible' : 'status.hidden')|trans({}, 'admin_categories') }}"
                                    aria-label="{{ 'action.toggle_active'|trans({}, 'admin_categories') }}"></button>
                            <button class="icon-btn"
                                    onclick="UI.openEdit({{ category.id }}, '{{ catName|e('js') }}')"
                                    title="{{ 'action.edit_name'|trans({}, 'admin_categories') }}" aria-label="{{ 'action.edit_name'|trans({}, 'admin_categories') }}">
                                <i class="ti ti-edit" aria-hidden="true"></i>
                            </button>
                            <button class="icon-btn danger"
                                    onclick="deleteCat({{ category.id }}, '{{ catName|e('js') }}', {{ productCount }}, this)"
                                    title="{{ 'action.delete'|trans({}, 'admin_categories') }}" aria-label="{{ 'action.delete_category'|trans({}, 'admin_categories') }}">
                                <i class="ti ti-trash" aria-hidden="true"></i>
                            </button>
                        </div>
                    </div>
                {% endfor %}
            </div>

            <p style="font-size:12px;color:var(--tx-7);margin-top:12px;text-align:center">
                <i class="ti ti-grip-vertical" aria-hidden="true"></i>
                {{ 'hint.drag_reorder'|trans({}, 'admin_categories') }}
            </p>
        {% endif %}

    </div>

    {# ── Desktop modal ── #}
    <div class="modal-overlay" id="d-modal" onclick="if(event.target===this)UI.close()">
        <div class="modal">
            <div class="panel-header">
                <div class="panel-title" id="d-modal-title">{{ 'action.new_category'|trans({}, 'admin_categories') }}</div>
                <button class="panel-close" onclick="UI.close()" aria-label="{{ 'action.close'|trans({}, 'admin_categories') }}"><i class="ti ti-x"></i></button>
            </div>
            <div class="panel-body">
                <div class="field">
                    <label for="cat-name-d">{{ 'field.name'|trans({}, 'admin_categories') }} <span style="color:var(--brand)">*</span></label>
                    <input type="text" id="cat-name-d"
                           placeholder="{{ 'field.name_placeholder'|trans({}, 'admin_categories') }}"
                           onkeydown="if(event.key==='Enter') UI.save()">
                    <div class="field-error" id="cat-error-d">{{ 'field.name_required'|trans({}, 'admin_categories') }}</div>
                </div>
            </div>
            <div class="panel-footer">
                <button class="btn" onclick="UI.close()">{{ 'action.cancel'|trans({}, 'admin_categories') }}</button>
                <button class="btn btn-primary" id="d-save-btn" onclick="UI.save()">
                    <i class="ti ti-check" aria-hidden="true"></i> {{ 'action.save'|trans({}, 'admin_categories') }}
                </button>
            </div>
        </div>
    </div>

    {# ── Mobile bottom sheet ── #}
    <div class="sheet-overlay" id="m-sheet" onclick="if(event.target===this)UI.close()">
        <div class="sheet">
            <div class="sheet-handle"></div>
            <div class="panel-header">
                <div class="panel-title" id="m-sheet-title">{{ 'action.new_category'|trans({}, 'admin_categories') }}</div>
                <button class="panel-close" onclick="UI.close()" aria-label="{{ 'action.close'|trans({}, 'admin_categories') }}"><i class="ti ti-x"></i></button>
            </div>
            <div class="panel-body">
                <div class="field">
                    <label for="cat-name-m">{{ 'field.name'|trans({}, 'admin_categories') }} <span style="color:var(--brand)">*</span></label>
                    <input type="text" id="cat-name-m"
                           placeholder="{{ 'field.name_placeholder'|trans({}, 'admin_categories') }}"
                           onkeydown="if(event.key==='Enter') UI.save()">
                    <div class="field-error" id="cat-error-m">{{ 'field.name_required'|trans({}, 'admin_categories') }}</div>
                </div>
            </div>
            <div class="panel-footer">
                <button class="btn" onclick="UI.close()">{{ 'action.cancel'|trans({}, 'admin_categories') }}</button>
                <button class="btn btn-primary" onclick="UI.save()">
                    <i class="ti ti-check" aria-hidden="true"></i> {{ 'action.save'|trans({}, 'admin_categories') }}
                </button>
            </div>
        </div>
    </div>

{% endblock %}

{% block javascripts %}
    <script>
        const MSG_NEW_CATEGORY    = "{{ 'action.new_category'|trans({}, 'admin_categories')|e('js') }}";
        const MSG_EDIT_CATEGORY   = "{{ 'modal.edit_title'|trans({}, 'admin_categories')|e('js') }}";
        const MSG_UPDATED         = "{{ 'toast.updated'|trans({}, 'admin_categories')|e('js') }}";
        const MSG_CREATED         = "{{ 'toast.created'|trans({}, 'admin_categories')|e('js') }}";
        const MSG_VISIBLE         = "{{ 'status.visible'|trans({}, 'admin_categories')|e('js') }}";
        const MSG_HIDDEN          = "{{ 'status.hidden'|trans({}, 'admin_categories')|e('js') }}";
        const MSG_TOAST_VISIBLE   = "{{ 'toast.visible'|trans({}, 'admin_categories')|e('js') }}";
        const MSG_TOAST_HIDDEN    = "{{ 'toast.hidden'|trans({}, 'admin_categories')|e('js') }}";
        const MSG_DELETED         = "{{ 'toast.deleted'|trans({}, 'admin_categories')|e('js') }}";
        const MSG_CONFIRM_DELETE_WITH_PRODUCTS = "{{ 'confirm.delete_with_products'|trans({}, 'admin_categories')|e('js') }}";
        const MSG_CONFIRM_DELETE_SIMPLE        = "{{ 'confirm.delete_simple'|trans({}, 'admin_categories')|e('js') }}";

        const isMobile = () => window.innerWidth < 768;

        let editingId = null;

        const UI = {
            openNew() {
                editingId = null;
                document.getElementById('d-modal-title').textContent = MSG_NEW_CATEGORY;
                document.getElementById('m-sheet-title').textContent = MSG_NEW_CATEGORY;
                document.getElementById('cat-name-d').value = '';
                document.getElementById('cat-name-m').value = '';
                document.getElementById('cat-error-d').classList.remove('show');
                document.getElementById('cat-error-m').classList.remove('show');
                if (isMobile()) {
                    document.getElementById('m-sheet').classList.add('open');
                    setTimeout(() => document.getElementById('cat-name-m').focus(), 80);
                } else {
                    document.getElementById('d-modal').classList.add('open');
                    setTimeout(() => document.getElementById('cat-name-d').focus(), 80);
                }
            },
            openEdit(id, name) {
                editingId = id;
                document.getElementById('d-modal-title').textContent = MSG_EDIT_CATEGORY;
                document.getElementById('m-sheet-title').textContent = MSG_EDIT_CATEGORY;
                document.getElementById('cat-name-d').value = name;
                document.getElementById('cat-name-m').value = name;
                document.getElementById('cat-error-d').classList.remove('show');
                document.getElementById('cat-error-m').classList.remove('show');
                if (isMobile()) {
                    document.getElementById('m-sheet').classList.add('open');
                    setTimeout(() => document.getElementById('cat-name-m').focus(), 80);
                } else {
                    document.getElementById('d-modal').classList.add('open');
                    setTimeout(() => document.getElementById('cat-name-d').focus(), 80);
                }
            },
            close() {
                document.getElementById('d-modal').classList.remove('open');
                document.getElementById('m-sheet').classList.remove('open');
            },
            async save() {
                const inputId = isMobile() ? 'cat-name-m' : 'cat-name-d';
                const errorId = isMobile() ? 'cat-error-m' : 'cat-error-d';
                const name    = document.getElementById(inputId).value.trim();

                if (!name) {
                    document.getElementById(errorId).classList.add('show');
                    return;
                }
                document.getElementById(errorId).classList.remove('show');

                const url  = editingId
                    ? `/admin/categories/${editingId}/edit`
                    : '/admin/categories/create';
                const data = await api(url, { name });
                if (data.error) { showToast(data.error, 'error'); return; }

                showToast(editingId ? MSG_UPDATED : MSG_CREATED, 'success');
                this.close();
                setTimeout(() => location.reload(), 700);
            },
        };

        // ── Toggle active ──
        async function toggleCat(id, btn) {
            const data = await api(`/admin/categories/${id}/toggle`);
            btn.classList.toggle('on', data.active);
            const card = btn.closest('.cat-card');
            const meta = card.querySelector('.cat-meta');
            if (meta) meta.innerHTML = meta.innerHTML.replace(new RegExp(`${MSG_VISIBLE}|${MSG_HIDDEN}`), data.active ? MSG_VISIBLE : MSG_HIDDEN);
            showToast(data.active ? MSG_TOAST_VISIBLE : MSG_TOAST_HIDDEN);
        }

        // ── Delete ──
        async function deleteCat(id, name, count, btn) {
            const msg = count > 0
                ? MSG_CONFIRM_DELETE_WITH_PRODUCTS.replace('%name%', name).replace('%count%', count)
                : MSG_CONFIRM_DELETE_SIMPLE.replace('%name%', name);
            if (!confirm(msg)) return;
            const data = await api(`/admin/categories/${id}/delete`);
            if (data.ok) {
                btn.closest('.cat-card').remove();
                showToast(MSG_DELETED, 'success');
                if (!document.querySelector('.cat-card')) location.reload();
            }
        }

        // ── API helper ──
        async function api(url, body = null) {
            const opts = { method: 'POST', headers: { 'Content-Type': 'application/json' } };
            opts.body  = JSON.stringify(body ?? {});
            const res  = await fetch(url, opts);
            return res.json();
        }

        function showToast(msg, type = 'info') { window.showToast?.(msg, type); }
    </script>
{% endblock %}
