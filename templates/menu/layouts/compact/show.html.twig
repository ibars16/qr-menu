{# Layout: Compact — numbered rows, horizontal-scroll card back #}
{% include 'menu/themes/' ~ theme ~ '/vars.html.twig' %}
<style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: var(--bg); background-attachment: var(--bg-attach, scroll); color: var(--fg); min-height: 100vh; -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; line-height: 1.5; }

    /* ── Header ── */
    .header { position: sticky; top: 0; z-index: 200; background: var(--hdr-bg); backdrop-filter: var(--hdr-blur); -webkit-backdrop-filter: var(--hdr-blur); border-bottom: 1px solid var(--hdr-border); padding: 14px 22px; }
    .header-row { display: flex; align-items: center; justify-content: space-between; gap: 12px; max-width: 760px; margin: 0 auto; }
    .logo-wrap { display: flex; align-items: center; gap: 12px; }
    .logo { width: 38px; height: 38px; border-radius: 11px; background: var(--logo-bg); display: flex; align-items: center; justify-content: center; color: #fff; font-size: 15px; font-weight: 800; flex-shrink: 0; overflow: hidden; box-shadow: 0 2px 12px rgba(0,0,0,0.22); }
    .logo img { width: 100%; height: 100%; object-fit: cover; }
    .resto-name { font-size: 16px; font-weight: 700; color: var(--fg); letter-spacing: -0.4px; }
    .selectors { display: flex; gap: 6px; }
    .sel-wrap { position: relative; }
    .sel-wrap select { appearance: none; background: var(--surface); border: 1.5px solid var(--b1); color: var(--fg-2); font-size: 12px; padding: 7px 26px 7px 12px; border-radius: 24px; cursor: pointer; outline: none; transition: border-color 0.2s, background 0.2s; font-weight: 500; }
    .sel-wrap select:hover { border-color: var(--b2); }
    .sel-wrap .chev { position: absolute; right: 9px; top: 50%; transform: translateY(-50%); font-size: 9px; color: var(--fg-3); pointer-events: none; }

    /* ── Hero ── */
    .hero { position: relative; padding: var(--hero-pad, 38px 22px 32px); background: var(--hero-bg); border-bottom: 1px solid var(--hero-border); overflow: hidden; }
    .hero-bg-img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: var(--hero-img-op, 0); pointer-events: none; }
    .hero-overlay-el { position: absolute; inset: 0; background: var(--hero-overlay, none); pointer-events: none; }
    .hero-inner { position: relative; z-index: 1; max-width: 760px; margin: 0 auto; }
    .hero-name { font-size: 34px; font-weight: 900; color: var(--hero-fg, var(--fg)); letter-spacing: -1.2px; line-height: 1.06; }
    .hero-sub { font-size: 14px; color: var(--hero-fg-2, var(--fg-2)); margin-top: 8px; letter-spacing: 0.01em; }

    /* ── UI wrapper ── */
    .ui-wrap { max-width: 760px; margin: 0 auto; padding: 0 22px; }

    .search-wrap { padding-top: 22px; position: relative; }
    .search-input { width: 100%; background: var(--in-bg); border: 1.5px solid var(--in-border); color: var(--in-text); font-size: 15px; padding: 14px 16px 14px 50px; border-radius: var(--search-radius, 16px); outline: none; transition: border-color 0.22s, box-shadow 0.22s; }
    .search-input::placeholder { color: var(--in-ph); }
    .search-input:focus { border-color: var(--in-focus-border); box-shadow: var(--in-focus-shadow); }
    .search-icon { position: absolute; left: 17px; top: 36px; font-size: 17px; color: var(--fg-3); pointer-events: none; }

    .diet-filters { display: flex; flex-wrap: wrap; gap: 8px; padding-top: 16px; }
    .diet-filter { background: var(--tab-bg); border: 1.5px solid var(--tab-border); color: var(--tab-text); border-radius: var(--tab-radius, 24px); padding: 7px 16px; cursor: pointer; font-size: 12px; font-weight: 600; line-height: 1; letter-spacing: 0.01em; transition: background 0.2s, border-color 0.2s, color 0.2s, box-shadow 0.2s, transform 0.15s; user-select: none; }
    .diet-filter:hover { background: var(--tab-hbg); color: var(--tab-htext); transform: translateY(-1px); }
    .diet-filter:active { transform: scale(0.97); }
    .diet-filter.active { background: var(--tab-act-bg); border-color: var(--tab-act-border); color: var(--tab-act-text); box-shadow: var(--tab-act-shadow); }
    .sep { height: 1px; margin: 16px 0 0; background: var(--sep-bg); }

    /* Allergen filter — a single button so it's easy to find without
       crowding the search bar; opens a checklist of only the allergens
       actually present on this menu (see MenuController::$menuAllergens). */
    .allergen-filter-wrap { position: relative; padding-top: 12px; }
    .allergen-filter-btn {
        display: inline-flex; align-items: center; gap: 7px; font-family: inherit;
        background: var(--tab-bg); border: 1.5px solid var(--tab-border); color: var(--tab-text);
        border-radius: var(--tab-radius, 24px); padding: 7px 16px; cursor: pointer;
        font-size: 12px; font-weight: 600; letter-spacing: 0.01em;
        transition: background 0.2s, border-color 0.2s, color 0.2s, transform 0.15s; user-select: none;
    }
    .allergen-filter-btn:hover { background: var(--tab-hbg); color: var(--tab-htext); transform: translateY(-1px); }
    .allergen-filter-btn[aria-expanded="true"], .allergen-filter-btn.has-selection {
        background: var(--tab-act-bg); border-color: var(--tab-act-border); color: var(--tab-act-text);
    }
    .allergen-filter-badge {
        display: inline-flex; align-items: center; justify-content: center; min-width: 16px; height: 16px;
        padding: 0 4px; border-radius: 999px; background: #d64545; color: #fff; font-size: 10px; font-weight: 700;
    }
    .allergen-filter-panel {
        position: absolute; top: calc(100% + 8px); left: 0; z-index: 60; width: min(300px, 86vw);
        background: var(--cb-bg); border: 1px solid var(--bdiv); border-radius: 14px; padding: 14px;
        box-shadow: 0 12px 32px rgba(0,0,0,0.28);
    }
    .allergen-filter-panel[hidden] { display: none; }
    .allergen-filter-panel-title { font-size: 11px; font-weight: 700; color: var(--btt); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 10px; }
    .allergen-filter-options { display: flex; flex-direction: column; gap: 1px; max-height: 260px; overflow-y: auto; }
    .allergen-filter-option { display: flex; align-items: center; gap: 9px; padding: 8px 7px; border-radius: 8px; cursor: pointer; font-size: 13px; color: var(--bn); user-select: none; }
    .allergen-filter-option:hover { background: var(--in-bg); }
    .allergen-filter-option input { width: 16px; height: 16px; accent-color: #d64545; cursor: pointer; flex-shrink: 0; }
    .allergen-filter-clear {
        display: block; width: 100%; margin-top: 10px; padding-top: 10px; border: none; border-top: 1px solid var(--bdiv);
        font-family: inherit; background: none; color: var(--fg-3); font-size: 12px; font-weight: 600; cursor: pointer;
    }
    .allergen-filter-clear:hover { color: var(--bn); }

    /* Cross-contamination / exception note on an allergen chip */
    .alg-note-btn { display: inline-flex; align-items: center; margin-left: 3px; cursor: pointer; opacity: 0.8; border: none; background: none; padding: 0; color: inherit; }
    .alg-note-btn:hover { opacity: 1; }
    .alg-note-btn i { font-size: 12px; }
    .alg-note-popover {
        position: fixed; max-width: 240px; background: var(--cb-bg); border: 1px solid var(--bdiv);
        border-radius: 10px; padding: 10px 12px; font-size: 12px; line-height: 1.5; color: var(--bn);
        box-shadow: 0 12px 32px rgba(0,0,0,0.3); z-index: 90;
    }

    .cat-tabs { display: flex; gap: 7px; padding-top: 16px; overflow-x: auto; scrollbar-width: none; padding-bottom: 4px; }
    .cat-tabs::-webkit-scrollbar { display: none; }
    .cat-tab { font-size: 13px; font-weight: 600; padding: 8px 18px; border-radius: var(--tab-radius, 24px); background: var(--tab-bg); border: 1.5px solid var(--tab-border); color: var(--tab-text); white-space: nowrap; flex-shrink: 0; cursor: pointer; line-height: 1; letter-spacing: 0.01em; transition: background 0.2s, border-color 0.2s, color 0.2s, box-shadow 0.2s, transform 0.15s; user-select: none; }
    .cat-tab:hover { background: var(--tab-hbg); color: var(--tab-htext); transform: translateY(-1px); }
    .cat-tab:active { transform: scale(0.97); }
    .cat-tab.active { background: var(--tab-act-bg); border-color: var(--tab-act-border); color: var(--tab-act-text); box-shadow: var(--tab-act-shadow); }

    /* ── Content ── */
    .content { max-width: 760px; margin: 0 auto; padding: 0 0 120px; }
    .cat-section { padding-top: 36px; }
    .cat-title-row { display: flex; align-items: center; gap: 12px; padding: 0 22px 16px; }
    .cat-title-row::before { content: ''; width: 3px; height: 14px; border-radius: 2px; background: var(--tab-act-bg); opacity: 0.8; flex-shrink: 0; }
    .cat-title { font-size: 11px; font-weight: 800; color: var(--cat-title); text-transform: uppercase; letter-spacing: 0.15em; white-space: nowrap; }
    .cat-sep { flex: 1; height: 1px; background: var(--cat-sep); }
    .no-results { text-align: center; padding: 70px 20px; color: var(--fg-3); font-size: 15px; display: none; max-width: 760px; margin: 0 auto; }
    .empty-state { text-align: center; padding: 80px 20px; color: var(--fg-3); font-size: 15px; }
    .cards-list { display: flex; flex-direction: column; }

    /* ── Flip card row ── */
    .card-wrap { perspective: 1400px; cursor: pointer; }
    .card { width: 100%; height: 100px; position: relative; transform-style: preserve-3d; transition: transform 0.55s cubic-bezier(0.35,0.15,0.2,1); }
    .card.flipped { transform: rotateY(180deg); }
    .card-front, .card-back { position: absolute; inset: 0; backface-visibility: hidden; -webkit-backface-visibility: hidden; overflow: hidden; }

    /* ── Front ── */
    .card-front { background: var(--surface); border-bottom: 1px solid var(--row-border); display: flex; align-items: center; padding: 0 22px; transition: background 0.2s; }
    .card-wrap:hover .card:not(.flipped) .card-front { background: var(--row-hover); }
    .row-num { font-size: 13px; font-weight: 700; color: var(--num); width: 30px; flex-shrink: 0; transition: color 0.2s; font-variant-numeric: tabular-nums; letter-spacing: -0.3px; }
    .card-wrap:hover .row-num { color: var(--num-h); }
    .front-img { width: 64px; height: 64px; flex-shrink: 0; border-radius: var(--badge-radius, 10px); background: var(--cf-img); overflow: hidden; display: flex; align-items: center; justify-content: center; font-size: 28px; margin-right: 16px; position: relative; }
    .front-img[data-lightbox] { cursor: zoom-in; }
    .spicy-badge { position: absolute; top: 3px; right: 3px; background: rgba(0,0,0,0.55); color: #ef4444; border-radius: 10px; padding: 1px 3px; font-size: 11px; line-height: 1; z-index: 2; display: flex; align-items: center; }
    .front-img img { width: 100%; height: 100%; object-fit: cover; }
    .front-info { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 4px; }
    .front-name { font-size: 16px; font-weight: 600; color: var(--cn); letter-spacing: -0.3px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; transition: color 0.2s; }
    .card-wrap:hover .front-name { color: var(--fg); }
    .front-meta { display: flex; align-items: center; gap: 6px; }
    .front-badge { font-size: 11px; padding: 2px 9px; border-radius: var(--badge-radius, 8px); background: var(--cbg); border: 1px solid var(--cbc); color: var(--cbt); font-weight: 500; }
    .front-right { display: flex; flex-direction: column; align-items: flex-end; gap: 5px; flex-shrink: 0; margin-left: 16px; }
    .front-price { font-size: 19px; font-weight: 700; color: var(--cp); letter-spacing: -0.5px; font-variant-numeric: tabular-nums; }
    .supplement-badge { font-size: 0.75em; font-weight: 700; color: var(--cp); white-space: nowrap; }
    .flip-hint { font-size: 10px; color: var(--hint); transition: color 0.2s; display: flex; align-items: center; gap: 3px; }
    .card-wrap:hover .flip-hint { color: var(--hint-h); }

    /* ── Back (horizontal scroll) ── */
    .card-back { background: var(--cb-bg); border-bottom: 1px solid var(--cb-border); transform: rotateY(180deg); display: flex; flex-direction: row; align-items: stretch; }
    .back-close { flex-shrink: 0; width: 50px; display: flex; align-items: center; justify-content: center; color: var(--close-t); cursor: pointer; background: transparent; border: none; border-right: 1px solid var(--bdiv); font-size: 13px; transition: color 0.2s, background 0.2s; }
    .back-close:hover { color: var(--close-ht); background: var(--close-hbg); }

    .back-scroll { position: relative; flex: 1; overflow: hidden; }
    .back-scroll::after { content: ''; position: absolute; top: 0; right: 0; bottom: 0; width: 44px; background: linear-gradient(to right, transparent, var(--fade)); pointer-events: none; transition: opacity 0.22s; opacity: 0; }
    .back-scroll.can-right::after { opacity: 1; }
    @keyframes cue-slide   { 0%,100% { transform: translateY(-50%) translateX(0); } 50% { transform: translateY(-50%) translateX(3px);  } }
    @keyframes cue-slide-l { 0%,100% { transform: translateY(-50%) translateX(0); } 50% { transform: translateY(-50%) translateX(-3px); } }
    .scroll-cue-h, .scroll-cue-l { position: absolute; top: 50%; transform: translateY(-50%); background: var(--cue-bg); color: var(--cue-text); border-radius: 50%; width: 24px; height: 24px; display: flex; align-items: center; justify-content: center; font-size: 14px; border: none; cursor: pointer; pointer-events: none; opacity: 0; user-select: none; transition: opacity 0.22s; z-index: 2; }
    .scroll-cue-h { right: 9px; }
    .scroll-cue-h::after { content: '›'; }
    .scroll-cue-l { left: 9px; }
    .scroll-cue-l::after { content: '‹'; }
    .back-scroll.can-right .scroll-cue-h { opacity: 1; pointer-events: auto; animation: cue-slide   2s ease-in-out infinite; }
    .back-scroll.can-left  .scroll-cue-l { opacity: 1; pointer-events: auto; animation: cue-slide-l 2s ease-in-out infinite; }
    /* Lightbox */
    .lb-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.9); z-index: 9000; display: flex; align-items: center; justify-content: center; opacity: 0; pointer-events: none; transition: opacity 0.26s; }
    .lb-overlay.open { opacity: 1; pointer-events: auto; }
    .lb-content { position: relative; max-width: min(92vw, 560px); width: 100%; }
    .lb-img { width: 100%; height: auto; max-height: 78vh; object-fit: contain; border-radius: 12px; display: block; transform: scale(0.88); transition: transform 0.3s cubic-bezier(0.34,1.56,0.64,1); }
    .lb-overlay.open .lb-img { transform: scale(1); }
    .lb-close { position: absolute; top: -14px; right: -14px; width: 32px; height: 32px; border-radius: 50%; background: rgba(255,255,255,0.18); border: 1.5px solid rgba(255,255,255,0.3); color: #fff; font-size: 18px; cursor: pointer; display: flex; align-items: center; justify-content: center; padding: 0; line-height: 1; transition: background 0.18s; }
    .lb-close:hover { background: rgba(255,255,255,0.3); }

    .back-body { height: 100%; overflow-x: auto; overflow-y: hidden; display: flex; align-items: stretch; scrollbar-width: none; }
    .back-body::-webkit-scrollbar { display: none; }
    .bsec { flex-shrink: 0; padding: 14px 18px; display: flex; flex-direction: column; gap: 4px; border-right: 1px solid var(--bdiv); }
    .bsec-title { font-size: 9px; font-weight: 700; color: var(--btt); text-transform: uppercase; letter-spacing: 0.12em; margin-bottom: 2px; }
    .back-desc { font-size: 12px; color: var(--bdesc); line-height: 1.5; max-width: 200px; }
    .ing-list { display: flex; gap: 4px; align-items: center; flex-wrap: nowrap; }
    .ing { font-size: 11px; padding: 3px 9px; border-radius: var(--badge-radius, 8px); background: var(--ing-bg); color: var(--ing-t); border: 1px solid var(--ing-b); white-space: nowrap; }
    .lbl-list { display: flex; gap: 4px; }
    .lbl { font-size: 11px; padding: 3px 9px; border-radius: var(--badge-radius, 8px); white-space: nowrap; }
    .lbl-g { background: var(--lg-bg); color: var(--lg); border: 1px solid var(--lg-b); }
    .lbl-o { background: var(--lo-bg); color: var(--lo); border: 1px solid var(--lo-b); }
    .alg { font-size: 11px; padding: 3px 9px; border-radius: var(--badge-radius, 8px); border: 1px solid transparent; white-space: nowrap; }
    .alg-contains { background: rgba(220,38,38,0.12); color: #d64545; border-color: rgba(220,38,38,0.28); }
    .alg-may_contain { background: transparent; color: #c78a3d; border: 1px dashed rgba(199,138,61,0.55); }
    .alg-free_from { background: rgba(127,127,127,0.08); color: var(--btt); border-color: var(--bdiv); }
    .allergen-disclaimer { font-size: 11px; color: var(--fg-3); padding-top: 10px; line-height: 1.5; }
    .nut-row { display: flex; align-items: baseline; gap: 4px; }
    .nut-v { font-size: 20px; font-weight: 700; color: var(--nut-v); font-variant-numeric: tabular-nums; }
    .nut-u { font-size: 11px; color: var(--nut-u); }
    .spicy-row { display: flex; align-items: center; gap: 4px; }
    .dot { width: 8px; height: 8px; border-radius: 50%; background: var(--dot-off); flex-shrink: 0; }
    .dot.on { background: var(--dot-on); }
    .spicy-txt { font-size: 11px; color: var(--spicy-t); white-space: nowrap; }
</style>
{% include 'menu/themes/' ~ theme ~ '/overrides.html.twig' ignore missing %}

<header class="header">
    <div class="header-row">
        <div class="logo-wrap">
            <div class="logo">{% if restaurant.logo %}<img src="{{ asset('uploads/logos/' ~ restaurant.logo) }}" alt="">{% else %}{{ restaurant.name|slice(0,1)|upper }}{% endif %}</div>
            <div class="resto-name">{{ restaurant.name }}</div>
        </div>
        <div class="selectors">
            <div class="sel-wrap"><select onchange="changeLanguage(this.value)">{% for code, lang in languages %}<option value="{{ code }}" {{ locale == code ? 'selected' : '' }}>{{ lang.flag }} {{ code|upper }}</option>{% endfor %}</select><span class="chev">▾</span></div>
            <div class="sel-wrap"><select onchange="changeCurrency(this.value)">{% for code, curr in currencies %}<option value="{{ code }}" {{ currency == code ? 'selected' : '' }}>{{ curr.symbol }} {{ code }}</option>{% endfor %}</select><span class="chev">▾</span></div>
        </div>
    </div>
</header>

<div class="hero">
    {% if restaurant.logo %}<img class="hero-bg-img" src="{{ asset('uploads/banners/' ~ restaurant.logo) }}" alt="">{% endif %}
    <div class="hero-overlay-el"></div>
    <div class="hero-inner"><div class="hero-name">{{ restaurant.name }}</div><div class="hero-sub">Nuestra carta</div></div>
</div>

<div class="ui-wrap">
    <div class="search-wrap"><i class="ti ti-search search-icon"></i><input type="text" class="search-input" id="menu-search" placeholder="Buscar platos…" autocomplete="off"></div>
    {% if tags|length > 0 %}<div class="diet-filters"><button class="diet-filter active" data-tag="all">Todo</button>{% for tag in tags %}{% if tagNames[tag.id] is defined %}<button class="diet-filter" data-tag="{{ tag.id }}">{{ tag.icon }} {{ tagNames[tag.id] }}</button>{% endif %}{% endfor %}</div><div class="sep"></div>{% endif %}
    {% if menuAllergens|length > 0 %}
        <div class="allergen-filter-wrap">
            <button type="button" class="allergen-filter-btn" id="allergen-filter-btn" onclick="toggleAllergenFilterPanel()" aria-expanded="false" aria-haspopup="true">
                <i class="ti ti-shield-check" style="font-size:14px" aria-hidden="true"></i>
                <span>Evitar alérgenos</span>
                <span class="allergen-filter-badge" id="allergen-filter-badge" style="display:none">0</span>
            </button>
            <div class="allergen-filter-panel" id="allergen-filter-panel" hidden>
                <div class="allergen-filter-panel-title">Ocultar platos que contengan…</div>
                <div class="allergen-filter-options">
                    {% for a in menuAllergens %}
                        <label class="allergen-filter-option">
                            <input type="checkbox" value="{{ a.code }}" onchange="onAllergenFilterChange()">
                            <span>{{ a.icon }} {{ a.name }}</span>
                        </label>
                    {% endfor %}
                </div>
                <button type="button" class="allergen-filter-clear" onclick="clearAllergenFilters()">Borrar selección</button>
            </div>
        </div>
    {% endif %}
    <div class="allergen-disclaimer"><i class="ti ti-info-circle" style="font-size:12px"></i> La información de alérgenos es orientativa. Consulta con el personal antes de pedir si tienes alguna alergia.</div>
    <div class="cat-tabs" id="cat-tabs"><span class="cat-tab active" data-cat="all">Todo</span>{% for category in categories %}{% set t = category.getTranslation(locale) %}{% if not t %}{% set t = category.getTranslation(restaurant.defaultLanguage) %}{% endif %}{% if not t %}{% set t = category.translations.first %}{% endif %}{% if t %}<span class="cat-tab" data-cat="cat-{{ category.id }}">{{ t.name }}</span>{% endif %}{% endfor %}</div>
</div>

<div class="content">
    <div class="no-results" id="no-results">No se encontraron platos</div>
    {% for category in categories %}
        {% set catT = category.getTranslation(locale) %}
        {% if not catT %}{% set catT = category.getTranslation(restaurant.defaultLanguage) %}{% endif %}
        {% if not catT %}{% set catT = category.translations.first %}{% endif %}
        {% if catT and category.activeProductsSorted|length > 0 %}
            <section class="cat-section" id="cat-{{ category.id }}" data-section="cat-{{ category.id }}">
                <div class="cat-title-row"><div class="cat-title">{{ catT.name }}</div><div class="cat-sep"></div></div>
                <div class="cards-list">
                    {% for product in category.activeProductsSorted %}
                        {% set pT = product.getTranslation(locale) %}
                        {% if not pT %}{% set pT = product.getTranslation(restaurant.defaultLanguage) %}{% endif %}
                        {% if not pT %}{% set pT = product.translations.first %}{% endif %}
                        {% if pT %}
                            <div class="card-wrap" onclick="flipCard(this)" data-tags="{% for tag in product.tags %}{{ tag.id }} {% endfor %}" data-allergens="{% for a in productAllergens[product.id]|default([]) %}{{ a.code }}:{{ a.presence }} {% endfor %}">
                                <div class="card">
                                    <div class="card-front">
                                        <div class="row-num">{{ loop.index < 10 ? '0' ~ loop.index : loop.index }}</div>
                                        <div class="front-img" {% if product.image %}data-lightbox="{{ asset('uploads/products/' ~ product.image) }}" onclick="event.stopPropagation();lbOpen(this.dataset.lightbox)"{% endif %}>{% if product.image %}<img src="{{ asset('uploads/products/' ~ product.image) }}" alt="{{ pT.name }}" loading="lazy">{% else %}🍽️{% endif %}{% if product.spicyLevel > 0 %}<div class="spicy-badge">{% if product.spicyLevel <= 2 %}<svg width="1em" height="1em" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 7c0 5-6 5-6 10a6 6 0 0 0 12 0c0-5-6-5-6-10z" fill="currentColor"/><path d="M12 3c0 1.5 1.5 3 3 3" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg>{% elseif product.spicyLevel <= 4 %}<svg width="1em" height="1em" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 7c0 5-6 5-6 10a6 6 0 0 0 12 0c0-5-6-5-6-10z" fill="currentColor"/><path d="M12 3c0 1.5 1.5 3 3 3" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg><svg width="1em" height="1em" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 7c0 5-6 5-6 10a6 6 0 0 0 12 0c0-5-6-5-6-10z" fill="currentColor"/><path d="M12 3c0 1.5 1.5 3 3 3" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg>{% else %}<svg width="1em" height="1em" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 7c0 5-6 5-6 10a6 6 0 0 0 12 0c0-5-6-5-6-10z" fill="currentColor"/><path d="M12 3c0 1.5 1.5 3 3 3" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg><svg width="1em" height="1em" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 7c0 5-6 5-6 10a6 6 0 0 0 12 0c0-5-6-5-6-10z" fill="currentColor"/><path d="M12 3c0 1.5 1.5 3 3 3" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg><svg width="1em" height="1em" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 7c0 5-6 5-6 10a6 6 0 0 0 12 0c0-5-6-5-6-10z" fill="currentColor"/><path d="M12 3c0 1.5 1.5 3 3 3" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg>{% endif %}</div>{% endif %}</div>
                                        <div class="front-info">
                                            <div class="front-name">{{ pT.name }}{% if product.supplementPrice %} <span class="supplement-badge">+{{ (product.supplementPrice / 100)|number_format(2) }}€</span>{% endif %}</div>
                                            <div class="front-meta">
                                                {% for tag in product.tags %}{% if tagNames[tag.id] is defined %}<span class="front-badge">{{ tag.icon }} {{ tagNames[tag.id] }}</span>{% endif %}{% endfor %}
                                            </div>
                                        </div>
                                        <div class="front-right">
                                            <div class="front-price">{% if product.glassPrice %}Copa {{ (product.glassPrice / 100)|number_format(2) }}€ · Botella {{ (product.convertedPrice / 100)|number_format(2) }}{% else %}{{ (product.convertedPrice / 100)|number_format(2) }}{% endif %}</div>
                                            <div class="flip-hint"><i class="ti ti-rotate-clockwise"></i> info</div>
                                        </div>
                                    </div>
                                    <div class="card-back">
                                        <button class="back-close" onclick="unflipCard(event,this)" aria-label="Volver"><i class="ti ti-x"></i></button>
                                        <div class="back-scroll horiz">
                                            <div class="back-body">
                                                <div class="bsec"><div class="bsec-title">Plato</div><div class="back-desc" style="font-weight:600;font-size:13px;color:var(--bn)">{{ pT.name }}{% if product.supplementPrice %} <span class="supplement-badge">+{{ (product.supplementPrice / 100)|number_format(2) }}€</span>{% endif %}</div><div style="font-size:18px;font-weight:700;color:var(--bp);margin-top:4px;font-variant-numeric:tabular-nums">{% if product.glassPrice %}Copa {{ (product.glassPrice / 100)|number_format(2) }}€ · Botella {{ (product.convertedPrice / 100)|number_format(2) }} {{ currency }}{% else %}{{ (product.convertedPrice / 100)|number_format(2) }} {{ currency }}{% endif %}</div></div>
                                                {% if pT.description %}<div class="bsec"><div class="bsec-title">Descripción</div><div class="back-desc">{{ pT.description }}</div></div>{% endif %}
                                                {% set ingredientNames = product.getIngredientNames(locale, restaurant.defaultLanguage) %}{% if ingredientNames|length > 0 %}<div class="bsec"><div class="bsec-title">Ingredientes</div><div class="ing-list">{% for name in ingredientNames %}<div class="ing">{{ name }}</div>{% endfor %}</div></div>{% endif %}
                                                {% if product.tags|length > 0 %}<div class="bsec"><div class="bsec-title">Etiquetas</div><div class="lbl-list">{% for tag in product.tags %}{% if tagNames[tag.id] is defined %}<div class="lbl lbl-g">{{ tag.icon }} {{ tagNames[tag.id] }}</div>{% endif %}{% endfor %}</div></div>{% endif %}
                                                {% if productAllergens[product.id]|default([])|length > 0 %}<div class="bsec"><div class="bsec-title">Alérgenos</div><div class="lbl-list">{% for a in productAllergens[product.id] %}{% set noteBtn = a.note ? '<span class="alg-note-btn" role="button" tabindex="0" aria-label="Más información" data-note="' ~ a.note|e('html_attr') ~ '" onclick="toggleAllergenNote(event, this)"><i class="ti ti-info-circle" aria-hidden="true"></i></span>' : '' %}{% if a.presence == 'free_from' %}<div class="alg alg-free_from">✓ Sin {{ a.name }}{{ noteBtn|raw }}</div>{% elseif a.presence == 'may_contain' %}<div class="alg alg-may_contain">{{ a.icon }} {{ a.name }} · trazas{{ noteBtn|raw }}</div>{% else %}<div class="alg alg-contains">{{ a.icon }} {{ a.name }}{{ noteBtn|raw }}</div>{% endif %}{% endfor %}</div></div>{% endif %}
                                                {% if product.spicyLevel > 0 %}<div class="bsec"><div class="bsec-title">Picante</div><div class="spicy-row">{% for i in 1..5 %}<div class="dot {{ i <= product.spicyLevel ? 'on' : '' }}"></div>{% endfor %}<span class="spicy-txt">{% if product.spicyLevel == 1 %}Suave{% elseif product.spicyLevel == 2 %}Medio{% elseif product.spicyLevel == 3 %}Picante{% elseif product.spicyLevel == 4 %}Muy picante{% else %}Extremo{% endif %}</span></div></div>{% endif %}
                                                {% if product.calories %}<div class="bsec"><div class="bsec-title">Calorías</div><div class="nut-row"><span class="nut-v">{{ product.calories }}</span><span class="nut-u">kcal</span></div></div>{% endif %}
                                            </div>
                                            <button class="scroll-cue-l" type="button" aria-label="Volver"></button>
                                            <button class="scroll-cue-h" type="button" aria-label="Siguiente"></button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% endif %}
                    {% endfor %}
                </div>
            </section>
        {% endif %}
    {% else %}<div class="empty-state">No hay productos disponibles.</div>{% endfor %}
</div>

<div class="lb-overlay" id="lb-overlay" role="dialog" aria-modal="true" aria-hidden="true" onclick="if(event.target===this)lbClose()">
    <div class="lb-content">
        <img class="lb-img" id="lb-img" src="" alt="">
        <button class="lb-close" aria-label="Cerrar" onclick="lbClose()">×</button>
    </div>
</div>

