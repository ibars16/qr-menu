{# Layout: Grid — portrait flip cards, 2/3/4 column grid #}
{% include 'menu/themes/' ~ theme ~ '/vars.html.twig' %}
<style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: var(--bg); background-attachment: var(--bg-attach); color: var(--fg); min-height: 100vh; -webkit-font-smoothing: antialiased; }

    .header { position: sticky; top: 0; z-index: 200; background: var(--hdr-bg); backdrop-filter: var(--hdr-blur); -webkit-backdrop-filter: var(--hdr-blur); border-bottom: 1px solid var(--hdr-border); padding: 13px 20px; }
    .header-row { display: flex; align-items: center; justify-content: space-between; gap: 10px; max-width: 920px; margin: 0 auto; }
    .logo-wrap { display: flex; align-items: center; gap: 11px; }
    .logo { width: 38px; height: 38px; border-radius: 11px; background: var(--logo-bg); display: flex; align-items: center; justify-content: center; color: #fff; font-size: 15px; font-weight: 800; flex-shrink: 0; overflow: hidden; box-shadow: 0 2px 12px rgba(0,0,0,0.22); }
    .logo img { width: 100%; height: 100%; object-fit: cover; }
    .resto-name { font-size: 15px; font-weight: 700; color: var(--fg); letter-spacing: -0.3px; }
    .selectors { display: flex; gap: 6px; }
    .sel-wrap { position: relative; }
    .sel-wrap select { appearance: none; background: var(--surface); border: 1.5px solid var(--b1); color: var(--fg-2); font-size: 12px; padding: 7px 24px 7px 11px; border-radius: 24px; cursor: pointer; outline: none; transition: border-color 0.2s; font-weight: 500; }
    .sel-wrap select:hover { border-color: var(--b2); }
    .sel-wrap .chev { position: absolute; right: 8px; top: 50%; transform: translateY(-50%); font-size: 9px; color: var(--fg-3); pointer-events: none; }

    .hero { padding: 40px 20px 34px; background: var(--hero-bg); border-bottom: 1px solid var(--hero-border); }
    .hero-inner { max-width: 920px; margin: 0 auto; }
    .hero-name { font-size: 36px; font-weight: 900; color: var(--fg); letter-spacing: -1.2px; line-height: 1.05; }
    .hero-sub { font-size: 14px; color: var(--fg-2); margin-top: 8px; }

    .ui-wrap { padding: 0 14px; }
    @media (min-width: 768px) { .ui-wrap { max-width: 920px; margin: 0 auto; padding: 0 24px; } }

    .search-wrap { padding-top: 20px; position: relative; }
    .search-input { width: 100%; background: var(--in-bg); border: 1.5px solid var(--in-border); color: var(--in-text); font-size: 15px; padding: 13px 16px 13px 48px; border-radius: var(--search-radius, 16px); outline: none; transition: border-color 0.22s, box-shadow 0.22s; }
    .search-input::placeholder { color: var(--in-ph); }
    .search-input:focus { border-color: var(--in-focus-border); box-shadow: var(--in-focus-shadow); }
    .search-icon { position: absolute; left: 16px; top: 33px; font-size: 16px; color: var(--fg-3); pointer-events: none; }

    .diet-filters { display: flex; flex-wrap: wrap; gap: 7px; padding-top: 14px; }
    .diet-filter { background: var(--tab-bg); border: 1.5px solid var(--tab-border); color: var(--tab-text); border-radius: var(--tab-radius, 24px); padding: 7px 14px; cursor: pointer; font-size: 12px; font-weight: 600; line-height: 1; transition: background 0.2s, border-color 0.2s, color 0.2s, transform 0.15s; user-select: none; }
    .diet-filter:hover { background: var(--tab-hbg); color: var(--tab-htext); transform: translateY(-1px); }
    .diet-filter:active { transform: scale(0.97); }
    .diet-filter.active { background: var(--tab-act-bg); border-color: var(--tab-act-border); color: var(--tab-act-text); box-shadow: var(--tab-act-shadow); }
    .sep { height: 1px; margin: 14px 0 0; background: var(--sep-bg); }

    /* Allergen filter — a single button so it's easy to find without
       crowding the search bar; opens a checklist of only the allergens
       actually present on this menu (see MenuController::$menuAllergens). */
    .allergen-filter-wrap { position: relative; padding-top: 12px; }
    .allergen-filter-btn {
        display: inline-flex; align-items: center; gap: 7px; font-family: inherit;
        background: var(--tab-bg); border: 1.5px solid var(--tab-border); color: var(--tab-text);
        border-radius: var(--tab-radius, 24px); padding: 7px 16px; cursor: pointer;
        font-size: 12px; font-weight: 600; letter-spacing: 0.01em;
        transition: background 0.2s, border-color 0.2s, color 0.2s, transform 0.15s; user-select: none;
    }
    .allergen-filter-btn:hover { background: var(--tab-hbg); color: var(--tab-htext); transform: translateY(-1px); }
    .allergen-filter-btn[aria-expanded="true"], .allergen-filter-btn.has-selection {
        background: var(--tab-act-bg); border-color: var(--tab-act-border); color: var(--tab-act-text);
    }
    .allergen-filter-badge {
        display: inline-flex; align-items: center; justify-content: center; min-width: 16px; height: 16px;
        padding: 0 4px; border-radius: 999px; background: #d64545; color: #fff; font-size: 10px; font-weight: 700;
    }
    .allergen-filter-panel {
        position: absolute; top: calc(100% + 8px); left: 0; z-index: 60; width: min(300px, 86vw);
        background: var(--cb-bg); border: 1px solid var(--bdiv); border-radius: 14px; padding: 14px;
        box-shadow: 0 12px 32px rgba(0,0,0,0.28);
    }
    .allergen-filter-panel[hidden] { display: none; }
    .allergen-filter-panel-title { font-size: 11px; font-weight: 700; color: var(--btt); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 10px; }
    .allergen-filter-options { display: flex; flex-direction: column; gap: 1px; max-height: 260px; overflow-y: auto; }
    .allergen-filter-option { display: flex; align-items: center; gap: 9px; padding: 8px 7px; border-radius: 8px; cursor: pointer; font-size: 13px; color: var(--bn); user-select: none; }
    .allergen-filter-option:hover { background: var(--in-bg); }
    .allergen-filter-option input { width: 16px; height: 16px; accent-color: #d64545; cursor: pointer; flex-shrink: 0; }
    .allergen-filter-clear {
        display: block; width: 100%; margin-top: 10px; padding-top: 10px; border: none; border-top: 1px solid var(--bdiv);
        font-family: inherit; background: none; color: var(--fg-3); font-size: 12px; font-weight: 600; cursor: pointer;
    }
    .allergen-filter-clear:hover { color: var(--bn); }

    /* Cross-contamination / exception note on an allergen chip */
    .alg-note-btn { display: inline-flex; align-items: center; margin-left: 3px; cursor: pointer; opacity: 0.8; border: none; background: none; padding: 0; color: inherit; }
    .alg-note-btn:hover { opacity: 1; }
    .alg-note-btn i { font-size: 12px; }
    .alg-note-popover {
        position: fixed; max-width: 240px; background: var(--cb-bg); border: 1px solid var(--bdiv);
        border-radius: 10px; padding: 10px 12px; font-size: 12px; line-height: 1.5; color: var(--bn);
        box-shadow: 0 12px 32px rgba(0,0,0,0.3); z-index: 90;
    }

    .cat-tabs { display: flex; gap: 6px; padding-top: 14px; overflow-x: auto; scrollbar-width: none; padding-bottom: 4px; }
    .cat-tabs::-webkit-scrollbar { display: none; }
    .cat-tab { font-size: 13px; font-weight: 600; padding: 8px 18px; border-radius: var(--tab-radius, 24px); border: 1.5px solid var(--tab-border); background: var(--tab-bg); color: var(--tab-text); white-space: nowrap; flex-shrink: 0; cursor: pointer; line-height: 1; transition: background 0.2s, border-color 0.2s, color 0.2s, transform 0.15s; user-select: none; }
    .cat-tab:hover { background: var(--tab-hbg); color: var(--tab-htext); transform: translateY(-1px); }
    .cat-tab:active { transform: scale(0.97); }
    .cat-tab.active { background: var(--tab-act-bg); border-color: var(--tab-act-border); color: var(--tab-act-text); box-shadow: var(--tab-act-shadow); }

    .content { padding: 0 14px 100px; }
    @media (min-width: 768px) { .content { padding: 0 24px 100px; max-width: 920px; margin: 0 auto; } }
    .cat-section { padding-top: 36px; }
    .cat-title { display: flex; align-items: center; gap: 14px; margin-bottom: 18px; font-size: 11px; font-weight: 800; color: var(--cat-title); text-transform: uppercase; letter-spacing: 0.14em; }
    .cat-title::before { content: ''; width: 3px; height: 12px; border-radius: 2px; background: var(--tab-act-bg); flex-shrink: 0; opacity: 0.8; }
    .cat-title::after { content: ''; flex: 1; height: 1px; background: var(--cat-sep, transparent); }
    .no-results { display: none; text-align: center; padding: 60px 20px; color: var(--fg-3); font-size: 15px; }
    .empty-state { text-align: center; padding: 80px 20px; color: var(--fg-3); font-size: 15px; }

    .cards-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 12px; }
    @media (min-width: 580px) { .cards-grid { grid-template-columns: repeat(3,1fr); } }
    @media (min-width: 900px) { .cards-grid { grid-template-columns: repeat(4,1fr); } }

    /* ── Flip card ── */
    .card-wrap { perspective: 1400px; cursor: pointer; }
    .card { width: 100%; height: 290px; position: relative; transform-style: preserve-3d; transition: transform 0.52s cubic-bezier(0.4,0.18,0.18,1); border-radius: var(--card-radius, 18px); }
    @media (min-width: 580px) { .card { height: 302px; } }
    @media (min-width: 900px) { .card { height: 312px; } }
    .card.flipped { transform: rotateY(180deg); }
    .card-front, .card-back { position: absolute; inset: 0; border-radius: var(--card-radius, 18px); backface-visibility: hidden; -webkit-backface-visibility: hidden; overflow: hidden; }

    /* ── Front ── */
    .card-front { background: var(--cf-bg); border: 1px solid var(--cf-border); display: flex; flex-direction: column; box-shadow: var(--card-shadow, none); transition: box-shadow 0.25s, border-color 0.25s, transform 0.25s; }
    .card-front::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: var(--accent-line-h, 3px); background: var(--cf-accent); opacity: var(--cf-accent-op); border-radius: var(--card-radius, 18px) var(--card-radius, 18px) 0 0; z-index: 1; }
    .card-wrap:hover .card:not(.flipped) .card-front { box-shadow: var(--card-hover-shadow, var(--cf-hshadow, none)); border-color: var(--cf-hborder); transform: translateY(var(--card-lift, -4px)); }
    .front-img { height: 210px; background: var(--cf-img); display: flex; align-items: center; justify-content: center; font-size: 36px; position: relative; overflow: hidden; flex-shrink: 0; }
    @media (min-width: 580px) { .front-img { height: 220px; } }
    @media (min-width: 900px) { .front-img { height: 228px; } }
    .front-img img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
    .front-img-overlay { position: absolute; inset: 0; background: linear-gradient(to bottom, transparent 55%, rgba(0,0,0,0.12) 100%); pointer-events: none; }
    .spicy-badge { position: absolute; top: 6px; right: 6px; background: rgba(0,0,0,0.55); color: #ef4444; border-radius: 16px; padding: 2px 5px; font-size: 13px; line-height: 1; z-index: 3; display: flex; align-items: center; gap: 1px; }
    .front-body { flex: 1; padding: 9px 12px 10px; display: flex; flex-direction: column; justify-content: space-between; min-height: 0; overflow: hidden; }
    .front-badges { display: flex; gap: 4px; flex-wrap: wrap; margin-bottom: 4px; }
    .fbadge { font-size: 10px; padding: 2px 7px; border-radius: var(--badge-radius, 7px); background: var(--cbg); border: 1px solid var(--cbc); color: var(--cbt); font-weight: 500; }
    .fbadge-hot { color: #e06840; border-color: rgba(224,104,64,0.22); background: rgba(224,104,64,0.08); }
    .front-name { font-size: 14px; font-weight: 700; color: var(--cn); letter-spacing: -0.3px; line-height: 1.3; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .front-bottom { display: flex; align-items: center; justify-content: space-between; }
    .front-price { font-size: 18px; font-weight: 800; color: var(--cp); letter-spacing: -0.5px; font-variant-numeric: tabular-nums; }
    .flip-hint { font-size: 10px; color: var(--hint); display: flex; align-items: center; gap: 2px; padding: 4px 9px; border-radius: 16px; border: 1px solid var(--tab-border); background: var(--tab-bg); transition: color 0.2s, border-color 0.2s; white-space: nowrap; }
    .card-wrap:hover .flip-hint { color: var(--hint-h); border-color: var(--cf-hborder); }

    /* ── Back ── */
    .card-back { background: var(--cb-bg); border: 1px solid var(--cb-border); transform: rotateY(180deg); display: flex; flex-direction: column; }
    .back-close { position: absolute; top: 9px; right: 9px; width: 26px; height: 26px; border-radius: 50%; background: var(--close-bg); border: 1px solid var(--close-b); cursor: pointer; color: var(--close-t); display: flex; align-items: center; justify-content: center; font-size: 10px; z-index: 2; transition: color 0.18s, background 0.18s, transform 0.22s; }
    .back-close:hover { color: var(--close-ht); background: var(--close-hbg); transform: rotate(90deg); }
    .back-header { padding: 12px 38px 11px 13px; border-bottom: 1px solid var(--bdiv); flex-shrink: 0; }
    .back-name { font-size: 13px; font-weight: 700; color: var(--bn); letter-spacing: -0.25px; line-height: 1.22; }
    .back-price { font-size: 13px; color: var(--bp); margin-top: 2px; font-variant-numeric: tabular-nums; font-weight: 700; }
    .supplement-badge { font-size: 0.75em; font-weight: 700; color: var(--cp); white-space: nowrap; }

    .back-scroll { position: relative; flex: 1; min-height: 0; overflow: hidden; }
    .back-scroll::after { content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 36px; background: linear-gradient(transparent, var(--fade)); pointer-events: none; transition: opacity 0.22s; opacity: 0; }
    .back-scroll.can-dn::after { opacity: 1; }
    @keyframes cue-dn { 0%,100% { transform: translateX(-50%) translateY(0); } 50% { transform: translateX(-50%) translateY(3px); } }
    @keyframes cue-up { 0%,100% { transform: translateX(-50%) translateY(0); } 50% { transform: translateX(-50%) translateY(-3px); } }
    .scroll-cue-dn, .scroll-cue-up { position: absolute; left: 50%; transform: translateX(-50%); background: var(--cue-bg); color: var(--cue-text); border: none; border-radius: 50%; width: 24px; height: 24px; display: flex; align-items: center; justify-content: center; font-size: 11px; cursor: pointer; pointer-events: none; opacity: 0; transition: opacity 0.22s; user-select: none; z-index: 2; }
    .scroll-cue-dn { bottom: 7px; }
    .scroll-cue-dn::after { content: '↓'; }
    .scroll-cue-up { top: 7px; }
    .scroll-cue-up::after { content: '↑'; }
    .back-scroll.can-dn .scroll-cue-dn { opacity: 1; pointer-events: auto; animation: cue-dn 2s ease-in-out infinite; }
    .back-scroll.can-up .scroll-cue-up { opacity: 1; pointer-events: auto; animation: cue-up 2s ease-in-out infinite; }

    .back-body { height: 100%; overflow-y: auto; padding: 11px 13px 34px; scrollbar-width: none; display: flex; flex-direction: column; gap: 8px; }
    .back-body::-webkit-scrollbar { display: none; }
    .bsec { display: flex; flex-direction: column; gap: 4px; }
    .bsec + .bsec { padding-top: 7px; border-top: 1px solid var(--bdiv); }
    .bsec-title { font-size: 9px; font-weight: 700; color: var(--btt); text-transform: uppercase; letter-spacing: 0.1em; }
    .back-desc { font-size: 11px; color: var(--bdesc); line-height: 1.56; }
    .ing-list { display: flex; flex-wrap: wrap; gap: 3px; }
    .ing { font-size: 10px; padding: 2px 8px; border-radius: var(--badge-radius, 7px); background: var(--ing-bg); color: var(--ing-t); border: 1px solid var(--ing-b); }
    .lbl-list { display: flex; flex-wrap: wrap; gap: 3px; }
    .lbl { font-size: 10px; padding: 2px 8px; border-radius: var(--badge-radius, 7px); }
    .lbl-g { background: var(--lg-bg); color: var(--lg); border: 1px solid var(--lg-b); }
    .lbl-o { background: var(--lo-bg); color: var(--lo); border: 1px solid var(--lo-b); }
    .alg { font-size: 10px; padding: 2px 8px; border-radius: var(--badge-radius, 7px); border: 1px solid transparent; }
    .alg-contains { background: rgba(220,38,38,0.12); color: #d64545; border-color: rgba(220,38,38,0.28); }
    .alg-may_contain { background: transparent; color: #c78a3d; border: 1px dashed rgba(199,138,61,0.55); }
    .alg-free_from { background: rgba(127,127,127,0.08); color: var(--btt); border-color: var(--bdiv); }
    .allergen-disclaimer { font-size: 11px; color: var(--fg-3); padding-top: 10px; line-height: 1.5; }
    .nut { display: inline-flex; align-items: baseline; gap: 3px; background: var(--nut-bg); border: 1px solid var(--nut-b); border-radius: 8px; padding: 5px 10px; }
    .nut-v { font-size: 15px; font-weight: 700; color: var(--nut-v); font-variant-numeric: tabular-nums; }
    .nut-u { font-size: 10px; color: var(--nut-u); }
    .spicy-row { display: flex; align-items: center; gap: 3px; }
    .dot { width: 7px; height: 7px; border-radius: 50%; background: var(--dot-off); flex-shrink: 0; }
    .dot.on { background: var(--dot-on); }
    .spicy-txt { font-size: 10px; color: var(--spicy-t); margin-left: 3px; }
</style>
{% include 'menu/themes/' ~ theme ~ '/overrides.html.twig' ignore missing %}

<header class="header">
    <div class="header-row">
        <div class="logo-wrap">
            <div class="logo">{% if restaurant.logo %}<img src="{{ asset('uploads/logos/' ~ restaurant.logo) }}" alt="">{% else %}{{ restaurant.name|slice(0,1)|upper }}{% endif %}</div>
            <div><div class="resto-name">{{ restaurant.name }}</div></div>
        </div>
        <div class="selectors">
            <div class="sel-wrap"><select onchange="changeLanguage(this.value)">{% for code, lang in languages %}<option value="{{ code }}" {{ locale == code ? 'selected' : '' }}>{{ lang.flag }} {{ code|upper }}</option>{% endfor %}</select><span class="chev">▾</span></div>
            <div class="sel-wrap"><select onchange="changeCurrency(this.value)">{% for code, curr in currencies %}<option value="{{ code }}" {{ currency == code ? 'selected' : '' }}>{{ curr.symbol }} {{ code }}</option>{% endfor %}</select><span class="chev">▾</span></div>
        </div>
    </div>
</header>

<div class="hero"><div class="hero-inner"><div class="hero-name">{{ restaurant.name }}</div><div class="hero-sub">Explora nuestra carta</div></div></div>

<div class="ui-wrap">
    <div class="search-wrap"><i class="ti ti-search search-icon"></i><input type="text" class="search-input" id="menu-search" placeholder="Buscar platos…" autocomplete="off"></div>
    {% if tags|length > 0 %}<div class="diet-filters"><button class="diet-filter active" data-tag="all">Todo</button>{% for tag in tags %}{% if tagNames[tag.id] is defined %}<button class="diet-filter" data-tag="{{ tag.id }}">{{ tag.icon }} {{ tagNames[tag.id] }}</button>{% endif %}{% endfor %}</div><div class="sep"></div>{% endif %}
    {% if menuAllergens|length > 0 %}
        <div class="allergen-filter-wrap">
            <button type="button" class="allergen-filter-btn" id="allergen-filter-btn" onclick="toggleAllergenFilterPanel()" aria-expanded="false" aria-haspopup="true">
                <i class="ti ti-shield-check" style="font-size:14px" aria-hidden="true"></i>
                <span>Evitar alérgenos</span>
                <span class="allergen-filter-badge" id="allergen-filter-badge" style="display:none">0</span>
            </button>
            <div class="allergen-filter-panel" id="allergen-filter-panel" hidden>
                <div class="allergen-filter-panel-title">Ocultar platos que contengan…</div>
                <div class="allergen-filter-options">
                    {% for a in menuAllergens %}
                        <label class="allergen-filter-option">
                            <input type="checkbox" value="{{ a.code }}" onchange="onAllergenFilterChange()">
                            <span>{{ a.icon }} {{ a.name }}</span>
                        </label>
                    {% endfor %}
                </div>
                <button type="button" class="allergen-filter-clear" onclick="clearAllergenFilters()">Borrar selección</button>
            </div>
        </div>
    {% endif %}
    <div class="allergen-disclaimer"><i class="ti ti-info-circle" style="font-size:12px"></i> La información de alérgenos es orientativa. Consulta con el personal antes de pedir si tienes alguna alergia.</div>
    <div class="cat-tabs" id="cat-tabs"><span class="cat-tab active" data-cat="all">Todo</span>{% for category in categories %}{% set t = category.getTranslation(locale) %}{% if not t %}{% set t = category.getTranslation(restaurant.defaultLanguage) %}{% endif %}{% if not t %}{% set t = category.translations.first %}{% endif %}{% if t %}<span class="cat-tab" data-cat="cat-{{ category.id }}">{{ t.name }}</span>{% endif %}{% endfor %}</div>
</div>

<div class="content">
    <div class="no-results" id="no-results">No se encontraron platos</div>
    {% for category in categories %}
        {% set catT = category.getTranslation(locale) %}
        {% if not catT %}{% set catT = category.getTranslation(restaurant.defaultLanguage) %}{% endif %}
        {% if not catT %}{% set catT = category.translations.first %}{% endif %}
        {% if catT and category.activeProductsSorted|length > 0 %}
            <section class="cat-section" id="cat-{{ category.id }}" data-section="cat-{{ category.id }}">
                <div class="cat-title">{{ catT.name }}</div>
                <div class="cards-grid">
                    {% for product in category.activeProductsSorted %}
                        {% set pT = product.getTranslation(locale) %}
                        {% if not pT %}{% set pT = product.getTranslation(restaurant.defaultLanguage) %}{% endif %}
                        {% if not pT %}{% set pT = product.translations.first %}{% endif %}
                        {% if pT %}
                            <div class="card-wrap" onclick="flipCard(this)" data-tags="{% for tag in product.tags %}{{ tag.id }} {% endfor %}" data-allergens="{% for a in productAllergens[product.id]|default([]) %}{{ a.code }}:{{ a.presence }} {% endfor %}">
                                <div class="card">
                                    <div class="card-front">
                                        <div class="front-img">
                                            {% if product.image %}<img src="{{ asset('uploads/products/' ~ product.image) }}" alt="{{ pT.name }}" loading="lazy">{% else %}🍽️{% endif %}
                                            <div class="front-img-overlay"></div>
                                            {% if product.spicyLevel > 0 %}<div class="spicy-badge">{% if product.spicyLevel <= 2 %}<svg width="1em" height="1em" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 7c0 5-6 5-6 10a6 6 0 0 0 12 0c0-5-6-5-6-10z" fill="currentColor"/><path d="M12 3c0 1.5 1.5 3 3 3" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg>{% elseif product.spicyLevel <= 4 %}<svg width="1em" height="1em" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 7c0 5-6 5-6 10a6 6 0 0 0 12 0c0-5-6-5-6-10z" fill="currentColor"/><path d="M12 3c0 1.5 1.5 3 3 3" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg><svg width="1em" height="1em" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 7c0 5-6 5-6 10a6 6 0 0 0 12 0c0-5-6-5-6-10z" fill="currentColor"/><path d="M12 3c0 1.5 1.5 3 3 3" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg>{% else %}<svg width="1em" height="1em" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 7c0 5-6 5-6 10a6 6 0 0 0 12 0c0-5-6-5-6-10z" fill="currentColor"/><path d="M12 3c0 1.5 1.5 3 3 3" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg><svg width="1em" height="1em" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 7c0 5-6 5-6 10a6 6 0 0 0 12 0c0-5-6-5-6-10z" fill="currentColor"/><path d="M12 3c0 1.5 1.5 3 3 3" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg><svg width="1em" height="1em" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 7c0 5-6 5-6 10a6 6 0 0 0 12 0c0-5-6-5-6-10z" fill="currentColor"/><path d="M12 3c0 1.5 1.5 3 3 3" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg>{% endif %}</div>{% endif %}
                                        </div>
                                        <div class="front-body">
                                            <div>
                                                <div class="front-badges">{% for tag in product.tags %}{% if tagNames[tag.id] is defined %}<div class="fbadge">{{ tag.icon }} {{ tagNames[tag.id] }}</div>{% endif %}{% endfor %}</div>
                                                <div class="front-name">{{ pT.name }}{% if product.supplementPrice %} <span class="supplement-badge">+{{ (product.supplementPrice / 100)|number_format(2) }}€</span>{% endif %}</div>
                                            </div>
                                            <div class="front-bottom">
                                                <div class="front-price">{% if product.glassPrice %}Copa {{ (product.glassPrice / 100)|number_format(2) }}€ · Botella {{ (product.convertedPrice / 100)|number_format(2) }} {{ currency }}{% else %}{{ (product.convertedPrice / 100)|number_format(2) }} {{ currency }}{% endif %}</div>
                                                <div class="flip-hint"><i class="ti ti-rotate-clockwise" style="font-size:10px"></i></div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="card-back">
                                        <button class="back-close" onclick="unflipCard(event,this)" aria-label="Cerrar"><i class="ti ti-x"></i></button>
                                        <div class="back-header"><div class="back-name">{{ pT.name }}{% if product.supplementPrice %} <span class="supplement-badge">+{{ (product.supplementPrice / 100)|number_format(2) }}€</span>{% endif %}</div><div class="back-price">{% if product.glassPrice %}Copa {{ (product.glassPrice / 100)|number_format(2) }}€ · Botella {{ (product.convertedPrice / 100)|number_format(2) }} {{ currency }}{% else %}{{ (product.convertedPrice / 100)|number_format(2) }} {{ currency }}{% endif %}</div></div>
                                        <div class="back-scroll">
                                            <div class="back-body">
                                                {% if pT.description %}<div class="bsec"><div class="bsec-title">Descripción</div><div class="back-desc">{{ pT.description }}</div></div>{% endif %}
                                                {% if product.spicyLevel > 0 %}<div class="bsec"><div class="bsec-title">Picante</div><div class="spicy-row">{% for i in 1..5 %}<div class="dot {{ i <= product.spicyLevel ? 'on' : '' }}"></div>{% endfor %}<span class="spicy-txt">{% if product.spicyLevel == 1 %}Suave{% elseif product.spicyLevel == 2 %}Medio{% elseif product.spicyLevel == 3 %}Picante{% elseif product.spicyLevel == 4 %}Muy picante{% else %}Extremo{% endif %}</span></div></div>{% endif %}
                                                {% if product.tags|length > 0 %}<div class="bsec"><div class="bsec-title">Etiquetas</div><div class="lbl-list">{% for tag in product.tags %}{% if tagNames[tag.id] is defined %}<div class="lbl lbl-g">{{ tag.icon }} {{ tagNames[tag.id] }}</div>{% endif %}{% endfor %}</div></div>{% endif %}
                                                {% if productAllergens[product.id]|default([])|length > 0 %}<div class="bsec"><div class="bsec-title">Alérgenos</div><div class="lbl-list">{% for a in productAllergens[product.id] %}{% set noteBtn = a.note ? '<span class="alg-note-btn" role="button" tabindex="0" aria-label="Más información" data-note="' ~ a.note|e('html_attr') ~ '" onclick="toggleAllergenNote(event, this)"><i class="ti ti-info-circle" aria-hidden="true"></i></span>' : '' %}{% if a.presence == 'free_from' %}<div class="alg alg-free_from">✓ Sin {{ a.name }}{{ noteBtn|raw }}</div>{% elseif a.presence == 'may_contain' %}<div class="alg alg-may_contain">{{ a.icon }} {{ a.name }} · trazas{{ noteBtn|raw }}</div>{% else %}<div class="alg alg-contains">{{ a.icon }} {{ a.name }}{{ noteBtn|raw }}</div>{% endif %}{% endfor %}</div></div>{% endif %}
                                                {% set ingredientNames = product.getIngredientNames(locale, restaurant.defaultLanguage) %}{% if ingredientNames|length > 0 %}<div class="bsec"><div class="bsec-title">Ingredientes</div><div class="ing-list">{% for name in ingredientNames %}<div class="ing">{{ name }}</div>{% endfor %}</div></div>{% endif %}
                                                {% if product.calories %}<div class="bsec"><div class="bsec-title">Calorías</div><div class="nut"><span class="nut-v">{{ product.calories }}</span><span class="nut-u">kcal</span></div></div>{% endif %}
                                            </div>
                                            <button class="scroll-cue-up" type="button" aria-label="Subir"></button>
                                            <button class="scroll-cue-dn" type="button" aria-label="Bajar"></button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% endif %}
                    {% endfor %}
                </div>
            </section>
        {% endif %}
    {% else %}<div class="empty-state">No hay productos disponibles.</div>{% endfor %}
</div>

{% include 'menu/_search_js.html.twig' %}
