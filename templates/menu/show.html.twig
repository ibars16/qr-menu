{#/home/david/gitProjects/qr-menu/templates/menu/show.html.twig#}
{% extends 'base.html.twig' %}

{% block title %}{{ restaurant.name }} · Mesa {{ table.number }}{% endblock %}

{% block stylesheets %}
    <style>
        :root {
            --brand: {{ restaurant.primaryColor }};
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: #0d0d0d;
            color: #fff;
            min-height: 100vh;
        }

        /* ── Header ── */
        .header {
            position: sticky; top: 0; z-index: 100;
            background: #0d0d0d;
            padding: 18px 24px 0;
            border-bottom: 0.5px solid #1f1f1f;
        }
        .header-top {
            display: flex; align-items: center;
            justify-content: space-between;
            margin-bottom: 14px;
        }
        .header-left { display: flex; align-items: center; gap: 12px; }
        .logo {
            width: 42px; height: 42px; border-radius: 12px;
            background: var(--brand);
            display: flex; align-items: center; justify-content: center;
            color: #fff; font-size: 18px; font-weight: 700;
            flex-shrink: 0; overflow: hidden;
        }
        .logo img { width: 100%; height: 100%; object-fit: cover; }
        .restaurant-name { font-size: 17px; font-weight: 600; color: #fff; letter-spacing: -0.3px; }
        .restaurant-sub  { font-size: 12px; color: #444; margin-top: 2px; }
        .header-controls { display: flex; gap: 6px; }
        .pill {
            font-size: 12px; padding: 6px 12px; border-radius: 20px;
            border: 0.5px solid #2a2a2a; color: #888;
            background: #161616; cursor: pointer;
            display: flex; align-items: center; gap: 5px;
            text-decoration: none; transition: border-color 0.15s, color 0.15s;
        }
        .pill:hover { border-color: #444; color: #fff; }

        /* ── Tabs ── */
        .tabs { display: flex; overflow-x: auto; scrollbar-width: none; padding: 0 2px; }
        .tabs::-webkit-scrollbar { display: none; }
        .tab {
            font-size: 13px; padding: 10px 16px; color: #444;
            white-space: nowrap; border-bottom: 2px solid transparent;
            flex-shrink: 0; cursor: pointer;
            text-decoration: none; transition: color 0.15s;
        }
        .tab:hover { color: #888; }
        .tab.active { color: var(--brand); border-bottom-color: var(--brand); font-weight: 600; }

        /* ── Content — sin max-width fijo, padding lateral generoso ── */
        .content {
            padding: 24px 24px 80px;
            width: 100%;
        }

        .category-section { padding-top: 32px; }
        .category-title {
            font-size: 11px; font-weight: 600; color: #333;
            text-transform: uppercase; letter-spacing: 0.12em;
            margin-bottom: 18px;
            padding-bottom: 10px;
            border-bottom: 0.5px solid #1a1a1a;
        }

        /* ── Grid responsive — columnas automáticas según espacio disponible ── */
        .cards-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 14px;
        }
        @media (min-width: 600px) {
            .cards-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 16px; }
        }
        @media (min-width: 900px) {
            .cards-grid { grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 18px; }
            .content { padding: 24px 40px 80px; }
        }
        @media (min-width: 1200px) {
            .cards-grid { grid-template-columns: repeat(5, minmax(0, 1fr)); gap: 20px; }
            .content { padding: 24px 60px 80px; }
        }
        @media (min-width: 1600px) {
            .cards-grid { grid-template-columns: repeat(6, minmax(0, 1fr)); gap: 22px; }
            .content { padding: 24px 80px 80px; }
        }

        /* ── Flip card ── */
        .card-wrap { perspective: 1000px; cursor: pointer; }
        .card {
            width: 100%; aspect-ratio: 3/4;
            position: relative; transform-style: preserve-3d;
            transition: transform 0.6s cubic-bezier(0.4, 0.2, 0.2, 1);
            border-radius: 18px;
        }
        .card.flipped { transform: rotateY(180deg); }
        .card-front, .card-back {
            position: absolute; inset: 0; border-radius: 18px;
            backface-visibility: hidden; -webkit-backface-visibility: hidden;
            overflow: hidden;
        }

        /* ── Front ── */
        .card-front {
            background: #161616;
            display: flex; flex-direction: column;
            border: 0.5px solid #2a2a2a;
        }
        .card-front::before {
            content: '';
            position: absolute; top: 0; left: 16px; right: 16px; height: 2px;
            background: linear-gradient(90deg, transparent, var(--brand), transparent);
            border-radius: 0 0 2px 2px; z-index: 1; opacity: 0.6;
        }
        .front-img {
            width: 100%; height: 58%;
            background: #1a1a1a;
            display: flex; align-items: center; justify-content: center;
            font-size: 52px; position: relative; overflow: hidden;
        }
        .front-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
        .front-img::after {
            content: '';
            position: absolute; inset: 0;
            background: radial-gradient(circle at 50% 60%, rgba(193,68,14,0.15) 0%, transparent 70%);
            pointer-events: none;
        }
        .flip-hint {
            position: absolute; top: 10px; right: 10px;
            background: rgba(0,0,0,0.65); border: 0.5px solid #2a2a2a;
            border-radius: 20px; padding: 4px 9px;
            font-size: 10px; color: #555;
            display: flex; align-items: center; gap: 3px; z-index: 2;
        }
        .front-overlay {
            position: absolute; bottom: 0; left: 0; right: 0;
            padding: 28px 14px 14px;
            background: linear-gradient(transparent, rgba(0,0,0,0.93) 55%);
        }
        .front-badges { display: flex; gap: 4px; margin-bottom: 8px; flex-wrap: wrap; }
        .fbadge {
            font-size: 10px; padding: 3px 8px; border-radius: 20px;
            background: rgba(255,255,255,0.07);
            border: 0.5px solid rgba(255,255,255,0.1);
            color: #aaa;
        }
        .fbadge-spicy { color: #F0997B; border-color: rgba(240,153,123,0.3); background: rgba(216,90,48,0.15); }
        .fbadge-veg   { color: #97C459; border-color: rgba(151,196,89,0.3);  background: rgba(99,153,34,0.15); }
        .fbadge-halal { color: #85B7EB; border-color: rgba(133,183,235,0.3); background: rgba(24,95,165,0.15); }
        .front-name  { font-size: 15px; font-weight: 600; color: #fff; letter-spacing: -0.2px; line-height: 1.25; margin-bottom: 5px; }
        .front-price { font-size: 17px; font-weight: 700; color: var(--brand); letter-spacing: -0.4px; }

        /* ── Back ── */
        .card-back {
            background: #141414; transform: rotateY(180deg);
            border: 0.5px solid #2a2a2a;
            display: flex; flex-direction: column;
        }
        .card-back::before {
            content: '';
            position: absolute; top: 0; left: 16px; right: 16px; height: 2px;
            background: linear-gradient(90deg, transparent, var(--brand), transparent);
            border-radius: 0 0 2px 2px; opacity: 0.4;
        }
        .back-close {
            position: absolute; top: 10px; right: 10px;
            width: 26px; height: 26px; border-radius: 50%;
            background: #222; border: 0.5px solid #333;
            cursor: pointer; color: #555;
            display: flex; align-items: center; justify-content: center;
            font-size: 12px; z-index: 2; transition: color 0.15s, background 0.15s;
        }
        .back-close:hover { color: #fff; background: #2a2a2a; }
        .back-header {
            padding: 14px 40px 10px 14px;
            border-bottom: 0.5px solid #1f1f1f; flex-shrink: 0;
        }
        .back-name  { font-size: 15px; font-weight: 600; color: #fff; letter-spacing: -0.3px; line-height: 1.2; }
        .back-price { font-size: 13px; color: var(--brand); font-weight: 600; margin-top: 3px; }
        .back-body {
            flex: 1; overflow-y: auto; padding: 12px 14px 14px;
            scrollbar-width: none;
            display: flex; flex-direction: column; gap: 12px;
        }
        .back-body::-webkit-scrollbar { display: none; }
        .bsec-title {
            font-size: 9px; font-weight: 600; color: #383838;
            text-transform: uppercase; letter-spacing: 0.09em;
            margin-bottom: 6px;
        }
        .ing-list { display: flex; flex-wrap: wrap; gap: 4px; }
        .ing {
            font-size: 11px; padding: 3px 9px; border-radius: 20px;
            background: #1e1e1e; color: #666; border: 0.5px solid #272727;
        }
        .lbl-list { display: flex; flex-wrap: wrap; gap: 4px; }
        .lbl { font-size: 11px; padding: 3px 9px; border-radius: 20px; }
        .lbl-g { background: rgba(59,109,17,0.2);  color: #97C459; border: 0.5px solid rgba(99,153,34,0.25); }
        .lbl-o { background: rgba(193,68,14,0.15); color: #F0997B; border: 0.5px solid rgba(240,153,123,0.25); }
        .lbl-b { background: rgba(24,95,165,0.15); color: #85B7EB; border: 0.5px solid rgba(133,183,235,0.25); }
        .nut-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; }
        .nut { background: #1a1a1a; border-radius: 8px; padding: 8px 10px; border: 0.5px solid #232323; }
        .nut-l { font-size: 10px; color: #3a3a3a; margin-bottom: 2px; }
        .nut-v { font-size: 15px; font-weight: 600; color: #bbb; letter-spacing: -0.5px; }
        .nut-u { font-size: 10px; color: #3a3a3a; font-weight: 400; }
        .spicy-row { display: flex; align-items: center; gap: 5px; }
        .dot { width: 8px; height: 8px; border-radius: 50%; background: #222; }
        .dot.on { background: #D85A30; box-shadow: 0 0 5px rgba(216,90,48,0.5); }
        .spicy-txt { font-size: 11px; color: #555; margin-left: 4px; }
        .empty { text-align: center; padding: 80px 20px; color: #333; font-size: 14px; }
    </style>
{% endblock %}

{% block body %}

    <div class="header">
        <div class="header-top">
            <div class="header-left">
                <div class="logo">
                    {% if restaurant.logo %}
                        <img src="{{ asset('uploads/logos/' ~ restaurant.logo) }}" alt="{{ restaurant.name }}">
                    {% else %}
                        {{ restaurant.name|slice(0,1)|upper }}
                    {% endif %}
                </div>
                <div>
                    <div class="restaurant-name">{{ restaurant.name }}</div>
                    <div class="restaurant-sub">Mesa {{ table.number }}</div>
                </div>
            </div>
            <div class="header-controls">
                <a href="?lang=es&currency={{ currency }}" class="pill" title="Español">🇪🇸 ES</a>
                <a href="?lang=en&currency={{ currency }}" class="pill" title="English">🇬🇧 EN</a>
            </div>
        </div>

        <div class="tabs">
            {% for category in categories %}
                {% set t = category.getTranslation(locale) %}
                {% if t %}
                    <a href="#cat-{{ category.id }}" class="tab">{{ t.name }}</a>
                {% endif %}
            {% endfor %}
        </div>
    </div>

    <div class="content">
        {% for category in categories %}
            {% set catT     = category.getTranslation(locale) %}
            {% set products = category.activeProductsSorted %}
            {% if catT and products|length > 0 %}
                <section class="category-section" id="cat-{{ category.id }}">
                    <div class="category-title">{{ catT.name }}</div>
                    <div class="cards-grid">
                        {% for product in products %}
                            {% include 'menu/_card.html.twig' with { product, locale, currency, restaurant } %}
                        {% endfor %}
                    </div>
                </section>
            {% endif %}
        {% else %}
            <div class="empty">No hay productos disponibles.</div>
        {% endfor %}
    </div>

{% endblock %}

{% block javascripts %}
    <script>
        function flipCard(wrap) {
            wrap.querySelector('.card').classList.toggle('flipped');
        }
        function unflipCard(event, btn) {
            event.stopPropagation();
            btn.closest('.card').classList.remove('flipped');
        }

        const sections = document.querySelectorAll('.category-section');
        const tabs     = document.querySelectorAll('.tab');
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    const id = entry.target.id;
                    tabs.forEach(t => t.classList.toggle('active', t.getAttribute('href') === '#' + id));
                }
            });
        }, { threshold: 0.3 });
        sections.forEach(s => observer.observe(s));
    </script>
{% endblock %}
