<script>
function changeLanguage(lang) { const u = new URL(window.location); u.searchParams.set('lang', lang); window.location.href = u.toString(); }
function changeCurrency(c)    { const u = new URL(window.location); u.searchParams.set('currency', c); window.location.href = u.toString(); }
function flipCard(wrap)        { wrap.querySelector('.card').classList.toggle('flipped'); }
function unflipCard(e, btn)    { e.stopPropagation(); btn.closest('.card').classList.remove('flipped'); }

const searchInput = document.getElementById('menu-search');
const noResults   = document.getElementById('no-results');
const sections    = document.querySelectorAll('.cat-section');
const catTabs     = document.querySelectorAll('.cat-tab');
const dietFilters = document.querySelectorAll('.diet-filter');
let activeTag = 'all';

function applyFilters() {
    const q      = searchInput.value.toLowerCase().trim();
    const active = document.querySelector('.cat-tab.active');
    const cat    = active ? active.dataset.cat : 'all';
    let anyVisible = false;

    sections.forEach(sec => {
        const catMatch = cat === 'all' || cat === sec.dataset.section;
        if (!catMatch) { sec.style.display = 'none'; return; }
        const rows = sec.querySelectorAll('.card-wrap, .product-row');
        let secVisible = false;
        rows.forEach(row => {
            const name     = row.querySelector('.front-name, .product-name')?.textContent.toLowerCase() ?? '';
            const tags     = (row.dataset.tags ?? '').trim().split(/\s+/).filter(Boolean);
            const search   = !q || name.includes(q);
            const tagMatch = activeTag === 'all' || tags.includes(activeTag);
            const show     = search && tagMatch;
            row.style.display = show ? '' : 'none';
            if (show) secVisible = true;
        });
        sec.style.display = secVisible ? '' : 'none';
        if (secVisible) anyVisible = true;
    });
    if (noResults) noResults.style.display = anyVisible ? 'none' : 'block';
}

searchInput?.addEventListener('input', applyFilters);

catTabs.forEach(tab => tab.addEventListener('click', () => {
    catTabs.forEach(t => t.classList.remove('active'));
    tab.classList.add('active');
    applyFilters();
    const cat = tab.dataset.cat;
    if (cat !== 'all') document.getElementById(cat)?.scrollIntoView({ behavior: 'smooth', block: 'start' });
}));

dietFilters.forEach(btn => btn.addEventListener('click', () => {
    dietFilters.forEach(x => x.classList.remove('active'));
    btn.classList.add('active');
    activeTag = btn.dataset.tag;
    applyFilters();
}));

const obs = new IntersectionObserver(entries => {
    const vis = entries.find(e => e.isIntersecting);
    if (!vis) return;
    const id = vis.target.dataset.section;
    catTabs.forEach(t => t.classList.toggle('active', t.dataset.cat === id));
}, { threshold: 0.3 });
sections.forEach(s => obs.observe(s));

// Scroll-fade + scroll-cue indicators for card backs
(function() {
    document.querySelectorAll('.card-wrap').forEach(wrap => {
        let initialized = false;
        wrap.addEventListener('click', function() {
            if (initialized) return;
            setTimeout(function() {
                const body = wrap.querySelector('.back-body');
                if (!body) return;
                const scroll = body.closest('.back-scroll');
                if (!scroll) return;
                const horiz = scroll.classList.contains('horiz');

                function check() {
                    if (horiz) {
                        const canScroll = body.scrollWidth > body.clientWidth + 4;
                        const atEnd = body.scrollLeft + body.clientWidth >= body.scrollWidth - 4;
                        scroll.classList.toggle('no-fade', !canScroll || atEnd);
                    } else {
                        const canScroll = body.scrollHeight > body.clientHeight + 4;
                        const atBottom = body.scrollTop + body.clientHeight >= body.scrollHeight - 4;
                        scroll.classList.toggle('no-scroll', !canScroll);
                        scroll.classList.toggle('at-bottom', canScroll && atBottom);
                        scroll.classList.toggle('no-fade', !canScroll || atBottom);
                    }
                }

                body.addEventListener('scroll', check, { passive: true });
                check();
                initialized = true;
            }, 560);
        });
    });

    // Vertical scroll cue — click scrolls down or back up
    document.addEventListener('click', function(e) {
        const cue = e.target.closest('.scroll-cue');
        if (!cue) return;
        e.stopPropagation();
        const scroll = cue.closest('.back-scroll');
        const body = scroll && scroll.querySelector('.back-body');
        if (!body) return;
        body.scrollBy({ top: scroll.classList.contains('at-bottom') ? -120 : 120, behavior: 'smooth' });
    }, true);

    // Horizontal scroll cue — click scrolls right
    document.addEventListener('click', function(e) {
        const cue = e.target.closest('.scroll-cue-h');
        if (!cue) return;
        e.stopPropagation();
        const scroll = cue.closest('.back-scroll');
        const body = scroll && scroll.querySelector('.back-body');
        if (!body) return;
        body.scrollBy({ left: 180, behavior: 'smooth' });
    }, true);
})();
</script>
