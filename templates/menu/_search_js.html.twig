<script>
// changeLanguage / changeCurrency are defined in menu/_prefs_dialog.html.twig,
// included once from menu/show.html.twig — they also persist the choice to
// the customer's preference cookie before reloading.
function flipCard(wrap)        { wrap.querySelector('.card').classList.toggle('flipped'); }
function unflipCard(e, btn)    { e.stopPropagation(); btn.closest('.card').classList.remove('flipped'); }

const searchInput = document.getElementById('menu-search');
const noResults   = document.getElementById('no-results');
const sections    = document.querySelectorAll('.cat-section');
const catTabs     = document.querySelectorAll('.cat-tab');
const dietFilters = document.querySelectorAll('.diet-filter');
let activeTag = 'all';

// Allergens a customer wants to avoid — multi-select, unlike the single-select
// diet filter above, since someone can have more than one allergy. A dish is
// hidden if it carries ANY selected allergen (data-allergens is "code:presence
// code:presence …", already on every card — see MenuController::$menuAllergens
// for where the checklist itself comes from).
const allergenFilterBtn   = document.getElementById('allergen-filter-btn');
const allergenFilterPanel = document.getElementById('allergen-filter-panel');
const allergenFilterBadge = document.getElementById('allergen-filter-badge');
let activeAllergens = new Set();

function applyFilters() {
    const q      = searchInput.value.toLowerCase().trim();
    const active = document.querySelector('.cat-tab.active');
    const cat    = active ? active.dataset.cat : 'all';
    let anyVisible = false;

    sections.forEach(sec => {
        const catMatch = cat === 'all' || cat === sec.dataset.section;
        if (!catMatch) { sec.style.display = 'none'; return; }
        const rows = sec.querySelectorAll('.card-wrap, .product-row');
        let secVisible = false;
        rows.forEach(row => {
            const name      = row.querySelector('.front-name, .product-name')?.textContent.toLowerCase() ?? '';
            const tags      = (row.dataset.tags ?? '').trim().split(/\s+/).filter(Boolean);
            const allergens = (row.dataset.allergens ?? '').trim().split(/\s+/).filter(Boolean).map(a => a.split(':')[0]);
            const search        = !q || name.includes(q);
            const tagMatch      = activeTag === 'all' || tags.includes(activeTag);
            const allergenMatch = activeAllergens.size === 0 || ![...activeAllergens].some(a => allergens.includes(a));
            const show     = search && tagMatch && allergenMatch;
            row.style.display = show ? '' : 'none';
            if (show) secVisible = true;
        });
        sec.style.display = secVisible ? '' : 'none';
        if (secVisible) anyVisible = true;
    });
    if (noResults) noResults.style.display = anyVisible ? 'none' : 'block';
}

function toggleAllergenFilterPanel() {
    if (!allergenFilterPanel) return;
    const open = !allergenFilterPanel.hidden;
    allergenFilterPanel.hidden = open;
    allergenFilterBtn?.setAttribute('aria-expanded', open ? 'false' : 'true');
}

function onAllergenFilterChange() {
    activeAllergens = new Set(
        Array.from(document.querySelectorAll('.allergen-filter-option input:checked')).map(el => el.value)
    );
    if (allergenFilterBadge) {
        allergenFilterBadge.textContent = String(activeAllergens.size);
        allergenFilterBadge.style.display = activeAllergens.size > 0 ? '' : 'none';
    }
    allergenFilterBtn?.classList.toggle('has-selection', activeAllergens.size > 0);
    applyFilters();
}

function clearAllergenFilters() {
    document.querySelectorAll('.allergen-filter-option input:checked').forEach(el => { el.checked = false; });
    onAllergenFilterChange();
}

document.addEventListener('click', e => {
    if (!allergenFilterPanel || allergenFilterPanel.hidden) return;
    if (allergenFilterPanel.contains(e.target) || allergenFilterBtn?.contains(e.target)) return;
    allergenFilterPanel.hidden = true;
    allergenFilterBtn?.setAttribute('aria-expanded', 'false');
});

// Cross-contamination / exception notes on allergen chips — click-to-open,
// closes on outside click or Escape. Same interaction as the "?" help icons
// in the Admin Panel, kept intentionally simple: no hover-only behavior, so
// it works identically on touch and desktop.
function toggleAllergenNote(event, btnEl) {
    event.stopPropagation();
    const wasOpen = btnEl.classList.contains('note-open');
    closeAllergenNotes();
    if (wasOpen) return;

    const pop = document.createElement('div');
    pop.className = 'alg-note-popover';
    pop.textContent = btnEl.dataset.note;
    document.body.appendChild(pop);

    const rect = btnEl.getBoundingClientRect();
    const popRect = pop.getBoundingClientRect();
    let left = rect.left + rect.width / 2 - popRect.width / 2;
    left = Math.max(8, Math.min(left, window.innerWidth - popRect.width - 8));
    let top = rect.bottom + 8;
    if (top + popRect.height > window.innerHeight - 8) top = rect.top - popRect.height - 8;

    pop.style.left = left + 'px';
    pop.style.top = top + 'px';
    btnEl.classList.add('note-open');
}
function closeAllergenNotes() {
    document.querySelectorAll('.alg-note-popover').forEach(p => p.remove());
    document.querySelectorAll('.alg-note-btn.note-open').forEach(el => el.classList.remove('note-open'));
}
document.addEventListener('click', closeAllergenNotes);
document.addEventListener('keydown', e => {
    if (e.key !== 'Escape') return;
    closeAllergenNotes();
    if (allergenFilterPanel && !allergenFilterPanel.hidden) {
        allergenFilterPanel.hidden = true;
        allergenFilterBtn?.setAttribute('aria-expanded', 'false');
    }
});

searchInput?.addEventListener('input', applyFilters);

catTabs.forEach(tab => tab.addEventListener('click', () => {
    catTabs.forEach(t => t.classList.remove('active'));
    tab.classList.add('active');
    applyFilters();
    const cat = tab.dataset.cat;
    if (cat !== 'all') document.getElementById(cat)?.scrollIntoView({ behavior: 'smooth', block: 'start' });
}));

dietFilters.forEach(btn => btn.addEventListener('click', () => {
    dietFilters.forEach(x => x.classList.remove('active'));
    btn.classList.add('active');
    activeTag = btn.dataset.tag;
    applyFilters();
}));

const obs = new IntersectionObserver(entries => {
    const vis = entries.find(e => e.isIntersecting);
    if (!vis) return;
    const id = vis.target.dataset.section;
    catTabs.forEach(t => t.classList.toggle('active', t.dataset.cat === id));
}, { threshold: 0.3 });
sections.forEach(s => obs.observe(s));

// Scroll indicators for card backs — bidirectional, no flash
(function() {
    document.querySelectorAll('.card-wrap').forEach(wrap => {
        let initialized = false;
        wrap.addEventListener('click', function() {
            if (initialized) return;
            setTimeout(function() {
                const body = wrap.querySelector('.back-body');
                if (!body) return;
                const scroll = body.closest('.back-scroll');
                if (!scroll) return;
                const horiz = scroll.classList.contains('horiz');

                function check() {
                    if (horiz) {
                        const canScroll = body.scrollWidth > body.clientWidth + 4;
                        const atStart = body.scrollLeft < 4;
                        const atEnd   = body.scrollLeft + body.clientWidth >= body.scrollWidth - 4;
                        scroll.classList.toggle('can-right', canScroll && !atEnd);
                        scroll.classList.toggle('can-left',  canScroll && !atStart);
                    } else {
                        const canScroll = body.scrollHeight > body.clientHeight + 4;
                        const atTop    = body.scrollTop < 4;
                        const atBottom = body.scrollTop + body.clientHeight >= body.scrollHeight - 4;
                        scroll.classList.toggle('can-dn', canScroll && !atBottom);
                        scroll.classList.toggle('can-up', canScroll && !atTop);
                    }
                }

                body.addEventListener('scroll', check, { passive: true });
                check();
                initialized = true;
            }, 560);
        });
    });

    // All scroll-cue clicks handled in capture phase to prevent card from unflipping
    document.addEventListener('click', function(e) {
        if (e.target.closest('.scroll-cue-dn')) {
            e.stopPropagation();
            e.target.closest('.back-scroll')?.querySelector('.back-body')?.scrollBy({ top: 120, behavior: 'smooth' });
            return;
        }
        if (e.target.closest('.scroll-cue-up')) {
            e.stopPropagation();
            e.target.closest('.back-scroll')?.querySelector('.back-body')?.scrollBy({ top: -120, behavior: 'smooth' });
            return;
        }
        if (e.target.closest('.scroll-cue-h')) {
            e.stopPropagation();
            e.target.closest('.back-scroll')?.querySelector('.back-body')?.scrollBy({ left: 180, behavior: 'smooth' });
            return;
        }
        if (e.target.closest('.scroll-cue-l')) {
            e.stopPropagation();
            e.target.closest('.back-scroll')?.querySelector('.back-body')?.scrollBy({ left: -180, behavior: 'smooth' });
        }
    }, true);
})();

// Lightbox — global functions called via inline onclick attributes
function lbOpen(src) {
    var overlay = document.getElementById('lb-overlay');
    var img = document.getElementById('lb-img');
    if (!overlay || !img || !src) return;
    img.src = src;
    overlay.classList.add('open');
    overlay.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
}
function lbClose() {
    var overlay = document.getElementById('lb-overlay');
    if (!overlay) return;
    overlay.classList.remove('open');
    overlay.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
}
document.addEventListener('keydown', function(e) { if (e.key === 'Escape') lbClose(); });
</script>
