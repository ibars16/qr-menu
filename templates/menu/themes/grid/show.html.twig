{# Theme: Grid View — 2 columns, big images, light background, flip cards #}
<style>
    :root { --brand: {{ restaurant.primaryColor }}; }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #faf9f7; color: #1a1a1a; min-height: 100vh; }

    .header { position: sticky; top: 0; z-index: 200; background: rgba(250,249,247,0.97); backdrop-filter: blur(12px); border-bottom: 1px solid #ede9e2; padding: 11px 16px; }
    .header-row { display: flex; align-items: center; justify-content: space-between; gap: 10px; }
    .logo-wrap { display: flex; align-items: center; gap: 9px; }
    .logo { width: 34px; height: 34px; border-radius: 9px; background: var(--brand); display: flex; align-items: center; justify-content: center; color: #fff; font-size: 14px; font-weight: 700; flex-shrink: 0; overflow: hidden; }
    .logo img { width: 100%; height: 100%; object-fit: cover; }
    .resto-name { font-size: 14px; font-weight: 700; color: #1a1a1a; }
    .selectors { display: flex; gap: 5px; }
    .sel-wrap { position: relative; }
    .sel-wrap select { appearance: none; background: #fff; border: 1px solid #e5e2dc; color: #666; font-size: 11px; padding: 5px 20px 5px 9px; border-radius: 20px; cursor: pointer; outline: none; }
    .sel-wrap .chev { position: absolute; right: 6px; top: 50%; transform: translateY(-50%); font-size: 8px; color: #bbb; pointer-events: none; }

    .hero { padding: 20px 16px; background: linear-gradient(135deg, var(--brand), color-mix(in srgb, var(--brand) 50%, #000)); }
    .hero-name { font-size: 22px; font-weight: 700; color: #fff; }

    .search-wrap { padding: 12px 16px 0; position: relative; }
    .search-input { width: 100%; background: #fff; border: 1px solid #e5e2dc; color: #333; font-size: 15px; padding: 10px 14px 10px 38px; border-radius: 10px; outline: none; box-shadow: 0 1px 4px rgba(0,0,0,0.05); }
    .search-input::placeholder { color: #bbb; }
    .search-icon { position: absolute; left: 28px; top: 23px; font-size: 15px; color: #bbb; pointer-events: none; }

    .cat-tabs { display: flex; gap: 6px; padding: 10px 16px 0; overflow-x: auto; scrollbar-width: none; }
    .cat-tabs::-webkit-scrollbar { display: none; }
    .cat-tab { font-size: 12px; font-weight: 500; padding: 6px 13px; border-radius: 20px; border: 1px solid #e5e2dc; background: #fff; color: #999; white-space: nowrap; flex-shrink: 0; cursor: pointer; }
    .cat-tab.active { background: var(--brand); border-color: var(--brand); color: #fff; }

    .diet-filters { display: flex; flex-wrap: wrap; gap: 5px; padding: 8px 16px 0; }
    .diet-filter { background: #fff; border: 1px solid #e5e2dc; color: #999; border-radius: 20px; padding: 5px 11px; cursor: pointer; font-size: 11px; }
    .diet-filter.active { background: var(--brand); border-color: var(--brand); color: #fff; }
    .sep { height: 1px; margin: 10px 16px; background: #f0ede8; }

    .content { padding: 0 12px 80px; }
    @media (min-width: 768px) { .content { padding: 0 24px 80px; max-width: 900px; margin: 0 auto; } }

    .cat-section { padding-top: 20px; }
    .cat-title { font-size: 11px; font-weight: 700; color: #bbb; text-transform: uppercase; letter-spacing: 0.12em; margin-bottom: 10px; padding: 0 4px; }

    .cards-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    @media (min-width: 600px) { .cards-grid { grid-template-columns: repeat(3,1fr); } }
    @media (min-width: 900px) { .cards-grid { grid-template-columns: repeat(4,1fr); } }

    /* ── Flip card ── */
    .card-wrap { perspective: 1400px; cursor: pointer; }
    .card { width: 100%; height: 220px; position: relative; transform-style: preserve-3d; transition: transform 0.55s cubic-bezier(0.4,0.2,0.2,1); border-radius: 12px; }
    .card.flipped { transform: rotateY(180deg); }
    .card-front, .card-back { position: absolute; inset: 0; border-radius: 12px; backface-visibility: hidden; -webkit-backface-visibility: hidden; overflow: hidden; }

    /* ── Front ── */
    .card-front { background: #fff; border: 1px solid #f0ede8; display: flex; flex-direction: column; transition: box-shadow 0.15s, transform 0.15s; }
    .card-wrap:hover .card:not(.flipped) .card-front { box-shadow: 0 4px 16px rgba(0,0,0,0.08); transform: translateY(-2px); }
    .front-img { height: 110px; flex-shrink: 0; background: #fff3ee; display: flex; align-items: center; justify-content: center; font-size: 40px; overflow: hidden; position: relative; }
    .front-img img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
    .front-body { flex: 1; padding: 10px 11px; display: flex; flex-direction: column; justify-content: space-between; min-height: 0; }
    .front-name { font-size: 13px; font-weight: 600; color: #1a1a1a; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-bottom: 2px; }
    .front-badges { display: flex; flex-wrap: wrap; gap: 3px; margin-bottom: 3px; }
    .fbadge { font-size: 10px; padding: 1px 6px; border-radius: 20px; background: #f5f2ee; color: #999; }
    .fbadge-hot { background: rgba(193,68,14,0.08); color: var(--brand); }
    .front-bottom { display: flex; align-items: center; justify-content: space-between; }
    .front-price { font-size: 14px; font-weight: 700; color: var(--brand); }
    .flip-hint { font-size: 10px; color: #ccc; display: flex; align-items: center; gap: 2px; }

    /* ── Back ── */
    .card-back { background: #faf9f7; border: 1px solid #ede9e2; transform: rotateY(180deg); display: flex; flex-direction: column; }
    .back-close { position: absolute; top: 8px; right: 8px; width: 24px; height: 24px; border-radius: 50%; background: #f0ede8; border: 1px solid #e5e2dc; cursor: pointer; color: #aaa; display: flex; align-items: center; justify-content: center; font-size: 11px; z-index: 2; transition: color 0.15s, background 0.15s; }
    .back-close:hover { color: #555; background: #e5e2dc; }
    .back-header { padding: 10px 36px 8px 12px; border-bottom: 1px solid #ede9e2; flex-shrink: 0; }
    .back-name  { font-size: 13px; font-weight: 600; color: #1a1a1a; line-height: 1.3; }
    .back-price { font-size: 13px; color: var(--brand); font-weight: 700; margin-top: 1px; }
    .back-body  { flex: 1; min-height: 0; overflow-y: auto; padding: 8px 12px 10px; scrollbar-width: none; display: flex; flex-direction: column; gap: 6px; }
    .back-body::-webkit-scrollbar { display: none; }
    .bsec-title { font-size: 9px; font-weight: 600; color: #bbb; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 2px; }
    .back-desc  { font-size: 11px; color: #777; line-height: 1.5; }
    .ing-list   { display: flex; flex-wrap: wrap; gap: 3px; }
    .ing        { font-size: 10px; padding: 1px 6px; border-radius: 20px; background: #f0ede8; color: #999; }
    .lbl-list   { display: flex; flex-wrap: wrap; gap: 3px; }
    .lbl        { font-size: 10px; padding: 1px 6px; border-radius: 20px; }
    .lbl-g      { background: rgba(59,109,17,0.1); color: #5a8f1e; border: 1px solid rgba(99,153,34,0.15); }
    .lbl-o      { background: rgba(193,68,14,0.08); color: var(--brand); border: 1px solid rgba(193,68,14,0.15); }
    .nut        { background: #f0ede8; border-radius: 6px; padding: 4px 8px; display: inline-flex; align-items: baseline; gap: 3px; }
    .nut-v      { font-size: 13px; font-weight: 600; color: #555; }
    .nut-u      { font-size: 10px; color: #aaa; }
    .spicy-row  { display: flex; align-items: center; gap: 3px; }
    .dot        { width: 7px; height: 7px; border-radius: 50%; background: #e5e2dc; }
    .dot.on     { background: #D85A30; }
    .spicy-txt  { font-size: 11px; color: #aaa; margin-left: 3px; }

    .no-results { text-align: center; padding: 60px 20px; color: #ccc; font-size: 15px; display: none; }
    .empty { text-align: center; padding: 80px 20px; color: #ccc; font-size: 15px; }
</style>

<header class="header">
    <div class="header-row">
        <div class="logo-wrap">
            <div class="logo">{% if restaurant.logo %}<img src="{{ asset('uploads/logos/' ~ restaurant.logo) }}" alt="">{% else %}{{ restaurant.name|slice(0,1)|upper }}{% endif %}</div>
            <div><div class="resto-name">{{ restaurant.name }}</div></div>
        </div>
        <div class="selectors">
            <div class="sel-wrap"><select onchange="changeLanguage(this.value)">{% for code, lang in languages %}<option value="{{ code }}" {{ locale == code ? 'selected' : '' }}>{{ lang.flag }} {{ code|upper }}</option>{% endfor %}</select><span class="chev">▾</span></div>
            <div class="sel-wrap"><select onchange="changeCurrency(this.value)">{% for code, curr in currencies %}<option value="{{ code }}" {{ currency == code ? 'selected' : '' }}>{{ curr.symbol }} {{ code }}</option>{% endfor %}</select><span class="chev">▾</span></div>
        </div>
    </div>
</header>

<div class="hero"><div class="hero-name">{{ restaurant.name }}</div></div>

<div class="search-wrap"><i class="ti ti-search search-icon" aria-hidden="true"></i><input type="text" class="search-input" id="menu-search" placeholder="Buscar…" autocomplete="off"></div>

{% if tags|length > 0 %}<div class="diet-filters"><button class="diet-filter active" data-tag="all">Todo</button>{% for tag in tags %}{% set tagT = null %}{% for tr in tag.translations %}{% if tr.locale == locale %}{% set tagT = tr %}{% endif %}{% endfor %}{% if tagT %}<button class="diet-filter" data-tag="{{ tag.id }}">{{ tag.icon }} {{ tagT.name }}</button>{% endif %}{% endfor %}</div><div class="sep"></div>{% endif %}

<div class="cat-tabs" id="cat-tabs"><span class="cat-tab active" data-cat="all">Todo</span>{% for category in categories %}{% set t = category.getTranslation(locale) %}{% if t %}<span class="cat-tab" data-cat="cat-{{ category.id }}">{{ t.name }}</span>{% endif %}{% endfor %}</div>

<div class="content">
    <div class="no-results" id="no-results">No se encontraron platos</div>
    {% for category in categories %}
        {% set catT = category.getTranslation(locale) %}
        {% if catT and category.activeProductsSorted|length > 0 %}
            <section class="cat-section" id="cat-{{ category.id }}" data-section="cat-{{ category.id }}">
                <div class="cat-title">{{ catT.name }}</div>
                <div class="cards-grid">
                    {% for product in category.activeProductsSorted %}
                        {% set pT = product.getTranslation(locale) %}
                        {% if not pT %}{% set pT = product.getTranslation(restaurant.defaultLanguage) %}{% endif %}
                        {% if not pT %}{% set pT = product.translations.first %}{% endif %}
                        {% if pT %}
                            <div class="card-wrap"
                                 onclick="flipCard(this)"
                                 data-tags="{% for tag in product.tags %}{{ tag.id }} {% endfor %}">
                                <div class="card">
                                    {# Front #}
                                    <div class="card-front">
                                        <div class="front-img">
                                            {% if product.image %}<img src="{{ asset('uploads/products/' ~ product.image) }}" alt="{{ pT.name }}" loading="lazy">{% else %}🍽️{% endif %}
                                        </div>
                                        <div class="front-body">
                                            <div>
                                                <div class="front-name">{{ pT.name }}</div>
                                                <div class="front-badges">
                                                    {% if product.spicyLevel > 0 %}<span class="fbadge fbadge-hot">{% for i in 1..product.spicyLevel %}🌶{% endfor %}</span>{% endif %}
                                                    {% for tag in product.tags %}{% set tagT = null %}{% for tr in tag.translations %}{% if tr.locale == locale %}{% set tagT = tr %}{% endif %}{% endfor %}{% if tagT %}<span class="fbadge">{{ tag.icon }}</span>{% endif %}{% endfor %}
                                                </div>
                                            </div>
                                            <div class="front-bottom">
                                                <div class="front-price">{{ (product.convertedPrice / 100)|number_format(2) }} {{ currency }}</div>
                                                <div class="flip-hint"><i class="ti ti-rotate-clockwise" style="font-size:11px" aria-hidden="true"></i> ver</div>
                                            </div>
                                        </div>
                                    </div>
                                    {# Back #}
                                    <div class="card-back">
                                        <button class="back-close" onclick="unflipCard(event, this)" aria-label="Volver">
                                            <i class="ti ti-x" aria-hidden="true"></i>
                                        </button>
                                        <div class="back-header">
                                            <div class="back-name">{{ pT.name }}</div>
                                            <div class="back-price">{{ (product.convertedPrice / 100)|number_format(2) }} {{ currency }}</div>
                                        </div>
                                        <div class="back-body">
                                            {% if pT.description %}<div><div class="bsec-title">Descripción</div><div class="back-desc">{{ pT.description }}</div></div>{% endif %}
                                            {% if product.spicyLevel > 0 %}
                                                <div>
                                                    <div class="bsec-title">Picante</div>
                                                    <div class="spicy-row">{% for i in 1..5 %}<div class="dot {{ i <= product.spicyLevel ? 'on' : '' }}"></div>{% endfor %}<span class="spicy-txt">{% if product.spicyLevel == 1 %}Suave{% elseif product.spicyLevel == 2 %}Medio{% elseif product.spicyLevel == 3 %}Picante{% elseif product.spicyLevel == 4 %}Muy picante{% else %}Extremo{% endif %}</span></div>
                                                </div>
                                            {% endif %}
                                            {% if product.tags|length > 0 %}
                                                <div>
                                                    <div class="bsec-title">Etiquetas</div>
                                                    <div class="lbl-list">{% for tag in product.tags %}{% set tagT = null %}{% for tr in tag.translations %}{% if tr.locale == locale %}{% set tagT = tr %}{% endif %}{% endfor %}{% if tagT %}<div class="lbl lbl-g">{{ tag.icon }} {{ tagT.name }}</div>{% endif %}{% endfor %}</div>
                                                </div>
                                            {% endif %}
                                            {% if product.ingredients|length > 0 %}
                                                <div>
                                                    <div class="bsec-title">Ingredientes</div>
                                                    <div class="ing-list">{% for ingredient in product.ingredients %}{% set ingT = ingredient.getTranslation(locale) %}{% if not ingT %}{% set ingT = ingredient.getTranslation(restaurant.defaultLanguage) %}{% endif %}{% if ingT %}<div class="ing">{{ ingT.name }}</div>{% endif %}{% endfor %}</div>
                                                </div>
                                            {% endif %}
                                            {% if product.calories %}
                                                <div><div class="bsec-title">Calorías</div><div class="nut"><span class="nut-v">{{ product.calories }}</span> <span class="nut-u">kcal</span></div></div>
                                            {% endif %}
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% endif %}
                    {% endfor %}
                </div>
            </section>
        {% endif %}
    {% else %}
        <div class="empty">No hay productos disponibles.</div>
    {% endfor %}
</div>

{% include 'menu/_search_js.html.twig' %}
