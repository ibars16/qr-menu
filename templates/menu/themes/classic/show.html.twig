{# Theme: Classic — dark background, horizontal flip cards, original design #}
{% set restaurant = restaurant %}
<style>
    :root { --brand: {{ restaurant.primaryColor }}; }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #0a0a0a; color: #fff; min-height: 100vh; }

    /* ── Header ── */
    .header { position: sticky; top: 0; z-index: 200; background: rgba(10,10,10,0.97); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border-bottom: 1px solid #1c1c1c; padding: 12px 18px; }
    .header-row { display: flex; align-items: center; justify-content: space-between; gap: 12px; }
    .logo-wrap { display: flex; align-items: center; gap: 10px; }
    .logo { width: 38px; height: 38px; border-radius: 10px; background: var(--brand); display: flex; align-items: center; justify-content: center; color: #fff; font-size: 16px; font-weight: 700; flex-shrink: 0; overflow: hidden; }
    .logo img { width: 100%; height: 100%; object-fit: cover; }
    .resto-name  { font-size: 16px; font-weight: 600; color: #fff; letter-spacing: -0.3px; }

    .header-actions { display: flex; align-items: center; gap: 8px; }
    .selector { position: relative; display: inline-flex; align-items: center; }
    .selector select { appearance: none; -webkit-appearance: none; background: #181818; border: 1px solid #2a2a2a; color: #ccc; font-size: 12px; padding: 7px 24px 7px 10px; border-radius: 20px; cursor: pointer; outline: none; transition: border-color 0.15s; }
    .selector select:hover { border-color: #444; }
    .selector .chevron { position: absolute; right: 8px; top: 50%; transform: translateY(-50%); font-size: 10px; color: #555; pointer-events: none; }

    /* ── Hero ── */
    .hero { width: 100%; height: 160px; position: relative; background: linear-gradient(160deg, #1a0905, #2d1108); overflow: hidden; display: flex; align-items: flex-end; padding: 16px 18px; }
    .hero img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0.5; }
    .hero-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(10,10,10,0.9) 0%, rgba(10,10,10,0.2) 100%); }
    .hero-tagline { font-size: 14px; color: #777; line-height: 1.4; position: relative; z-index: 1; }
    @media (min-width: 768px) { .hero { height: 220px; } }

    /* ── Search ── */
    .search-bar { padding: 14px 18px 0; position: relative; }
    .search-bar input { width: 100%; background: #161616; border: 1px solid #242424; color: #ccc; font-size: 15px; padding: 12px 14px 12px 44px; border-radius: 12px; outline: none; transition: border-color 0.15s; }
    .search-bar input::placeholder { color: #444; }
    .search-bar input:focus { border-color: #444; }
    .search-icon { position: absolute; left: 30px; top: 26px; font-size: 18px; color: #444; pointer-events: none; }

    /* ── Diet filters ── */
    .diet-filters { display: flex; flex-wrap: wrap; gap: 8px; padding: 12px 18px 0; max-height: 92px; overflow-y: auto; scrollbar-width: none; }
    .diet-filters::-webkit-scrollbar { display: none; }
    .diet-filter { background: #141414; border: 1px solid #252525; color: #888; border-radius: 20px; padding: 8px 14px; cursor: pointer; white-space: nowrap; font-size: 13px; }
    .diet-filter.active { background: var(--brand); border-color: var(--brand); color: #fff; }
    .menu-separator { height: 1px; margin: 12px 18px; background: linear-gradient(90deg, transparent, #2a2a2a, transparent); opacity: 0.8; }

    /* ── Category tabs ── */
    .cat-tabs { display: flex; gap: 8px; padding: 12px 18px 0; overflow-x: auto; scrollbar-width: none; }
    .cat-tabs::-webkit-scrollbar { display: none; }
    .cat-tab { font-size: 13px; font-weight: 500; padding: 8px 16px; border-radius: 20px; border: 1px solid #252525; color: #555; background: #141414; white-space: nowrap; flex-shrink: 0; cursor: pointer; transition: all 0.15s; }
    .cat-tab:hover { color: #aaa; border-color: #3a3a3a; }
    .cat-tab.active { background: var(--brand); border-color: var(--brand); color: #fff; }

    /* ── Content ── */
    .content { padding: 0 18px 80px; }
    @media (min-width: 768px)  { .content { padding: 0 32px 80px; } }
    @media (min-width: 1100px) { .content { padding: 0 60px 80px; max-width: 1400px; margin: 0 auto; } }

    .cat-section { padding-top: 28px; }
    .cat-title { font-size: 11px; font-weight: 600; color: #2a2a2a; text-transform: uppercase; letter-spacing: 0.12em; margin-bottom: 16px; padding-bottom: 10px; border-bottom: 1px solid #181818; }
    .no-results { display: none; text-align: center; padding: 60px 20px; color: #333; font-size: 15px; }

    /* ── Cards grid ── */
    .cards-grid { display: grid; grid-template-columns: 1fr; gap: 14px; }
    @media (min-width: 768px)  { .cards-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 16px; } }
    @media (min-width: 1200px) { .cards-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 18px; } }

    /* ── Flip card ── */
    .card-wrap { perspective: 1200px; cursor: pointer; }
    .card { width: 100%; height: 200px; position: relative; transform-style: preserve-3d; transition: transform 0.55s cubic-bezier(0.4, 0.2, 0.2, 1); border-radius: 16px; }
    @media (min-width: 768px) { .card { height: 220px; } }
    .card.flipped { transform: rotateY(180deg); }
    .card-front, .card-back { position: absolute; inset: 0; border-radius: 16px; backface-visibility: hidden; -webkit-backface-visibility: hidden; overflow: hidden; }

    /* ── Front ── */
    .card-front { background: #161616; border: 1px solid #242424; display: flex; flex-direction: row; }
    .card-front::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: linear-gradient(90deg, transparent, var(--brand) 40%, transparent); opacity: 0.6; border-radius: 16px 16px 0 0; }
    .front-img { width: 155px; flex-shrink: 0; background: #1c1c1c; display: flex; align-items: center; justify-content: center; font-size: 56px; position: relative; overflow: hidden; }
    .front-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .front-img-glow { position: absolute; inset: 0; background: radial-gradient(circle at 50% 60%, rgba(193,68,14,0.15) 0%, transparent 70%); pointer-events: none; }
    @media (min-width: 768px) { .front-img { width: 180px; } }
    .front-info { flex: 1; padding: 16px 14px; display: flex; flex-direction: column; justify-content: space-between; min-width: 0; }
    .front-badges { display: flex; gap: 5px; flex-wrap: wrap; margin-bottom: 8px; }
    .fbadge { font-size: 12px; padding: 3px 9px; border-radius: 20px; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); color: #aaa; }
    .fbadge-hot { color: #F0997B; border-color: rgba(240,153,123,0.3); background: rgba(216,90,48,0.12); }
    .front-name { font-size: 18px; font-weight: 600; color: #fff; letter-spacing: -0.4px; line-height: 1.2; margin-bottom: 6px; }
    .front-desc { font-size: 13px; color: #555; line-height: 1.45; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .front-bottom { display: flex; align-items: center; justify-content: space-between; margin-top: 12px; }
    .front-price { font-size: 22px; font-weight: 700; color: var(--brand); letter-spacing: -0.5px; }
    .flip-hint { font-size: 11px; color: #333; display: flex; align-items: center; gap: 4px; }

    /* ── Back ── */
    .card-back { background: #131313; transform: rotateY(180deg); border: 1px solid #242424; display: flex; flex-direction: column; }
    .card-back::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: linear-gradient(90deg, transparent, var(--brand) 40%, transparent); opacity: 0.3; border-radius: 16px 16px 0 0; }
    .back-close { position: absolute; top: 12px; right: 12px; width: 26px; height: 26px; border-radius: 50%; background: #1e1e1e; border: 1px solid #2a2a2a; cursor: pointer; color: #666; display: flex; align-items: center; justify-content: center; font-size: 13px; z-index: 2; transition: color 0.15s, background 0.15s; }
    .back-close:hover { color: #fff; background: #2a2a2a; }
    .back-header { padding: 14px 48px 12px 16px; border-bottom: 1px solid #1e1e1e; flex-shrink: 0; }
    .back-name  { font-size: 17px; font-weight: 600; color: #fff; letter-spacing: -0.4px; line-height: 1.2; }
    .back-price { font-size: 15px; color: var(--brand); font-weight: 700; margin-top: 3px; }
    .back-body  { flex: 1; overflow-y: auto; padding: 12px 16px 16px; scrollbar-width: none; display: grid; grid-template-columns: 1fr 1fr; gap: 12px; align-content: start; }
    .back-body::-webkit-scrollbar { display: none; }
    .back-col-full { grid-column: 1 / -1; }
    .bsec-title { font-size: 10px; font-weight: 600; color: #333; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 6px; }
    .back-desc  { font-size: 13px; color: #666; line-height: 1.5; }
    .ing-list   { display: flex; flex-wrap: wrap; gap: 5px; }
    .ing        { font-size: 12px; padding: 3px 9px; border-radius: 20px; background: #1c1c1c; color: #666; border: 1px solid #252525; }
    .lbl-list   { display: flex; flex-wrap: wrap; gap: 5px; }
    .lbl        { font-size: 12px; padding: 3px 9px; border-radius: 20px; }
    .lbl-g      { background: rgba(59,109,17,0.18); color: #7aad40; border: 1px solid rgba(99,153,34,0.2); }
    .lbl-o      { background: rgba(193,68,14,0.14); color: #d06040; border: 1px solid rgba(240,153,123,0.2); }
    .nut        { background: #1a1a1a; border-radius: 8px; padding: 8px 10px; border: 1px solid #222; }
    .nut-l      { font-size: 11px; color: #444; margin-bottom: 3px; }
    .nut-v      { font-size: 17px; font-weight: 600; color: #aaa; letter-spacing: -0.4px; }
    .nut-u      { font-size: 11px; color: #444; font-weight: 400; }
    .spicy-row  { display: flex; align-items: center; gap: 5px; }
    .dot        { width: 9px; height: 9px; border-radius: 50%; background: #222; }
    .dot.on     { background: #D85A30; }
    .spicy-txt  { font-size: 12px; color: #666; margin-left: 4px; }
    .empty      { text-align: center; padding: 80px 20px; color: #2a2a2a; font-size: 15px; }
</style>

{# ── Header ── #}
<header class="header">
    <div class="header-row">
        <div class="logo-wrap">
            <div class="logo">
                {% if restaurant.logo %}
                    <img src="{{ asset('uploads/logos/' ~ restaurant.logo) }}" alt="{{ restaurant.name }}">
                {% else %}
                    {{ restaurant.name|slice(0,1)|upper }}
                {% endif %}
            </div>
            <div>
                <div class="resto-name">{{ restaurant.name }}</div>
            </div>
        </div>
        <div class="header-actions">
            <div class="selector">
                <select onchange="changeLanguage(this.value)" aria-label="Idioma">
                    {% for code, language in languages %}
                        <option value="{{ code }}" {{ locale == code ? 'selected' : '' }}>{{ language.flag }} {{ language.name }}</option>
                    {% endfor %}
                </select>
                <span class="chevron">▾</span>
            </div>
            <div class="selector">
                <select onchange="changeCurrency(this.value)" aria-label="Moneda">
                    {% for code, currencyData in currencies %}
                        <option value="{{ code }}" {{ currency == code ? 'selected' : '' }}>{{ currencyData.symbol }} {{ code }}</option>
                    {% endfor %}
                </select>
                <span class="chevron">▾</span>
            </div>
        </div>
    </div>
</header>

{# ── Hero ── #}
<div class="hero">
    {% if restaurant.logo %}
        <img src="{{ asset('uploads/banners/' ~ restaurant.logo) }}" alt="{{ restaurant.name }}">
    {% endif %}
    <div class="hero-overlay"></div>
    <div class="hero-tagline">{{ restaurant.name }}</div>
</div>

{# ── Search ── #}
<div class="search-bar">
    <i class="ti ti-search search-icon" aria-hidden="true"></i>
    <input type="text" id="menu-search" placeholder="Buscar en el menú..." autocomplete="off" aria-label="Buscar platos">
</div>

{# ── Diet filters ── #}
{% if tags|length > 0 %}
    <div class="diet-filters">
        <button class="diet-filter active" data-tag="all">Todo</button>
        {% for tag in tags %}
            {% set tagT = null %}
            {% for tr in tag.translations %}{% if tr.locale == locale %}{% set tagT = tr %}{% endif %}{% endfor %}
            {% if tagT %}
                <button class="diet-filter" data-tag="{{ tag.id }}">{{ tag.icon }} {{ tagT.name }}</button>
            {% endif %}
        {% endfor %}
    </div>
    <div class="menu-separator"></div>
{% endif %}

{# ── Category tabs ── #}
<div class="cat-tabs" id="cat-tabs">
    <span class="cat-tab active" data-cat="all">Todo</span>
    {% for category in categories %}
        {% set t = category.getTranslation(locale) %}
        {% if t %}<span class="cat-tab" data-cat="cat-{{ category.id }}">{{ t.name }}</span>{% endif %}
    {% endfor %}
</div>

{# ── Menu content ── #}
<div class="content">
    <div class="no-results" id="no-results">No se encontraron platos</div>

    {% for category in categories %}
        {% set catT     = category.getTranslation(locale) %}
        {% set products = category.activeProductsSorted %}
        {% if catT and products|length > 0 %}
            <section class="cat-section" id="cat-{{ category.id }}" data-section="cat-{{ category.id }}">
                <div class="cat-title">{{ catT.name }}</div>
                <div class="cards-grid">
                    {% for product in products %}
                        {% set translation = product.getTranslation(locale) %}
                        {% if not translation %}{% set translation = product.getTranslation(restaurant.defaultLanguage) %}{% endif %}
                        {% if not translation %}{% set translation = product.translations.first %}{% endif %}
                        {% if translation %}
                            <div class="card-wrap"
                                 data-tags="{% for tag in product.tags %}{{ tag.id }}{% if not loop.last %} {% endif %}{% endfor %}"
                                 onclick="flipCard(this)">
                                <div class="card">
                                    {# Front #}
                                    <div class="card-front">
                                        <div class="front-img">
                                            {% if product.image %}
                                                <img src="{{ asset('uploads/products/' ~ product.image) }}" alt="{{ translation.name }}" loading="lazy">
                                            {% else %}🍽️{% endif %}
                                            <div class="front-img-glow"></div>
                                        </div>
                                        <div class="front-info">
                                            <div class="front-top">
                                                <div class="front-badges">
                                                    {% if product.spicyLevel > 0 %}
                                                        <div class="fbadge fbadge-hot">
                                                            {% if product.spicyLevel <= 2 %}🌶{% elseif product.spicyLevel <= 4 %}🌶🌶{% else %}🌶🌶🌶{% endif %}
                                                        </div>
                                                    {% endif %}
                                                    {% for tag in product.tags %}
                                                        {% set tagT = null %}
                                                        {% for tr in tag.translations %}{% if tr.locale == locale %}{% set tagT = tr %}{% endif %}{% endfor %}
                                                        {% if tagT %}<div class="fbadge">{{ tag.icon }} {{ tagT.name }}</div>{% endif %}
                                                    {% endfor %}
                                                </div>
                                                <div class="front-name">{{ translation.name }}</div>
                                                {% if translation.description %}<div class="front-desc">{{ translation.description }}</div>{% endif %}
                                            </div>
                                            <div class="front-bottom">
                                                <div class="front-price">{{ (product.convertedPrice / 100)|number_format(2) }} {{ currency }}</div>
                                                <div class="flip-hint"><i class="ti ti-rotate-clockwise" style="font-size:13px" aria-hidden="true"></i> girar</div>
                                            </div>
                                        </div>
                                    </div>
                                    {# Back #}
                                    <div class="card-back">
                                        <button class="back-close" onclick="unflipCard(event, this)" aria-label="Volver">
                                            <i class="ti ti-x" aria-hidden="true"></i>
                                        </button>
                                        <div class="back-header">
                                            <div class="back-name">{{ translation.name }}</div>
                                            <div class="back-price">{{ (product.convertedPrice / 100)|number_format(2) }} {{ currency }}</div>
                                        </div>
                                        <div class="back-body">
                                            {% if translation.description %}
                                                <div class="back-col-full">
                                                    <div class="bsec-title">Descripción</div>
                                                    <div class="back-desc">{{ translation.description }}</div>
                                                </div>
                                            {% endif %}
                                            {% if product.spicyLevel > 0 %}
                                                <div class="back-col-full">
                                                    <div class="bsec-title">Picante</div>
                                                    <div class="spicy-row">
                                                        {% for i in 1..5 %}<div class="dot {{ i <= product.spicyLevel ? 'on' : '' }}"></div>{% endfor %}
                                                        <span class="spicy-txt">
                                                        {% if product.spicyLevel == 1 %}Suave{% elseif product.spicyLevel == 2 %}Medio{% elseif product.spicyLevel == 3 %}Picante{% elseif product.spicyLevel == 4 %}Muy picante{% else %}Extremo{% endif %}
                                                    </span>
                                                    </div>
                                                </div>
                                            {% endif %}
                                            {% if product.tags|length > 0 %}
                                                <div class="back-col-full">
                                                    <div class="bsec-title">Etiquetas</div>
                                                    <div class="lbl-list">
                                                        {% for tag in product.tags %}
                                                            {% set tagT = null %}
                                                            {% for tr in tag.translations %}{% if tr.locale == locale %}{% set tagT = tr %}{% endif %}{% endfor %}
                                                            {% if tagT %}<div class="lbl lbl-g">{{ tag.icon }} {{ tagT.name }}</div>{% endif %}
                                                        {% endfor %}
                                                    </div>
                                                </div>
                                            {% endif %}
                                            {% if product.ingredients|length > 0 %}
                                                <div class="back-col-full">
                                                    <div class="bsec-title">Ingredientes</div>
                                                    <div class="ing-list">
                                                        {% for ingredient in product.ingredients %}
                                                            {% set ingT = ingredient.getTranslation(locale) %}
                                                            {% if not ingT %}{% set ingT = ingredient.getTranslation(restaurant.defaultLanguage) %}{% endif %}
                                                            {% if ingT %}<div class="ing">{{ ingT.name }}</div>{% endif %}
                                                        {% endfor %}
                                                    </div>
                                                </div>
                                            {% endif %}
                                            {% if product.calories %}
                                                <div>
                                                    <div class="bsec-title">Calorías</div>
                                                    <div class="nut">
                                                        <div class="nut-l">Energía</div>
                                                        <div class="nut-v">{{ product.calories }} <span class="nut-u">kcal</span></div>
                                                    </div>
                                                </div>
                                            {% endif %}
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% endif %}
                    {% endfor %}
                </div>
            </section>
        {% endif %}
    {% else %}
        <div class="empty">No hay productos disponibles.</div>
    {% endfor %}
</div>

<script>
    function changeLanguage(lang) { const u = new URL(window.location); u.searchParams.set('lang', lang); window.location.href = u.toString(); }
    function changeCurrency(c)    { const u = new URL(window.location); u.searchParams.set('currency', c); window.location.href = u.toString(); }
    function flipCard(wrap)        { wrap.querySelector('.card').classList.toggle('flipped'); }
    function unflipCard(e, btn)    { e.stopPropagation(); btn.closest('.card').classList.remove('flipped'); }

    const searchInput = document.getElementById('menu-search');
    const noResults   = document.getElementById('no-results');
    const sections    = document.querySelectorAll('.cat-section');
    const catTabs     = document.querySelectorAll('.cat-tab');
    const dietFilters = document.querySelectorAll('.diet-filter');
    let activeTag = 'all';

    function applyFilters() {
        const q   = searchInput.value.toLowerCase().trim();
        const cat = document.querySelector('.cat-tab.active')?.dataset.cat ?? 'all';
        let anyVisible = false;
        sections.forEach(sec => {
            if (cat !== 'all' && cat !== sec.dataset.section) { sec.style.display = 'none'; return; }
            const cards = sec.querySelectorAll('.card-wrap');
            let secVisible = false;
            cards.forEach(card => {
                const name     = card.querySelector('.front-name').textContent.toLowerCase();
                const tags     = (card.dataset.tags || '').trim().split(/\s+/).filter(Boolean);
                const show     = (!q || name.includes(q)) && (activeTag === 'all' || tags.includes(activeTag));
                card.style.display = show ? '' : 'none';
                if (show) secVisible = true;
            });
            sec.style.display = secVisible ? '' : 'none';
            if (secVisible) anyVisible = true;
        });
        noResults.style.display = anyVisible ? 'none' : 'block';
    }

    searchInput.addEventListener('input', applyFilters);
    catTabs.forEach(tab => tab.addEventListener('click', () => {
        catTabs.forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        applyFilters();
        const cat = tab.dataset.cat;
        if (cat !== 'all') document.getElementById(cat)?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }));
    dietFilters.forEach(btn => btn.addEventListener('click', () => {
        dietFilters.forEach(x => x.classList.remove('active'));
        btn.classList.add('active');
        activeTag = btn.dataset.tag;
        applyFilters();
    }));

    const scrollObs = new IntersectionObserver(entries => {
        const vis = entries.find(e => e.isIntersecting);
        if (!vis) return;
        const id = vis.target.dataset.section;
        catTabs.forEach(t => t.classList.toggle('active', t.dataset.cat === id));
    }, { threshold: 0.35 });
    sections.forEach(s => scrollObs.observe(s));
</script>
