{# Theme: Glassmorphism — dark purple accent, card grid #}
<style>
    :root { --brand: {{ restaurant.primaryColor }}; --accent: #a78bfa; }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: linear-gradient(160deg,#120820,#0a1528); color: #fff; min-height: 100vh; }

    .header { position: sticky; top: 0; z-index: 200; background: rgba(18,8,32,0.9); backdrop-filter: blur(16px); border-bottom: 1px solid rgba(255,255,255,0.08); padding: 12px 18px; }
    .header-row { display: flex; align-items: center; justify-content: space-between; gap: 10px; }
    .logo-wrap { display: flex; align-items: center; gap: 10px; }
    .logo { width: 36px; height: 36px; border-radius: 10px; background: var(--accent); display: flex; align-items: center; justify-content: center; color: #fff; font-size: 15px; font-weight: 700; flex-shrink: 0; overflow: hidden; }
    .logo img { width: 100%; height: 100%; object-fit: cover; }
    .resto-name  { font-size: 15px; font-weight: 700; color: #fff; }
    .selectors { display: flex; gap: 6px; }
    .sel-wrap { position: relative; }
    .sel-wrap select { appearance: none; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15); color: #ccc; font-size: 12px; padding: 6px 22px 6px 10px; border-radius: 20px; cursor: pointer; outline: none; }
    .sel-wrap .chev { position: absolute; right: 7px; top: 50%; transform: translateY(-50%); font-size: 9px; color: #666; pointer-events: none; }

    .hero { padding: 28px 18px; background: linear-gradient(135deg, rgba(167,139,250,0.15), rgba(83,74,183,0.1)); border-bottom: 1px solid rgba(255,255,255,0.06); }
    .hero-name  { font-size: 24px; font-weight: 700; color: #fff; letter-spacing: -0.5px; }

    .search-wrap { padding: 14px 18px 0; position: relative; }
    .search-input { width: 100%; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.12); color: #fff; font-size: 15px; padding: 11px 14px 11px 40px; border-radius: 12px; outline: none; }
    .search-input::placeholder { color: rgba(255,255,255,0.25); }
    .search-icon { position: absolute; left: 30px; top: 25px; font-size: 16px; color: rgba(255,255,255,0.25); pointer-events: none; }

    .cat-tabs { display: flex; gap: 6px; padding: 12px 18px 0; overflow-x: auto; scrollbar-width: none; }
    .cat-tabs::-webkit-scrollbar { display: none; }
    .cat-tab { font-size: 13px; padding: 7px 14px; border-radius: 20px; border: 1px solid rgba(255,255,255,0.12); background: rgba(255,255,255,0.05); color: rgba(255,255,255,0.45); white-space: nowrap; flex-shrink: 0; cursor: pointer; }
    .cat-tab.active { background: var(--accent); border-color: var(--accent); color: #fff; }

    .diet-filters { display: flex; flex-wrap: wrap; gap: 6px; padding: 10px 18px 0; }
    .diet-filter { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); color: rgba(255,255,255,0.45); border-radius: 20px; padding: 6px 12px; cursor: pointer; font-size: 12px; }
    .diet-filter.active { background: var(--accent); border-color: var(--accent); color: #fff; }
    .sep { height: 1px; margin: 12px 18px; background: rgba(255,255,255,0.06); }

    .content { padding: 0 14px 80px; }
    @media (min-width: 768px) { .content { padding: 0 24px 80px; max-width: 900px; margin: 0 auto; } }

    .cat-section { padding-top: 24px; }
    .cat-title { font-size: 11px; font-weight: 600; color: rgba(255,255,255,0.25); text-transform: uppercase; letter-spacing: 0.12em; margin-bottom: 12px; }

    .cards-grid { display: grid; grid-template-columns: 1fr; gap: 12px; }
    @media (min-width: 480px) { .cards-grid { grid-template-columns: repeat(2,1fr); } }
    @media (min-width: 900px) { .cards-grid { grid-template-columns: repeat(3,1fr); } }

    .card { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 14px; overflow: hidden; cursor: pointer; transition: transform 0.15s, border-color 0.15s; }
    .card:hover { transform: translateY(-2px); border-color: rgba(167,139,250,0.3); }
    .card-img { height: 140px; background: rgba(255,255,255,0.04); display: flex; align-items: center; justify-content: center; font-size: 48px; overflow: hidden; position: relative; }
    .card-img img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
    .card-img-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(18,8,32,0.8) 0%, transparent 60%); }
    .card-body { padding: 12px 14px; }
    .card-name  { font-size: 15px; font-weight: 600; color: #fff; margin-bottom: 4px; }
    .card-desc  { font-size: 12px; color: rgba(255,255,255,0.45); line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; margin-bottom: 10px; }
    .card-footer { display: flex; align-items: center; justify-content: space-between; }
    .card-price { font-size: 16px; font-weight: 700; color: var(--accent); }
    .card-more  { font-size: 11px; color: rgba(255,255,255,0.3); }

    .no-results { text-align: center; padding: 60px 20px; color: rgba(255,255,255,0.2); font-size: 15px; display: none; }
</style>

<header class="header">
    <div class="header-row">
        <div class="logo-wrap">
            <div class="logo">
                {% if restaurant.logo %}<img src="{{ asset('uploads/logos/' ~ restaurant.logo) }}" alt="">{% else %}{{ restaurant.name|slice(0,1)|upper }}{% endif %}
            </div>
            <div>
                <div class="resto-name">{{ restaurant.name }}</div>
            </div>
        </div>
        <div class="selectors">
            <div class="sel-wrap"><select onchange="changeLanguage(this.value)">{% for code, lang in languages %}<option value="{{ code }}" {{ locale == code ? 'selected' : '' }}>{{ lang.flag }} {{ code|upper }}</option>{% endfor %}</select><span class="chev">▾</span></div>
            <div class="sel-wrap"><select onchange="changeCurrency(this.value)">{% for code, curr in currencies %}<option value="{{ code }}" {{ currency == code ? 'selected' : '' }}>{{ curr.symbol }} {{ code }}</option>{% endfor %}</select><span class="chev">▾</span></div>
        </div>
    </div>
</header>

<div class="hero">
    <div class="hero-name">{{ restaurant.name }}</div>
</div>

<div class="search-wrap">
    <i class="ti ti-search search-icon" aria-hidden="true"></i>
    <input type="text" class="search-input" id="menu-search" placeholder="Buscar en el menú…" autocomplete="off">
</div>

{% if tags|length > 0 %}
    <div class="diet-filters">
        <button class="diet-filter active" data-tag="all">Todo</button>
        {% for tag in tags %}{% set tagT = null %}{% for tr in tag.translations %}{% if tr.locale == locale %}{% set tagT = tr %}{% endif %}{% endfor %}{% if tagT %}<button class="diet-filter" data-tag="{{ tag.id }}">{{ tag.icon }} {{ tagT.name }}</button>{% endif %}{% endfor %}
    </div>
    <div class="sep"></div>
{% endif %}

<div class="cat-tabs" id="cat-tabs">
    <span class="cat-tab active" data-cat="all">Todo</span>
    {% for category in categories %}{% set t = category.getTranslation(locale) %}{% if t %}<span class="cat-tab" data-cat="cat-{{ category.id }}">{{ t.name }}</span>{% endif %}{% endfor %}
</div>

<div class="content">
    <div class="no-results" id="no-results">No se encontraron platos</div>
    {% for category in categories %}
        {% set catT = category.getTranslation(locale) %}
        {% if catT and category.activeProductsSorted|length > 0 %}
            <section class="cat-section" id="cat-{{ category.id }}" data-section="cat-{{ category.id }}">
                <div class="cat-title">{{ catT.name }}</div>
                <div class="cards-grid">
                    {% for product in category.activeProductsSorted %}
                        {% set pT = product.getTranslation(locale) %}{% if not pT %}{% set pT = product.getTranslation(restaurant.defaultLanguage) %}{% endif %}{% if not pT %}{% set pT = product.translations.first %}{% endif %}
                        {% if pT %}
                            <div class="card" data-tags="{% for tag in product.tags %}{{ tag.id }} {% endfor %}">
                                <div class="card-img">
                                    {% if product.image %}<img src="{{ asset('uploads/products/' ~ product.image) }}" alt="{{ pT.name }}">{% else %}🍽️{% endif %}
                                    <div class="card-img-overlay"></div>
                                </div>
                                <div class="card-body">
                                    <div class="card-name">{{ pT.name }}</div>
                                    {% if pT.description %}<div class="card-desc">{{ pT.description }}</div>{% endif %}
                                    <div class="card-footer">
                                        <div class="card-price">{{ (product.convertedPrice / 100)|number_format(2) }} {{ currency }}</div>
                                        <div class="card-more">ver más ›</div>
                                    </div>
                                </div>
                            </div>
                        {% endif %}
                    {% endfor %}
                </div>
            </section>
        {% endif %}
    {% endfor %}
</div>

{% include 'menu/_search_js.html.twig' %}
