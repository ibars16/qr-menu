{# Theme: Glassmorphism — dark purple accent, flip cards #}
<style>
    :root { --brand: {{ restaurant.primaryColor }}; --accent: #a78bfa; --accent-dim: rgba(167,139,250,0.35); --back-bg: rgba(10,6,26,0.98); }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: linear-gradient(160deg,#120820 0%,#0a1528 60%,#0d1220 100%); background-attachment: fixed; color: #fff; min-height: 100vh; -webkit-font-smoothing: antialiased; }

    /* ── Header ── */
    .header { position: sticky; top: 0; z-index: 200; background: rgba(18,8,32,0.88); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border-bottom: 1px solid rgba(255,255,255,0.07); padding: 11px 18px; }
    .header-row { display: flex; align-items: center; justify-content: space-between; gap: 10px; max-width: 900px; margin: 0 auto; }
    .logo-wrap { display: flex; align-items: center; gap: 10px; }
    .logo { width: 34px; height: 34px; border-radius: 9px; background: linear-gradient(135deg,var(--accent),#7c3aed); display: flex; align-items: center; justify-content: center; color: #fff; font-size: 14px; font-weight: 700; flex-shrink: 0; overflow: hidden; box-shadow: 0 2px 8px rgba(167,139,250,0.35); }
    .logo img { width: 100%; height: 100%; object-fit: cover; }
    .resto-name { font-size: 15px; font-weight: 700; color: #fff; letter-spacing: -0.2px; }
    .selectors { display: flex; gap: 6px; }
    .sel-wrap { position: relative; }
    .sel-wrap select { appearance: none; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.13); color: #ccc; font-size: 12px; padding: 6px 22px 6px 10px; border-radius: 20px; cursor: pointer; outline: none; transition: border-color 0.15s; }
    .sel-wrap select:hover { border-color: rgba(255,255,255,0.22); }
    .sel-wrap .chev { position: absolute; right: 7px; top: 50%; transform: translateY(-50%); font-size: 9px; color: #666; pointer-events: none; }

    /* ── Hero ── */
    .hero { padding: 32px 18px 28px; background: linear-gradient(135deg, rgba(167,139,250,0.18) 0%, rgba(83,74,183,0.12) 50%, rgba(10,8,32,0) 100%); border-bottom: 1px solid rgba(255,255,255,0.06); position: relative; overflow: hidden; }
    .hero::before { content: ''; position: absolute; top: -40px; right: -40px; width: 200px; height: 200px; border-radius: 50%; background: radial-gradient(circle, rgba(167,139,250,0.12) 0%, transparent 70%); pointer-events: none; }
    .hero-name { font-size: 26px; font-weight: 800; color: #fff; letter-spacing: -0.6px; }
    .hero-sub  { font-size: 13px; color: rgba(255,255,255,0.35); margin-top: 4px; }

    /* ── Layout container (aligns filters + tabs with card grid) ── */
    .ui-wrap { padding: 0 14px; }
    @media (min-width: 768px) { .ui-wrap { max-width: 900px; margin: 0 auto; padding: 0 24px; } }

    /* ── Search ── */
    .search-wrap { padding-top: 16px; position: relative; }
    .search-input { width: 100%; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.11); color: #fff; font-size: 15px; padding: 11px 14px 11px 42px; border-radius: 12px; outline: none; transition: border-color 0.2s, box-shadow 0.2s; }
    .search-input::placeholder { color: rgba(255,255,255,0.22); }
    .search-input:focus { border-color: var(--accent-dim); box-shadow: 0 0 0 3px rgba(167,139,250,0.12); }
    .search-icon { position: absolute; left: 14px; top: 27px; font-size: 16px; color: rgba(255,255,255,0.22); pointer-events: none; }

    /* ── Diet filters ── */
    .diet-filters { display: flex; flex-wrap: wrap; gap: 6px; padding-top: 12px; }
    .diet-filter { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: rgba(255,255,255,0.4); border-radius: 20px; padding: 6px 13px; cursor: pointer; font-size: 12px; transition: background 0.15s, border-color 0.15s, color 0.15s; }
    .diet-filter:hover { color: rgba(255,255,255,0.7); border-color: rgba(255,255,255,0.2); }
    .diet-filter.active { background: var(--accent); border-color: var(--accent); color: #fff; }
    .sep { height: 1px; margin: 14px 0 0; background: rgba(255,255,255,0.06); }

    /* ── Category tabs ── */
    .cat-tabs { display: flex; gap: 6px; padding-top: 14px; overflow-x: auto; scrollbar-width: none; padding-bottom: 2px; }
    .cat-tabs::-webkit-scrollbar { display: none; }
    .cat-tab { font-size: 13px; font-weight: 500; padding: 7px 16px; border-radius: 20px; border: 1px solid rgba(255,255,255,0.1); background: rgba(255,255,255,0.04); color: rgba(255,255,255,0.4); white-space: nowrap; flex-shrink: 0; cursor: pointer; transition: background 0.2s, border-color 0.2s, color 0.2s; }
    .cat-tab:hover { color: rgba(255,255,255,0.7); border-color: rgba(255,255,255,0.2); }
    .cat-tab.active { background: var(--accent); border-color: var(--accent); color: #fff; box-shadow: 0 2px 12px rgba(167,139,250,0.3); }

    /* ── Content ── */
    .content { padding: 0 14px 100px; }
    @media (min-width: 768px) { .content { padding: 0 24px 100px; max-width: 900px; margin: 0 auto; } }

    .cat-section { padding-top: 28px; }
    .cat-title { font-size: 10px; font-weight: 700; color: rgba(255,255,255,0.2); text-transform: uppercase; letter-spacing: 0.14em; margin-bottom: 14px; }

    .cards-grid { display: grid; grid-template-columns: 1fr; gap: 10px; }
    @media (min-width: 480px) { .cards-grid { grid-template-columns: repeat(2,1fr); } }
    @media (min-width: 900px) { .cards-grid { grid-template-columns: repeat(3,1fr); } }

    /* ── Flip card ── */
    .card-wrap { perspective: 1200px; cursor: pointer; }
    .card { width: 100%; height: 200px; position: relative; transform-style: preserve-3d; transition: transform 0.55s cubic-bezier(0.4,0.2,0.2,1); border-radius: 14px; }
    @media (min-width: 768px) { .card { height: 220px; } }
    @media (min-width: 1100px) { .card { height: 236px; } }
    .card.flipped { transform: rotateY(180deg); }
    .card-front, .card-back { position: absolute; inset: 0; border-radius: 14px; backface-visibility: hidden; -webkit-backface-visibility: hidden; overflow: hidden; }

    /* ── Front ── */
    .card-front { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); display: flex; flex-direction: row; transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s; }
    .card-front::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px; background: linear-gradient(90deg, transparent 0%, rgba(167,139,250,0.5) 40%, transparent 100%); }
    .card-wrap:hover .card:not(.flipped) .card-front { border-color: rgba(167,139,250,0.45); box-shadow: 0 4px 20px rgba(167,139,250,0.12), inset 0 0 0 1px rgba(167,139,250,0.08); transform: translateY(-1px); }

    .front-img { width: 140px; flex-shrink: 0; background: rgba(255,255,255,0.04); display: flex; align-items: center; justify-content: center; font-size: 46px; position: relative; overflow: hidden; }
    .front-img img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
    .front-img-glow { position: absolute; inset: 0; background: radial-gradient(ellipse at 50% 70%, rgba(167,139,250,0.1) 0%, transparent 65%); pointer-events: none; }
    @media (min-width: 768px) { .front-img { width: 160px; } }

    .front-info { flex: 1; padding: 14px 13px; display: flex; flex-direction: column; justify-content: space-between; min-width: 0; }
    .front-badges { display: flex; gap: 4px; flex-wrap: wrap; margin-bottom: 7px; }
    .fbadge { font-size: 11px; padding: 2px 8px; border-radius: 20px; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.09); color: rgba(255,255,255,0.5); }
    .fbadge-hot { color: #F0997B; border-color: rgba(240,153,123,0.22); background: rgba(216,90,48,0.1); }
    .front-name { font-size: 16px; font-weight: 700; color: #fff; letter-spacing: -0.4px; line-height: 1.25; margin-bottom: 5px; }
    .front-desc { font-size: 12px; color: rgba(255,255,255,0.35); line-height: 1.45; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .front-bottom { display: flex; align-items: center; justify-content: space-between; margin-top: auto; padding-top: 10px; }
    .front-price { font-size: 19px; font-weight: 700; color: var(--accent); letter-spacing: -0.4px; font-variant-numeric: tabular-nums; }
    .flip-hint { font-size: 11px; color: rgba(255,255,255,0.18); display: flex; align-items: center; gap: 3px; transition: color 0.15s; }
    .card-wrap:hover .flip-hint { color: rgba(167,139,250,0.5); }

    /* ── Back ── */
    .card-back { background: var(--back-bg); border: 1px solid rgba(167,139,250,0.18); transform: rotateY(180deg); display: flex; flex-direction: column; }
    .card-back::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px; background: linear-gradient(90deg, transparent 0%, rgba(167,139,250,0.4) 40%, transparent 100%); }
    .back-close { position: absolute; top: 10px; right: 10px; width: 26px; height: 26px; border-radius: 50%; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); cursor: pointer; color: rgba(255,255,255,0.35); display: flex; align-items: center; justify-content: center; font-size: 11px; z-index: 2; transition: color 0.15s, background 0.15s; }
    .back-close:hover { color: #fff; background: rgba(255,255,255,0.12); }
    .back-header { padding: 12px 42px 11px 14px; border-bottom: 1px solid rgba(255,255,255,0.06); flex-shrink: 0; }
    .back-name  { font-size: 15px; font-weight: 700; color: #fff; letter-spacing: -0.3px; line-height: 1.2; }
    .back-price { font-size: 13px; color: var(--accent); font-weight: 700; margin-top: 2px; font-variant-numeric: tabular-nums; }

    /* Scroll container with fade indicator */
    .back-scroll { position: relative; flex: 1; min-height: 0; overflow: hidden; }
    .back-scroll::after { content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 32px; background: linear-gradient(transparent, var(--back-bg)); pointer-events: none; transition: opacity 0.25s; }
    .back-scroll.no-fade::after { opacity: 0; }

    .back-body  { height: 100%; overflow-y: auto; padding: 12px 14px 14px; scrollbar-width: none; display: flex; flex-direction: column; gap: 10px; }
    .back-body::-webkit-scrollbar { display: none; }

    .bsec { display: flex; flex-direction: column; gap: 4px; }
    .bsec + .bsec { padding-top: 6px; border-top: 1px solid rgba(255,255,255,0.05); }
    .bsec-title { font-size: 9px; font-weight: 700; color: rgba(255,255,255,0.22); text-transform: uppercase; letter-spacing: 0.1em; }
    .back-desc  { font-size: 12px; color: rgba(255,255,255,0.5); line-height: 1.55; }
    .ing-list   { display: flex; flex-wrap: wrap; gap: 4px; }
    .ing        { font-size: 11px; padding: 2px 8px; border-radius: 20px; background: rgba(255,255,255,0.05); color: rgba(255,255,255,0.38); border: 1px solid rgba(255,255,255,0.09); }
    .lbl-list   { display: flex; flex-wrap: wrap; gap: 4px; }
    .lbl        { font-size: 11px; padding: 2px 8px; border-radius: 20px; }
    .lbl-g      { background: rgba(59,109,17,0.2); color: #7aad40; border: 1px solid rgba(99,153,34,0.18); }
    .lbl-o      { background: rgba(193,68,14,0.14); color: #d06040; border: 1px solid rgba(240,153,123,0.18); }
    .nut        { display: inline-flex; align-items: baseline; gap: 4px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08); border-radius: 8px; padding: 5px 10px; }
    .nut-v      { font-size: 15px; font-weight: 700; color: rgba(255,255,255,0.7); font-variant-numeric: tabular-nums; }
    .nut-u      { font-size: 10px; color: rgba(255,255,255,0.28); }
    .spicy-row  { display: flex; align-items: center; gap: 4px; }
    .dot        { width: 8px; height: 8px; border-radius: 50%; background: rgba(255,255,255,0.1); flex-shrink: 0; }
    .dot.on     { background: #D85A30; }
    .spicy-txt  { font-size: 11px; color: rgba(255,255,255,0.38); margin-left: 4px; }

    .no-results { text-align: center; padding: 60px 20px; color: rgba(255,255,255,0.18); font-size: 15px; display: none; }
    .empty { text-align: center; padding: 80px 20px; color: rgba(255,255,255,0.14); font-size: 15px; }
</style>

<header class="header">
    <div class="header-row">
        <div class="logo-wrap">
            <div class="logo">
                {% if restaurant.logo %}<img src="{{ asset('uploads/logos/' ~ restaurant.logo) }}" alt="">{% else %}{{ restaurant.name|slice(0,1)|upper }}{% endif %}
            </div>
            <div><div class="resto-name">{{ restaurant.name }}</div></div>
        </div>
        <div class="selectors">
            <div class="sel-wrap"><select onchange="changeLanguage(this.value)">{% for code, lang in languages %}<option value="{{ code }}" {{ locale == code ? 'selected' : '' }}>{{ lang.flag }} {{ code|upper }}</option>{% endfor %}</select><span class="chev">▾</span></div>
            <div class="sel-wrap"><select onchange="changeCurrency(this.value)">{% for code, curr in currencies %}<option value="{{ code }}" {{ currency == code ? 'selected' : '' }}>{{ curr.symbol }} {{ code }}</option>{% endfor %}</select><span class="chev">▾</span></div>
        </div>
    </div>
</header>

<div class="hero">
    <div class="hero-name">{{ restaurant.name }}</div>
    <div class="hero-sub">Explora nuestra carta</div>
</div>

<div class="ui-wrap">
    <div class="search-wrap">
        <i class="ti ti-search search-icon" aria-hidden="true"></i>
        <input type="text" class="search-input" id="menu-search" placeholder="Buscar platos…" autocomplete="off" aria-label="Buscar">
    </div>

    {% if tags|length > 0 %}
        <div class="diet-filters">
            <button class="diet-filter active" data-tag="all">Todo</button>
            {% for tag in tags %}{% if tagNames[tag.id] is defined %}<button class="diet-filter" data-tag="{{ tag.id }}">{{ tag.icon }} {{ tagNames[tag.id] }}</button>{% endif %}{% endfor %}
        </div>
        <div class="sep"></div>
    {% endif %}

    <div class="cat-tabs" id="cat-tabs">
        <span class="cat-tab active" data-cat="all">Todo</span>
        {% for category in categories %}{% set t = category.getTranslation(locale) %}{% if t %}<span class="cat-tab" data-cat="cat-{{ category.id }}">{{ t.name }}</span>{% endif %}{% endfor %}
    </div>
</div>

<div class="content">
    <div class="no-results" id="no-results">No se encontraron platos</div>
    {% for category in categories %}
        {% set catT = category.getTranslation(locale) %}
        {% if catT and category.activeProductsSorted|length > 0 %}
            <section class="cat-section" id="cat-{{ category.id }}" data-section="cat-{{ category.id }}">
                <div class="cat-title">{{ catT.name }}</div>
                <div class="cards-grid">
                    {% for product in category.activeProductsSorted %}
                        {% set pT = product.getTranslation(locale) %}
                        {% if not pT %}{% set pT = product.getTranslation(restaurant.defaultLanguage) %}{% endif %}
                        {% if not pT %}{% set pT = product.translations.first %}{% endif %}
                        {% if pT %}
                            <div class="card-wrap" onclick="flipCard(this)"
                                 data-tags="{% for tag in product.tags %}{{ tag.id }} {% endfor %}">
                                <div class="card">
                                    <div class="card-front">
                                        <div class="front-img">
                                            {% if product.image %}<img src="{{ asset('uploads/products/' ~ product.image) }}" alt="{{ pT.name }}" loading="lazy">{% else %}🍽️{% endif %}
                                            <div class="front-img-glow"></div>
                                        </div>
                                        <div class="front-info">
                                            <div>
                                                <div class="front-badges">
                                                    {% if product.spicyLevel > 0 %}<div class="fbadge fbadge-hot">{% if product.spicyLevel <= 2 %}🌶{% elseif product.spicyLevel <= 4 %}🌶🌶{% else %}🌶🌶🌶{% endif %}</div>{% endif %}
                                                    {% for tag in product.tags %}{% if tagNames[tag.id] is defined %}<div class="fbadge">{{ tag.icon }} {{ tagNames[tag.id] }}</div>{% endif %}{% endfor %}
                                                </div>
                                                <div class="front-name">{{ pT.name }}</div>
                                                {% if pT.description %}<div class="front-desc">{{ pT.description }}</div>{% endif %}
                                            </div>
                                            <div class="front-bottom">
                                                <div class="front-price">{{ (product.convertedPrice / 100)|number_format(2) }} {{ currency }}</div>
                                                <div class="flip-hint"><i class="ti ti-rotate-clockwise" style="font-size:12px" aria-hidden="true"></i> girar</div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="card-back">
                                        <button class="back-close" onclick="unflipCard(event, this)" aria-label="Volver">
                                            <i class="ti ti-x" aria-hidden="true"></i>
                                        </button>
                                        <div class="back-header">
                                            <div class="back-name">{{ pT.name }}</div>
                                            <div class="back-price">{{ (product.convertedPrice / 100)|number_format(2) }} {{ currency }}</div>
                                        </div>
                                        <div class="back-scroll">
                                            <div class="back-body">
                                                {% if pT.description %}<div class="bsec"><div class="bsec-title">Descripción</div><div class="back-desc">{{ pT.description }}</div></div>{% endif %}
                                                {% if product.spicyLevel > 0 %}<div class="bsec"><div class="bsec-title">Picante</div><div class="spicy-row">{% for i in 1..5 %}<div class="dot {{ i <= product.spicyLevel ? 'on' : '' }}"></div>{% endfor %}<span class="spicy-txt">{% if product.spicyLevel == 1 %}Suave{% elseif product.spicyLevel == 2 %}Medio{% elseif product.spicyLevel == 3 %}Picante{% elseif product.spicyLevel == 4 %}Muy picante{% else %}Extremo{% endif %}</span></div></div>{% endif %}
                                                {% if product.tags|length > 0 %}<div class="bsec"><div class="bsec-title">Etiquetas</div><div class="lbl-list">{% for tag in product.tags %}{% if tagNames[tag.id] is defined %}<div class="lbl lbl-g">{{ tag.icon }} {{ tagNames[tag.id] }}</div>{% endif %}{% endfor %}</div></div>{% endif %}
                                                {% if product.ingredients|length > 0 %}<div class="bsec"><div class="bsec-title">Ingredientes</div><div class="ing-list">{% for ingredient in product.ingredients %}{% set ingT = ingredient.getTranslation(locale) %}{% if not ingT %}{% set ingT = ingredient.getTranslation(restaurant.defaultLanguage) %}{% endif %}{% if ingT %}<div class="ing">{{ ingT.name }}</div>{% endif %}{% endfor %}</div></div>{% endif %}
                                                {% if product.calories %}<div class="bsec"><div class="bsec-title">Calorías</div><div class="nut"><span class="nut-v">{{ product.calories }}</span><span class="nut-u">kcal</span></div></div>{% endif %}
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% endif %}
                    {% endfor %}
                </div>
            </section>
        {% endif %}
    {% else %}
        <div class="empty">No hay productos disponibles.</div>
    {% endfor %}
</div>

{% include 'menu/_search_js.html.twig' %}
