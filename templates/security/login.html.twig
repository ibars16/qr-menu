{% extends 'base.html.twig' %}

{% block title %}Acceder — QR Menu{% endblock %}

{% block stylesheets %}
    <style>
        :root { --brand: #C1440E; }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: #0a0a0a;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .login-wrap {
            width: 100%;
            max-width: 380px;
        }

        .login-logo {
            text-align: center;
            margin-bottom: 32px;
        }
        .login-logo-mark {
            width: 52px; height: 52px;
            border-radius: 14px;
            background: var(--brand);
            display: inline-flex;
            align-items: center; justify-content: center;
            font-size: 22px; font-weight: 700; color: #fff;
            margin-bottom: 12px;
        }
        .login-logo-name {
            font-size: 20px; font-weight: 600;
            color: #fff; letter-spacing: -0.4px;
        }
        .login-logo-sub {
            font-size: 13px; color: #555; margin-top: 4px;
        }

        .login-card {
            background: #141414;
            border: 1px solid #242424;
            border-radius: 16px;
            padding: 28px 24px;
        }

        .login-title {
            font-size: 17px; font-weight: 600;
            color: #fff; letter-spacing: -0.3px;
            margin-bottom: 6px;
        }
        .login-sub {
            font-size: 13px; color: #555;
            margin-bottom: 24px;
        }

        .field { margin-bottom: 16px; }
        .field label {
            display: block;
            font-size: 12px; font-weight: 500;
            color: #888; text-transform: uppercase;
            letter-spacing: 0.06em; margin-bottom: 6px;
        }
        .field input {
            width: 100%;
            background: #1a1a1a;
            border: 1px solid #2a2a2a;
            color: #fff; font-size: 15px;
            padding: 11px 14px;
            border-radius: 10px; outline: none;
            transition: border-color 0.15s;
        }
        .field input::placeholder { color: #444; }
        .field input:focus { border-color: #555; }

        .remember-row {
            display: flex; align-items: center;
            gap: 8px; margin-bottom: 20px;
        }
        .remember-row input[type="checkbox"] {
            width: 16px; height: 16px;
            accent-color: var(--brand); cursor: pointer;
        }
        .remember-row label {
            font-size: 13px; color: #666; cursor: pointer;
        }

        .login-btn {
            width: 100%; padding: 12px;
            background: var(--brand); color: #fff;
            border: none; border-radius: 10px;
            font-size: 15px; font-weight: 600;
            cursor: pointer; letter-spacing: -0.2px;
            transition: opacity 0.15s;
        }
        .login-btn:hover { opacity: 0.9; }

        .error-msg {
            background: rgba(193, 68, 14, 0.12);
            border: 1px solid rgba(193, 68, 14, 0.3);
            border-radius: 10px;
            padding: 10px 14px;
            font-size: 13px; color: #F0997B;
            margin-bottom: 20px;
            display: flex; align-items: center; gap: 8px;
        }
    </style>
{% endblock %}

{% block body %}
    <div class="login-wrap">

        <div class="login-logo">
            <div class="login-logo-mark">Q</div>
            <div class="login-logo-name">QR Menu</div>
            <div class="login-logo-sub">Panel de administración</div>
        </div>

        <div class="login-card">
            <div class="login-title">Bienvenido</div>
            <div class="login-sub">Accede con tu cuenta de restaurante</div>

            {% if error %}
                <div class="error-msg">
                    <i class="ti ti-alert-circle" style="font-size:16px;flex-shrink:0" aria-hidden="true"></i>
                    {{ error.messageKey|trans(error.messageData, 'security') }}
                </div>
            {% endif %}

            <form method="post">

                <div class="field">
                    <label for="email">Email</label>
                    <input type="email"
                           id="email"
                           name="email"
                           value="{{ last_username }}"
                           placeholder="tu@restaurante.com"
                           autocomplete="email"
                           autofocus
                           required>
                </div>

                <div class="field">
                    <label for="password">Contraseña</label>
                    <input type="password"
                           id="password"
                           name="password"
                           placeholder="••••••••"
                           autocomplete="current-password"
                           required>
                </div>

                <div class="remember-row">
                    <input type="checkbox" id="remember" name="_remember_me">
                    <label for="remember">Mantener sesión iniciada</label>
                </div>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                <button type="submit" class="login-btn">Entrar</button>

            </form>
            <div style="text-align:center;margin-top:16px;font-size:13px;color:#555">
                ¿No tienes cuenta?
                <a href="{{ path('app_register') }}" style="color:#888;text-decoration:none">
                    Regístrate gratis
                </a>
            </div>
        </div>

    </div>
{% endblock %}
